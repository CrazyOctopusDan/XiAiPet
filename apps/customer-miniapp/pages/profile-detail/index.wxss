.profile-detail-page {
  min-height: 100vh;
  padding: 18rpx 24rpx calc(154rpx + env(safe-area-inset-bottom));
  background: radial-gradient(circle at 12% 0%, rgba(246, 227, 150, 0.4) 0, transparent 34%), linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 58%, #F6E396 100%);
  color: #40535C;
  box-sizing: border-box;
}

.detail-hero-card,
.detail-card {
  border-radius: 34rpx;
  box-sizing: border-box;
}

.detail-hero-card {
  margin-top: 20rpx;
  padding: 34rpx 30rpx;
  background: linear-gradient(135deg, #FFFDF5 0%, #FFF8D8 54%, #F6E396 100%);
  box-shadow: 0 16rpx 36rpx rgba(80, 104, 105, 0.1);
}

.detail-eyebrow,
.detail-title,
.detail-subtitle,
.section-title,
.section-index,
.field-label,
.field-tip,
.contact-value,
.contact-action {
  display: block;
}

.detail-eyebrow {
  width: fit-content;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 230, 163, 0.16);
  font-size: 20rpx;
  font-weight: 700;
  color: #40535C;
}

.detail-title {
  margin-top: 18rpx;
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #40535C;
}

.detail-subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #7B8B92;
}

.detail-card {
  margin-top: 22rpx;
  padding: 30rpx 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 36rpx rgba(80, 104, 105, 0.08);
}

.section-head,
.gender-row,
.field-headline,
.contact-row {
  display: flex;
  align-items: center;
}

.section-head,
.field-headline,
.contact-row {
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #40535C;
}

.section-index {
  flex-shrink: 0;
  font-size: 32rpx;
  font-weight: 900;
  color: rgba(213, 241, 255, 0.18);
}

.field-block {
  margin-top: 28rpx;
}

.field-label {
  font-size: 23rpx;
  font-weight: 700;
  color: #7B8B92;
}

.text-input,
.picker-shell {
  width: 100%;
  height: 92rpx;
  margin-top: 12rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #FFFDF5;
  font-size: 28rpx;
  line-height: 92rpx;
  color: #40535C;
  box-sizing: border-box;
}

.picker-shell.locked {
  background: #FFFDF5;
  color: #7B8B92;
}

.gender-row {
  gap: 14rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.gender-pill {
  min-width: 150rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: #F6E396;
  border: 2rpx solid transparent;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  color: #6B7C84;
  box-sizing: border-box;
}

.gender-pill.active {
  background: #F6E396;
  border-color: #B9DDE8;
  color: #40535C;
  box-shadow: 0 12rpx 26rpx rgba(180, 130, 55, 0.24);
}

.lock-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
  color: #6B7C84;
  box-sizing: border-box;
}

.lock-badge.locked {
  background: #FFFDF5;
  color: #7B8B92;
}

.field-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7B8B92;
}

.contact-row {
  min-height: 116rpx;
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  background: #FFFDF5;
}

.contact-value {
  font-size: 28rpx;
  font-weight: 800;
  color: #40535C;
}

.contact-action {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 22rpx;
  font-weight: 800;
  color: #40535C;
}

.save-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 244, 0.94);
  box-shadow: 0 -16rpx 34rpx rgba(79, 52, 30, 0.08);
}

.save-button {
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #F6E396 0%, #F2C46F 100%);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
  color: #40535C;
  box-shadow: 0 14rpx 26rpx rgba(180, 130, 55, 0.22);
}

.save-button::after {
  border: 0;
}
