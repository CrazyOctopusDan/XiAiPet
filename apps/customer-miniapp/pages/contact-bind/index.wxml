<view class="contact-bind-page">
  <page-nav />
  <view class="contact-hero">
    <view class="hero-copy">
      <text class="eyebrow">联系方式</text>
      <text class="heading">告诉我怎么联系你～</text>
      <text class="body">用于配送确认和定制沟通。</text>
    </view>
    <view class="hero-badge">
      <text class="hero-badge-main">安全</text>
      <text class="hero-badge-sub">仅用于订单</text>
    </view>
  </view>
  <view class="manual-card">
    <text class="card-title">绑定手机号</text>
    <text class="input-label">手机号</text>
    <input class="input" type="number" inputmode="tel" maxlength="11" value="{{manualPhone}}" bindinput="handleManualPhoneInput" placeholder="请输入手机号" />
    <button class="secondary-cta" bindtap="handleManualSubmit" loading="{{submitting}}">
      提交绑定
    </button>
  </view>
  <view class="status-card {{statusTone}}">
    <text class="status-label">当前状态</text>
    <text class="status-text">{{statusText}}</text>
  </view>
</view>
