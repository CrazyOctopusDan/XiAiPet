.contact-bind-page {
  min-height: 100vh;
  padding: 18rpx 24rpx calc(56rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 64%, #F6E396 100%);
  color: #40535C;
  box-sizing: border-box;
}

.contact-hero,
.wechat-card,
.manual-card,
.status-card {
  border-radius: 34rpx;
  box-sizing: border-box;
}

.contact-hero {
  position: relative;
  overflow: hidden;
  margin-top: 20rpx;
  padding: 34rpx 30rpx;
  background: radial-gradient(circle at 15% 0%, #F6E396 0, transparent 42%), linear-gradient(135deg, #FFF6DC 0%, #FFFFFF 100%);
  box-shadow: 0 18rpx 44rpx rgba(80, 104, 105, 0.12);
}

.contact-hero::after {
  content: '';
  position: absolute;
  right: -42rpx;
  top: -38rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(213, 241, 255, 0.13);
}

.hero-copy {
  position: relative;
  z-index: 1;
  padding-right: 156rpx;
}

.eyebrow,
.heading,
.body,
.card-title,
.card-copy,
.input-label,
.status-label,
.status-text,
.hero-badge-main,
.hero-badge-sub {
  display: block;
}

.eyebrow {
  width: fit-content;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 20rpx;
  font-weight: 700;
  color: #40535C;
}

.heading {
  margin-top: 18rpx;
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #40535C;
}

.body,
.card-copy {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #7B8B92;
}

.hero-badge {
  position: absolute;
  right: 28rpx;
  bottom: 30rpx;
  z-index: 1;
  width: 124rpx;
  height: 124rpx;
  border-radius: 38rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #F6E396;
  box-shadow: inset 0 -8rpx 0 rgba(255, 255, 255, 0.08);
}

.hero-badge-main {
  font-size: 30rpx;
  font-weight: 800;
  color: #40535C;
}

.hero-badge-sub {
  margin-top: 4rpx;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.78);
}

.wechat-card,
.manual-card,
.status-card,
.privacy-card {
  margin-top: 22rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 36rpx rgba(80, 104, 105, 0.08);
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #40535C;
}

.card-tag {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 20rpx;
  font-weight: 700;
  color: #6B7C84;
}

.privacy-card {
  border: 2rpx solid rgba(213, 241, 255, 0.18);
  background: #FFFDF5;
  box-shadow: none;
}

.privacy-title,
.privacy-copy {
  display: block;
}

.privacy-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #40535C;
}

.privacy-copy {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: #7B8B92;
}

.primary-cta,
.secondary-cta,
.privacy-cta {
  height: 92rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 92rpx;
}

.primary-cta {
  background: linear-gradient(135deg, #F6E396 0%, #F2C46F 100%);
  color: #40535C;
  box-shadow: 0 14rpx 26rpx rgba(180, 130, 55, 0.22);
}

.secondary-cta {
  background: #F6E396;
  color: #40535C;
}

.privacy-cta {
  background: #FFFFFF;
  color: #6B7C84;
}

.primary-cta::after,
.secondary-cta::after,
.privacy-cta::after {
  border: 0;
}

.input-label {
  margin-top: 24rpx;
  font-size: 23rpx;
  font-weight: 700;
  color: #7B8B92;
}

.input {
  width: 100%;
  height: 92rpx;
  margin-top: 12rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #FFFDF5;
  font-size: 28rpx;
  color: #40535C;
  box-sizing: border-box;
}

.status-card {
  border: 2rpx solid rgba(64, 83, 92, 0.06);
}

.status-card.success {
  border-color: rgba(49, 145, 94, 0.22);
  background: #EEF9F1;
}

.status-card.error {
  border-color: rgba(217, 91, 65, 0.22);
  background: #FFFDF5;
}

.status-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #7B8B92;
}

.status-text {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #40535C;
}
