.catalog-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 12% 0%, rgba(246, 227, 150, 0.22) 0, transparent 30%),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 58%, #F6E396 100%);
  color: #40535C;
  box-sizing: border-box;
}

.catalog-main {
  min-height: 0;
  padding: 8rpx 22rpx 0;
  box-sizing: border-box;
}

.delivery-tabs {
  display: flex;
  gap: 12rpx;
  margin: 0;
  padding: 0 0 18rpx;
}

.delivery-tab {
  flex: 1;
  height: 58rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: 0 10rpx 22rpx rgba(80, 104, 105, 0.06);
  font-size: 25rpx;
  line-height: 58rpx;
  font-weight: 900;
  color: #7B8B92;
  text-align: center;
}

.delivery-tab.active {
  border-color: #40535C;
  background: #F6E396;
  color: #40535C;
}

.catalog-header-row {
  display: grid;
  grid-template-columns: 178rpx minmax(0, 1fr);
  align-items: center;
  gap: 14rpx;
  padding: 0 0 18rpx;
}

.search-box {
  display: flex;
  align-items: center;
  width: 178rpx;
  height: 72rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 22rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.82);
  color: #7B8B92;
  box-shadow: 0 10rpx 22rpx rgba(80, 104, 105, 0.05);
}

.search-icon {
  position: relative;
  flex-shrink: 0;
  width: 26rpx;
  height: 26rpx;
  margin-right: 12rpx;
  border: 4rpx solid #B9DDE8;
  border-radius: 50%;
  box-sizing: border-box;
}

.search-icon::after {
  content: '';
  position: absolute;
  right: -9rpx;
  bottom: -7rpx;
  width: 12rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #B9DDE8;
  transform: rotate(45deg);
}

.search-placeholder {
  display: block;
  font-size: 25rpx;
  line-height: 1.2;
  font-weight: 800;
}

.hero-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 22rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 10rpx 22rpx rgba(80, 104, 105, 0.05);
  font-size: 25rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.catalog-body {
  display: flex;
  gap: 16rpx;
  padding: 0;
}

.category-column {
  width: 148rpx;
  height: calc(100vh - 342rpx);
  padding: 10rpx 0 20rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.05);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.62);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.55);
  box-sizing: border-box;
}

.category-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  margin: 0 10rpx 10rpx;
  padding: 22rpx 8rpx;
  border-radius: 24rpx;
  color: #7B8B92;
  box-sizing: border-box;
}

.category-item.active {
  background: #FFFFFF;
  box-shadow: 0 12rpx 24rpx rgba(80, 104, 105, 0.08);
  color: #40535C;
  font-weight: 900;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: -10rpx;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 999rpx;
  background: #F6E396;
}

.category-icon {
  font-size: 34rpx;
  line-height: 1.1;
  font-weight: 900;
}

.category-label {
  font-size: 20rpx;
  text-align: center;
  line-height: 1.35;
  font-weight: 800;
}

.product-column {
  flex: 1;
  height: calc(100vh - 342rpx);
  padding: 0 2rpx;
  box-sizing: border-box;
}

.catalog-empty {
  display: flex;
  min-height: 360rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 56rpx 34rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  box-sizing: border-box;
  text-align: center;
}

.catalog-empty-title,
.catalog-empty-copy {
  display: block;
}

.catalog-empty-title {
  color: #40535C;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.catalog-empty-copy {
  color: #7B8B92;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.product-section {
  padding-bottom: 30rpx;
}

.section-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding: 8rpx 4rpx 16rpx;
}

.section-title {
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.section-subtitle {
  flex: 1;
  min-width: 0;
  font-size: 21rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #7B8B92;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.product-card {
  position: relative;
  min-height: 480rpx;
  padding: 0 0 74rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 30rpx rgba(80, 104, 105, 0.08);
  overflow: hidden;
  box-sizing: border-box;
}

.product-image {
  width: 100%;
  height: 236rpx;
  background: #FFFDF5;
}

.product-name,
.product-summary,
.product-member,
.product-price,
.product-stock {
  display: block;
  padding: 0 18rpx;
}

.product-name {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.product-summary,
.product-member,
.product-stock {
  margin-top: 10rpx;
  font-size: 21rpx;
  line-height: 1.42;
  font-weight: 700;
  color: #7B8B92;
}

.product-summary {
  min-height: 60rpx;
}

.product-member {
  color: #6B7C84;
}

.product-price {
  position: absolute;
  left: 0;
  bottom: 22rpx;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #E86B61;
}

.product-action {
  position: absolute;
  right: 14rpx;
  bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 100rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  overflow: visible;
  background: #F6E396;
  box-shadow: 0 12rpx 24rpx rgba(82, 116, 126, 0.16);
  font-size: 22rpx;
  line-height: 1;
  font-weight: 900;
  color: #40535C;
}

.product-action.direct {
  width: 58rpx;
  min-width: 58rpx;
  padding: 0;
  border-radius: 50%;
  font-size: 34rpx;
}

.product-action::after {
  border: 0;
}

.product-action-badge {
  position: absolute;
  top: -12rpx;
  right: -10rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFFFFF;
  border-radius: 999rpx;
  box-sizing: border-box;
  background: #E86B61;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1;
  color: #40535C;
}

.product-stepper {
  position: absolute;
  right: 12rpx;
  bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 7rpx;
  border-radius: 999rpx;
  background: #FFFDF5;
  box-shadow: inset 0 0 0 2rpx rgba(80, 104, 105, 0.06);
}

.soldout-toggle {
  margin: 18rpx 4rpx 0;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #7B8B92;
}

.soldout-mask {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 236rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(47, 47, 47, 0.38);
}

.soldout-stamp {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  color: #40535C;
  transform: rotate(-30deg);
}

.catalog-tail-spacer {
  height: 230rpx;
}

.cart-float {
  position: fixed;
  right: 24rpx;
  bottom: calc(42rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 130rpx;
  height: 130rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 40rpx;
  background: #F6E396;
  box-shadow: 0 18rpx 40rpx rgba(82, 116, 126, 0.22);
  box-sizing: border-box;
  color: #40535C;
}

.cart-float-icon {
  position: relative;
  width: 42rpx;
  height: 38rpx;
  border: 4rpx solid #40535C;
  border-top: 0;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.cart-float-handle {
  position: absolute;
  left: 9rpx;
  top: -14rpx;
  width: 18rpx;
  height: 16rpx;
  border: 4rpx solid #40535C;
  border-bottom: 0;
  border-radius: 12rpx 12rpx 0 0;
  box-sizing: border-box;
}

.cart-float-line {
  width: 22rpx;
  height: 4rpx;
  margin: 9rpx auto 0;
  border-radius: 999rpx;
  background: #40535C;
}

.cart-float-line.short {
  width: 14rpx;
  margin-top: 7rpx;
}

.cart-float-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.15;
  font-weight: 900;
}

.cart-float-badge {
  position: absolute;
  right: -10rpx;
  top: -14rpx;
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 8rpx;
  border: 4rpx solid #FFFFFF;
  border-radius: 999rpx;
  box-sizing: border-box;
  background: #E86B61;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
  font-weight: 900;
  color: #fff;
}

.quick-buy-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: calc(96rpx + env(safe-area-inset-top)) 24rpx calc(96rpx + env(safe-area-inset-bottom));
  z-index: 10;
  background: rgba(39, 25, 15, 0.38);
  box-sizing: border-box;
}

.quick-buy-panel {
  position: relative;
  width: 100%;
  max-height: calc(100vh - 192rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  overflow: hidden;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 36rpx;
  background: #FFFDF5;
  box-shadow: 0 28rpx 70rpx rgba(39, 25, 15, 0.2);
}

.quick-buy-image {
  width: 100%;
  height: 330rpx;
  background: #FFFDF5;
}

.product-image-placeholder,
.quick-buy-image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFFDF5 0%, #F6E396 100%);
  box-sizing: border-box;
  text-align: center;
}

.product-image-placeholder text,
.quick-buy-image-placeholder text {
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.quick-buy-close {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: rgba(64, 83, 92, 0.72);
  backdrop-filter: blur(8rpx);
  font-size: 42rpx;
  line-height: 58rpx;
  text-align: center;
  color: #40535C;
}

.quick-buy-content {
  padding: 28rpx 34rpx 0;
}

.quick-buy-name {
  display: block;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.quick-buy-summary {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.55;
  font-weight: 700;
  color: #7B8B92;
}

.quick-buy-member {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #6B7C84;
}

.quick-buy-spec-title {
  display: block;
  margin-top: 28rpx;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.quick-buy-specs {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.quick-buy-spec {
  padding: 16rpx 26rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 999rpx;
  background: #FFFFFF;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #7B8B92;
}

.quick-buy-spec.active {
  border-color: #40535C;
  background: #F6E396;
  color: #40535C;
}

.quick-buy-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 34rpx 0;
}

.quick-buy-price {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #E86B61;
}

.quick-buy-stepper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 7rpx;
  border-radius: 999rpx;
  background: #FFFDF5;
  box-shadow: inset 0 0 0 2rpx rgba(80, 104, 105, 0.06);
}

.stepper-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border: 2rpx solid #D8EEF2;
  border-radius: 50%;
  background: #FFFFFF;
  font-size: 0;
  line-height: 1;
  font-weight: 800;
  color: #7B8B92;
}

.stepper-btn::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 18rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #7B8B92;
  transform: translate(-50%, -50%);
}

.stepper-btn.plus {
  border-color: #40535C;
  background: #F6E396;
  color: #40535C;
}

.stepper-btn.plus::before,
.stepper-btn.plus::after {
  background: #40535C;
}

.stepper-btn.plus::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 5rpx;
  height: 18rpx;
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
}

.stepper-count {
  min-width: 22rpx;
  font-size: 25rpx;
  line-height: 1;
  font-weight: 900;
  text-align: center;
  color: #40535C;
}

.quick-buy-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin: 24rpx 34rpx 34rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #F6E396;
  box-shadow: 0 18rpx 38rpx rgba(82, 116, 126, 0.18);
  font-size: 28rpx;
  line-height: 88rpx;
  font-weight: 900;
  color: #40535C;
}

.quick-buy-submit::after {
  border: 0;
}
