.pets-page {
  min-height: 100vh;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 14% 0%, rgba(246, 190, 62, 0.22) 0, transparent 30%),
    linear-gradient(180deg, #FFF8EA 0%, #FFFDF6 54%, #F6E7C8 100%);
  color: #3A2A1E;
  box-sizing: border-box;
}

.pet-card-head {
  display: flex;
  align-items: center;
}

.pets-shell {
  padding: 26rpx 24rpx 0;
}

.pet-name,
.pet-meta,
.pet-allergy-label,
.pet-allergy-copy,
.empty-title,
.empty-copy {
  display: block;
}

.pet-list {
  margin-top: 8rpx;
}

.pet-card {
  margin-top: 18rpx;
  padding: 30rpx 26rpx;
  border: 2rpx solid rgba(82, 49, 24, 0.06);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 34rpx rgba(106, 72, 39, 0.08);
  box-sizing: border-box;
}

.pet-card-head {
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.pet-name {
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #3A2A1E;
}

.pet-meta {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #9A7B60;
}

.pet-edit {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  min-width: 132rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #3A2A1E;
  font-size: 23rpx;
  font-weight: 900;
  color: #FFE6A3;
}

.pet-allergy-label {
  margin-top: 22rpx;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #9A7B60;
}

.pet-allergy-copy {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.6;
  font-weight: 700;
  color: #6F5B47;
}

.empty-state {
  margin-top: 8rpx;
  padding: 80rpx 32rpx;
  border: 2rpx dashed rgba(82, 49, 24, 0.14);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.72);
  text-align: center;
  box-sizing: border-box;
}

.empty-title {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #3A2A1E;
}

.empty-copy {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 700;
  color: #8A6D53;
}

.pet-fixed-action {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 246, 0.94);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 -12rpx 32rpx rgba(72, 41, 17, 0.08);
  box-sizing: border-box;
}

.pet-add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #3A2A1E;
  font-size: 30rpx;
  line-height: 96rpx;
  font-weight: 900;
  color: #FFE6A3;
  box-shadow: 0 18rpx 38rpx rgba(72, 41, 17, 0.2);
}

.pet-add-button::after {
  border: 0;
}
