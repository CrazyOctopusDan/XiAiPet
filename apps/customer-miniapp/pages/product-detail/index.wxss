.detail-page {
  min-height: 100vh;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
  background: #F9F5D9;
}

.detail-swiper,
.detail-image {
  width: 100%;
  height: 700rpx;
}

.swiper-indicator {
  position: absolute;
  right: 22rpx;
  top: 610rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(32, 32, 32, 0.58);
  font-size: 22rpx;
  color: #FFFFFF;
}

.detail-card {
  margin: 18rpx 0;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
}

.intro-card {
  margin-top: 0;
}

.detail-title {
  display: block;
  font-size: 54rpx;
  font-weight: 700;
  color: #2A2A2A;
}

.detail-summary,
.detail-description,
.detail-member {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6C6762;
}

.detail-description {
  color: #5D564E;
}

.section-title {
  display: block;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #6B6760;
}

.spec-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spec-pill {
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: #F3F3F3;
  font-size: 22rpx;
  color: #6A645D;
}

.spec-pill.active {
  background: #F5E0A7;
  color: #9A6A3A;
}

.selected-spec-text {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #9A6A3A;
}

.long-image-card {
  padding-bottom: 12rpx;
}

.long-detail-image {
  width: 100%;
  margin-bottom: 14rpx;
  border-radius: 18rpx;
}

.detail-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 22rpx 18rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid rgba(79, 52, 30, 0.06);
  background: rgba(255, 255, 255, 0.98);
}

.bottom-top-row,
.bottom-bottom-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.bottom-selection-meta {
  flex: 1;
  min-width: 0;
}

.bottom-side-actions {
  display: flex;
  gap: 4rpx;
  width: 200rpx;
  flex-shrink: 0;
}

.side-action {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 92rpx;
}

.side-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
}

.side-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #4C453E;
}

.share-node,
.share-line,
.cart-basket,
.cart-handle,
.cart-wheel {
  position: absolute;
  box-sizing: border-box;
}

.share-node {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #544B43;
}

.share-node.left {
  left: 4rpx;
  top: 16rpx;
}

.share-node.top {
  right: 6rpx;
  top: 6rpx;
}

.share-node.bottom {
  right: 6rpx;
  bottom: 6rpx;
}

.share-line {
  left: 10rpx;
  width: 20rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #544B43;
  transform-origin: left center;
}

.share-line.upper {
  top: 16rpx;
  transform: rotate(-26deg);
}

.share-line.lower {
  bottom: 16rpx;
  transform: rotate(26deg);
}

.cart-basket {
  left: 7rpx;
  top: 13rpx;
  width: 24rpx;
  height: 16rpx;
  border: 3rpx solid #544B43;
  border-top: 0;
  border-radius: 0 0 8rpx 8rpx;
}

.cart-handle {
  left: 13rpx;
  top: 7rpx;
  width: 12rpx;
  height: 8rpx;
  border: 3rpx solid #544B43;
  border-bottom: 0;
  border-radius: 10rpx 10rpx 0 0;
}

.cart-wheel {
  bottom: 5rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: #544B43;
}

.cart-wheel.left {
  left: 10rpx;
}

.cart-wheel.right {
  right: 10rpx;
}

.cart-badge {
  position: absolute;
  right: 8rpx;
  top: 0;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 6rpx;
  border-radius: 16rpx;
  background: #F7C738;
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
  color: #FFFFFF;
}

.bottom-price {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
  color: #2D2D2D;
}

.bottom-selection-label {
  display: block;
  margin-top: 12rpx;
  overflow: hidden;
  font-size: 24rpx;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #5C544D;
}

.bottom-selection-label.placeholder {
  color: #B5A180;
}

.detail-stepper {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex-shrink: 0;
}

.stepper-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border: 3rpx solid #F2B12A;
  border-radius: 50%;
  box-sizing: border-box;
  font-size: 38rpx;
  line-height: 1;
  color: #F2B12A;
}

.stepper-btn.plus {
  background: #F7C43C;
  border-color: #F7C43C;
  color: #FFFFFF;
}

.stepper-count {
  min-width: 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
  text-align: center;
  color: #2D2D2D;
}

.add-cart-button {
  flex: 1;
  height: 84rpx;
  margin: 0;
  padding: 0 36rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: #F7C43C;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: 2rpx;
  color: #FFFFFF;
}

.add-cart-button.disabled {
  background: #E6D39D;
  color: rgba(255, 255, 255, 0.98);
}

.add-cart-button::after {
  border: 0;
}
