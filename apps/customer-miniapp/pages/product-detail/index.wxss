.detail-page {
  min-height: 100vh;
  padding-bottom: calc(250rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 12% 0%, rgba(246, 227, 150, 0.18) 0, transparent 30%),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 58%, #F6E396 100%);
  color: #40535C;
  box-sizing: border-box;
}

.detail-swiper {
  width: 100%;
  height: 670rpx;
  overflow: hidden;
  background: #FFFDF5;
}

.detail-image {
  width: 100%;
  height: 670rpx;
}

.swiper-indicator {
  position: absolute;
  right: 28rpx;
  top: 584rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(213, 241, 255, 0.88);
  backdrop-filter: blur(8rpx);
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.detail-card {
  margin: 18rpx 24rpx;
  padding: 32rpx 28rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
  box-sizing: border-box;
}

.intro-card {
  position: relative;
  margin-top: -74rpx;
  border-radius: 36rpx;
}

.detail-title {
  display: block;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 900;
  color: #40535C;
}

.detail-summary,
.detail-description,
.detail-member {
  display: block;
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.55;
  font-weight: 700;
  color: #7B8B92;
}

.detail-description {
  color: #7B8B92;
}

.detail-member {
  width: fit-content;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #6B7C84;
}

.spec-card {
  padding-bottom: 30rpx;
}

.section-title {
  display: block;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.spec-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spec-pill {
  padding: 17rpx 30rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 999rpx;
  background: #FFFFFF;
  box-sizing: border-box;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #7B8B92;
}

.spec-pill.active {
  border-color: #40535C;
  background: #F6E396;
  color: #40535C;
}

.selected-spec-text {
  display: block;
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #FFFDF5;
  font-size: 23rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #6B7C84;
}

.long-image-card {
  padding: 30rpx 0 10rpx;
  overflow: hidden;
}

.long-image-card .section-title {
  padding: 0 28rpx;
}

.long-detail-image {
  width: 100%;
  margin-bottom: 14rpx;
  background: #FFFDF5;
}

.detail-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 22rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid rgba(80, 104, 105, 0.06);
  background: rgba(255, 253, 246, 0.96);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 -18rpx 42rpx rgba(80, 104, 105, 0.1);
  box-sizing: border-box;
}

.bottom-top-row,
.bottom-bottom-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.bottom-selection-meta {
  flex: 1;
  min-width: 0;
}

.bottom-side-actions {
  display: flex;
  gap: 8rpx;
  width: 186rpx;
  flex-shrink: 0;
}

.side-action {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 88rpx;
  border-radius: 24rpx;
  color: #7B8B92;
}

.side-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
}

.side-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #7B8B92;
}

.share-node,
.share-line,
.cart-basket,
.cart-handle,
.cart-wheel {
  position: absolute;
  box-sizing: border-box;
}

.share-node {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #40535C;
}

.share-node.left {
  left: 4rpx;
  top: 16rpx;
}

.share-node.top {
  right: 6rpx;
  top: 6rpx;
}

.share-node.bottom {
  right: 6rpx;
  bottom: 6rpx;
}

.share-line {
  left: 10rpx;
  width: 20rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #40535C;
  transform-origin: left center;
}

.share-line.upper {
  top: 16rpx;
  transform: rotate(-26deg);
}

.share-line.lower {
  bottom: 16rpx;
  transform: rotate(26deg);
}

.cart-basket {
  left: 7rpx;
  top: 13rpx;
  width: 24rpx;
  height: 16rpx;
  border: 3rpx solid #40535C;
  border-top: 0;
  border-radius: 0 0 8rpx 8rpx;
}

.cart-handle {
  left: 13rpx;
  top: 7rpx;
  width: 12rpx;
  height: 8rpx;
  border: 3rpx solid #40535C;
  border-bottom: 0;
  border-radius: 10rpx 10rpx 0 0;
}

.cart-wheel {
  bottom: 5rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: #40535C;
}

.cart-wheel.left {
  left: 10rpx;
}

.cart-wheel.right {
  right: 10rpx;
}

.cart-badge {
  position: absolute;
  right: 4rpx;
  top: 0;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border: 4rpx solid #FFFDF5;
  border-radius: 999rpx;
  box-sizing: border-box;
  background: #E86B61;
  font-size: 18rpx;
  line-height: 26rpx;
  text-align: center;
  font-weight: 900;
  color: #FFFFFF;
}

.bottom-price {
  display: block;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
  color: #E86B61;
}

.bottom-selection-label {
  display: block;
  margin-top: 12rpx;
  overflow: hidden;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #7B8B92;
}

.bottom-selection-label.placeholder {
  color: #7B8B92;
}

.detail-stepper {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex-shrink: 0;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #FFFDF5;
  box-shadow: inset 0 0 0 2rpx rgba(80, 104, 105, 0.06);
}

.stepper-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border: 2rpx solid #D8EEF2;
  border-radius: 50%;
  box-sizing: border-box;
  background: #FFFFFF;
  font-size: 0;
  line-height: 0;
  font-weight: 800;
  color: #7B8B92;
}

.stepper-btn::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 18rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #7B8B92;
  transform: translate(-50%, -50%);
}

.stepper-btn.plus {
  border-color: #40535C;
  background: #F6E396;
  color: #40535C;
}

.stepper-btn.plus::before,
.stepper-btn.plus::after {
  background: #40535C;
}

.stepper-btn.plus::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 5rpx;
  height: 18rpx;
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
}

.stepper-count {
  min-width: 26rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
  color: #40535C;
}

.add-cart-button {
  flex: 1;
  height: 88rpx;
  margin: 0;
  padding: 0 36rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: #F6E396;
  box-shadow: 0 18rpx 38rpx rgba(82, 116, 126, 0.18);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.1;
  letter-spacing: 0;
  color: #40535C;
}

.add-cart-button.disabled {
  background: #F6E396;
  box-shadow: 0 14rpx 28rpx rgba(82, 116, 126, 0.12);
  opacity: 0.62;
  color: #40535C;
}

.add-cart-button::after {
  border: 0;
}
