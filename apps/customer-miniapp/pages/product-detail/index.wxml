<view class="detail-page" wx:if="{{product}}">
  <page-nav theme="light" reserve-space="{{false}}" />

  <swiper wx:if="{{product.gallery.length}}" class="detail-swiper" circular="true" indicator-dots="false" current="{{swiperIndex - 1}}" autoplay="{{product.gallery.length > 1}}" interval="3000" bindchange="handleSwiperChange">
    <swiper-item wx:for="{{product.gallery}}" wx:key="*this">
      <image class="detail-image" mode="aspectFill" src="{{item}}" />
    </swiper-item>
  </swiper>
  <view wx:else class="detail-swiper detail-swiper-placeholder"><text>{{product.name}}</text></view>
  <view class="swiper-indicator" wx:if="{{product.gallery.length}}">{{swiperIndex}}/{{product.gallery.length}}</view>

  <view class="detail-card intro-card">
    <text class="detail-title">{{product.name}}</text>
    <text class="detail-summary">{{product.summary}}</text>
    <text class="detail-description">{{product.description}}</text>
    <text class="detail-member">{{product.memberLevelLabel}}</text>
  </view>

  <view class="detail-card spec-card" wx:if="{{product.specs.length}}">
    <text class="section-title">尺寸和口味选择</text>
    <view class="spec-grid">
      <view class="spec-pill {{selectedSpecId === item.id ? 'active' : ''}}" wx:for="{{product.specs}}" wx:key="id" data-spec-id="{{item.id}}" bindtap="handleSpecTap">{{item.label}}</view>
    </view>
    <text class="selected-spec-text">当前选择：{{selectedSpecLabel}}</text>
  </view>

  <view class="detail-card long-image-card" wx:if="{{product.detailImages.length}}">
    <text class="section-title">商品详情</text>
    <image class="long-detail-image" wx:for="{{product.detailImages}}" wx:key="*this" mode="widthFix" src="{{item}}" />
  </view>

  <view class="detail-bottom-bar">
    <view class="bottom-top-row">
      <view class="bottom-selection-meta">
        <text class="bottom-price">￥{{selectedPrice}}</text>
        <text class="bottom-selection-label {{isAddToCartDisabled ? 'placeholder' : ''}}">{{selectedSpecLabel}}</text>
      </view>
      <view class="detail-stepper">
        <view class="stepper-btn" bindtap="handleMinus">-</view>
        <text class="stepper-count">{{quantity}}</text>
        <view class="stepper-btn plus" bindtap="handlePlus">+</view>
      </view>
    </view>
    <view class="bottom-bottom-row">
      <view class="bottom-side-actions">
        <view class="side-action" bindtap="handleShareTap">
          <view class="side-icon share-icon">
            <view class="share-node left"></view>
            <view class="share-node top"></view>
            <view class="share-node bottom"></view>
            <view class="share-line upper"></view>
            <view class="share-line lower"></view>
          </view>
          <text class="side-label">分享</text>
        </view>
        <view class="side-action" bindtap="handleCartTap">
          <view class="side-icon cart-icon">
            <view class="cart-handle"></view>
            <view class="cart-basket"></view>
            <view class="cart-wheel left"></view>
            <view class="cart-wheel right"></view>
          </view>
          <text class="side-label">购物车</text>
          <view class="cart-badge" wx:if="{{cartCount}}">{{cartCount}}</view>
        </view>
      </view>
      <button class="add-cart-button {{isAddToCartDisabled ? 'disabled' : ''}}" bindtap="handleAddToCart">加入购物车</button>
    </view>
  </view>
</view>
