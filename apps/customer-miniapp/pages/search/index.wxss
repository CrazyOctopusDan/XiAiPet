.search-page {
  min-height: 100vh;
  background: #FFFFFF;
}
.search-input-row {
  display: flex;
  align-items: center;
}

.search-input-row {
  gap: 16rpx;
  padding: 20rpx 24rpx 26rpx;
}

.search-input-shell {
  display: flex;
  align-items: center;
  flex: 1;
  height: 84rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #F6F6F6;
}

.search-input {
  flex: 1;
  margin-left: 10rpx;
}

.cancel-text {
  font-size: 32rpx;
  color: #22B800;
}

.results-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  padding: 0 8rpx 40rpx;
}

.result-card {
  position: relative;
  background: #FFFFFF;
}

.result-image {
  width: 100%;
  height: 360rpx;
  border-radius: 20rpx;
}

.result-name,
.result-summary,
.result-member,
.result-stock,
.result-price {
  display: block;
  padding: 0 12rpx;
}

.result-name {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.result-summary,
.result-member,
.result-stock {
  margin-top: 10rpx;
  font-size: 18rpx;
  color: #9C9C9C;
}

.result-member {
  color: #9A6A3A;
}

.result-price {
  margin-top: 18rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #FF3A30;
}

.result-soldout-label {
  position: absolute;
  right: 14rpx;
  bottom: 18rpx;
  font-size: 20rpx;
  color: #8E8A84;
}

.result-action {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 98rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  overflow: visible;
  background: #D9A15B;
  font-size: 20rpx;
  line-height: 1;
  color: #FFFFFF;
}

.result-action.direct {
  width: 48rpx;
  min-width: 48rpx;
  padding: 0;
  font-size: 34rpx;
}

.result-action::after {
  border: 0;
}

.result-action-badge {
  position: absolute;
  top: -12rpx;
  right: -10rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFFFFF;
  border-radius: 999rpx;
  box-sizing: border-box;
  background: #FF3B30;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1;
  color: #FFFFFF;
}

.result-stepper {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.stepper-circle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid #D8D8D8;
  border-radius: 24rpx;
  background: #FFFFFF;
  font-size: 32rpx;
  line-height: 1;
  color: #B5B5B5;
}

.stepper-circle.plus {
  border-color: #D9A15B;
  background: #D9A15B;
  color: #FFFFFF;
}

.stepper-value {
  min-width: 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #63594E;
  text-align: center;
}

.soldout-mask {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: rgba(47, 47, 47, 0.38);
}

.soldout-stamp {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 156rpx;
  height: 156rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 78rpx;
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #FFFFFF;
  transform: rotate(-30deg);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 240rpx;
  color: #8B8175;
}

.guide-state {
  color: #A0917E;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
}

.empty-body {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.quick-buy-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  z-index: 10;
  background: rgba(0, 0, 0, 0.34);
}

.quick-buy-panel {
  position: relative;
  width: 100%;
  overflow: hidden;
  border-radius: 36rpx;
  background: #FFFFFF;
}

.quick-buy-image {
  width: 100%;
  height: 360rpx;
}

.quick-buy-close {
  position: absolute;
  right: 26rpx;
  top: 26rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.5);
  font-size: 40rpx;
  line-height: 60rpx;
  text-align: center;
  color: #FFFFFF;
}

.quick-buy-content {
  padding: 28rpx 38rpx 0;
}

.quick-buy-name {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #4F341E;
}

.quick-buy-summary {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #726D68;
}

.quick-buy-member {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9A6A3A;
}

.quick-buy-spec-title {
  display: block;
  margin-top: 28rpx;
  font-size: 30rpx;
  color: #6E675F;
}

.quick-buy-specs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.quick-buy-spec {
  padding: 18rpx 30rpx;
  border-radius: 999rpx;
  background: #F4F4F4;
  font-size: 24rpx;
  color: #6E675F;
}

.quick-buy-spec.active {
  background: #F9E3A1;
  color: #9A6A3A;
}

.quick-buy-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 38rpx 0;
}

.quick-buy-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #313131;
}

.quick-buy-stepper {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  border: 2rpx solid #E0B447;
  border-radius: 28rpx;
  font-size: 38rpx;
  line-height: 52rpx;
  text-align: center;
  color: #D0A541;
}

.stepper-btn.plus {
  background: #F0C94C;
  color: #FFFFFF;
}

.stepper-count {
  font-size: 36rpx;
  color: #313131;
}

.quick-buy-submit {
  margin: 24rpx 38rpx 34rpx;
  border-radius: 999rpx;
  background: #F7C43C;
  font-weight: 600;
  color: #FFFFFF;
}
