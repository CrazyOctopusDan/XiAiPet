.checkout-page {
  min-height: 100vh;
  padding-bottom: calc(246rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 88% 6%, rgba(213, 241, 255, 0.34) 0, rgba(213, 241, 255, 0) 260rpx),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 70%, #F9EAA6 100%);
}
.checkout-card-head,
.checkout-bottom-bar {
  display: flex;
  align-items: center;
}

.checkout-shell {
  padding: 18rpx 20rpx 0;
}

.checkout-hero,
.checkout-card {
  border: 2rpx solid rgba(226, 194, 134, 0.46);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 42rpx rgba(112, 82, 42, 0.08);
  box-sizing: border-box;
}

.checkout-hero {
  padding: 32rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 253, 245, 0.95), rgba(255, 247, 210, 0.9));
}

.checkout-title,
.checkout-subtitle,
.pickup-phone-hint,
.pet-choice-hint,
.notice-copy,
.fulfillment-mode-label,
.fulfillment-mode-hint,
.store-name,
.store-address,
.reservation-date,
.remark-summary-text,
.gift-summary-text,
.selected-gift-name,
.selected-gift-desc,
.pet-choice-name,
.pet-choice-meta,
.notice-check-label,
.payment-method-label,
.payment-method-hint,
.fee-label,
.fee-value {
  display: block;
}

.checkout-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #40535C;
}

.checkout-subtitle,
.pickup-phone-hint,
.pet-choice-hint,
.notice-copy {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7B8B92;
}

.checkout-card {
  margin-top: 18rpx;
  padding: 26rpx 24rpx;
}

.checkout-card-head {
  justify-content: space-between;
}

.checkout-card-title,
.checkout-card-summary {
  font-size: 28rpx;
  font-weight: 700;
  color: #40535C;
}

.checkout-card-summary {
  color: #758A93;
}

.fulfillment-mode-row,
.pet-choice-row,
.checkout-bottom-actions {
  display: flex;
}

.fulfillment-mode-row {
  gap: 16rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.fulfillment-mode-pill {
  flex: 1;
  min-width: 188rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(226, 194, 134, 0.28);
  background: #FFFDF5;
  box-sizing: border-box;
}

.fulfillment-mode-pill.active {
  border-color: rgba(213, 241, 255, 0.9);
  background: #F6E396;
  box-shadow: 0 10rpx 24rpx rgba(190, 143, 54, 0.16);
}

.fulfillment-mode-label,
.store-name,
.reservation-date,
.pet-choice-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #40535C;
}

.fulfillment-mode-pill.active .fulfillment-mode-label,
.fulfillment-mode-pill.active .fulfillment-mode-hint {
  color: #40535C;
}

.fulfillment-mode-hint,
.store-address,
.pet-choice-meta,
.remark-summary-text,
.notice-check-label,
.payment-method-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7B8B92;
}

.store-card,
.address-summary-card,
.address-empty-card {
  margin-top: 20rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
}

.store-card,
.address-summary-card,
.remark-summary-card,
.gift-summary-card,
.notice-card {
  border: 2rpx solid rgba(226, 194, 134, 0.22);
  background: rgba(255, 253, 245, 0.9);
  box-sizing: border-box;
}

.address-empty-card {
  border: 2rpx dashed #E4D8C5;
  background: #FFFCF5;
}

.address-summary-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.address-summary-name,
.address-summary-phone,
.address-summary-body,
.address-empty-title,
.address-empty-body {
  display: block;
}

.address-summary-name,
.address-empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #40535C;
}

.address-summary-phone {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #876C53;
}

.address-summary-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #F0D39A;
  font-size: 20rpx;
  color: #6A4D2E;
}

.address-summary-body,
.address-empty-body {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7B8B92;
}

.pickup-phone-input {
  margin-top: 20rpx;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(226, 194, 134, 0.32);
  background: #FFFDF5;
  font-size: 28rpx;
  color: #40535C;
  box-sizing: border-box;
}

.pet-choice-row {
  gap: 14rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.pet-choice {
  padding: 14rpx 20rpx;
  border-radius: 22rpx;
  background: #FFFDF5;
}

.reservation-summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(226, 194, 134, 0.24);
  background: #FFFDF5;
  box-sizing: border-box;
}

.reservation-summary-title,
.reservation-summary-hint,
.reservation-summary-action {
  display: block;
}

.reservation-summary-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #40535C;
}

.reservation-summary-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7B8B92;
}

.reservation-summary-action {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 22rpx;
  font-weight: 700;
  color: #40535C;
}

.reservation-slot {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 68rpx;
  padding: 0 8rpx;
  border-radius: 20rpx;
  background: rgba(255, 253, 245, 0.92);
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  color: #7B8B92;
  box-sizing: border-box;
}

.reservation-slot.active,
.pet-choice.active {
  background: #F6E396;
  color: #40535C;
}

.pet-choice {
  border: 2rpx solid transparent;
  box-shadow: 0 8rpx 20rpx rgba(80, 104, 105, 0.06);
  box-sizing: border-box;
}

.pet-choice.active {
  border-color: #B9DDE8;
  box-shadow: 0 12rpx 26rpx rgba(180, 130, 55, 0.28);
}

.pet-choice.active .pet-choice-name,
.pet-choice.active .pet-choice-meta {
  color: #40535C;
}

.remark-summary-card,
.gift-summary-card,
.notice-card {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 24rpx;
}

.gift-summary-card {
  padding-top: 12rpx;
  padding-bottom: 12rpx;
}

.gift-summary-text {
  padding: 10rpx 0;
  font-size: 24rpx;
  color: #7B8B92;
}

.selected-gift-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 14rpx 0;
}

.selected-gift-row + .selected-gift-row {
  border-top: 2rpx solid rgba(64, 83, 92, 0.08);
}

.selected-gift-main {
  flex: 1;
  min-width: 0;
}

.selected-gift-name {
  font-size: 25rpx;
  font-weight: 800;
  color: #40535C;
}

.selected-gift-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #7B8B92;
}

.selected-gift-days {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 21rpx;
  font-weight: 800;
  color: #40535C;
}

.fee-row,
.fee-value-with-arrow,
.payment-method-row {
  display: flex;
}

.fee-row {
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
}

.fee-row:first-of-type {
  margin-top: 22rpx;
}

.fee-label {
  font-size: 24rpx;
  color: #7B8B92;
}

.fee-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #40535C;
}

.delivery-fee-row {
  min-height: 56rpx;
}

.fee-value-with-arrow {
  align-items: center;
  gap: 8rpx;
}

.fee-arrow {
  font-size: 34rpx;
  line-height: 1;
  color: #7B8B92;
}

.payment-method-row {
  gap: 14rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.payment-method-pill {
  flex: 1;
  min-width: 220rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(226, 194, 134, 0.24);
  background: #FFFDF5;
  box-sizing: border-box;
}

.payment-method-pill.active {
  background: #F6E396;
  border-color: rgba(213, 241, 255, 0.9);
}

.payment-method-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #40535C;
}

.payment-method-pill.active .payment-method-label,
.payment-method-pill.active .payment-method-hint {
  color: #40535C;
}

.remark-summary-text,
.notice-copy {
  margin-top: 0;
}

.notice-check-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.notice-check {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 2rpx solid #D4B37C;
  background: #FFFFFF;
  box-sizing: border-box;
}

.notice-check.active {
  background: #F6E396;
  border-color: #B9DDE8;
}

.notice-check-mark {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  color: #40535C;
}

.checkout-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-top: 22rpx;
}

.checkout-item-image {
  width: 116rpx;
  height: 116rpx;
  border-radius: 18rpx;
  background: #FFFDF5;
}

.checkout-item-image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx;
  background: linear-gradient(135deg, #FFFDF5 0%, #F6E396 100%);
  box-sizing: border-box;
  text-align: center;
}

.checkout-item-image-placeholder text {
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.checkout-item-main {
  flex: 1;
  min-width: 0;
}

.checkout-item-name,
.checkout-item-spec,
.checkout-item-price {
  display: block;
}

.checkout-item-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #333333;
}

.checkout-item-spec {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7B8B92;
}

.checkout-item-price {
  font-size: 26rpx;
  font-weight: 700;
  color: #FF5D4A;
}

.checkout-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 20rpx calc(30rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid rgba(226, 194, 134, 0.36);
  background: rgba(255, 253, 245, 0.96);
  box-shadow: 0 -18rpx 44rpx rgba(112, 82, 42, 0.1);
  box-sizing: border-box;
}

.checkout-total {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #40535C;
}

.checkout-bottom-actions {
  gap: 14rpx;
}

.checkout-total-price {
  margin-left: 8rpx;
  color: #FF3A30;
}

.checkout-return,
.checkout-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 200rpx;
  height: 86rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
}

.checkout-return {
  background: #FFFDF5;
  color: #6B5A47;
}

.checkout-submit {
  background: #F6E396;
  color: #40535C;
  box-shadow: 0 12rpx 26rpx rgba(190, 143, 54, 0.2);
}

.checkout-submit.disabled {
  background: #E3D7C3;
  color: #9D907C;
}

.checkout-return::after,
.checkout-submit::after {
  border: 0;
}

.reservation-mask {
  position: fixed;
  inset: 0;
  z-index: 45;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(0, 0, 0, 0.28);
}

.reservation-panel {
  width: 100%;
  max-height: 78vh;
  padding: 28rpx 24rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #FFFDF5;
  box-shadow: 0 -18rpx 48rpx rgba(38, 28, 16, 0.18);
  box-sizing: border-box;
}

.reservation-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.reservation-panel-title,
.reservation-panel-subtitle,
.reservation-date-name,
.reservation-date-count {
  display: block;
}

.reservation-panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #40535C;
}

.reservation-panel-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7B8B92;
}

.reservation-panel-close {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #FFFFFF;
  font-size: 36rpx;
  line-height: 1;
  color: #7B8B92;
}

.reservation-picker {
  display: flex;
  gap: 18rpx;
  height: 600rpx;
  margin-top: 24rpx;
}

.reservation-date-list {
  width: 188rpx;
  height: 100%;
  border-radius: 24rpx;
  background: rgba(248, 242, 232, 0.88);
}

.reservation-date-tab {
  margin: 10rpx;
  padding: 18rpx 14rpx;
  border-radius: 20rpx;
  color: #7B8B92;
}

.reservation-date-tab.active {
  background: #F6E396;
  color: #40535C;
  box-shadow: 0 10rpx 22rpx rgba(180, 130, 55, 0.26);
}

.reservation-date-name {
  font-size: 23rpx;
  font-weight: 700;
}

.reservation-date-count {
  margin-top: 6rpx;
  font-size: 19rpx;
  opacity: 0.76;
}

.reservation-time-list {
  flex: 1;
  height: 100%;
}

.reservation-slot-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.reservation-confirm {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  color: #40535C;
  box-shadow: 0 12rpx 26rpx rgba(190, 143, 54, 0.18);
}

.reservation-confirm::after {
  border: 0;
}

.delivery-fee-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.28);
}

.delivery-fee-panel {
  width: 560rpx;
  max-width: 100%;
  padding: 28rpx 28rpx 30rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(226, 194, 134, 0.42);
  background: #FFFDF5;
  box-shadow: 0 20rpx 52rpx rgba(38, 28, 16, 0.16);
  box-sizing: border-box;
}

.delivery-fee-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.delivery-fee-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #40535C;
}

.delivery-fee-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #FFFFFF;
  font-size: 34rpx;
  line-height: 1;
  color: #7B8B92;
}

.delivery-fee-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.delivery-fee-detail {
  display: block;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(226, 194, 134, 0.2);
  background: #FFFFFF;
  font-size: 24rpx;
  line-height: 1.45;
  color: #5F5144;
  box-sizing: border-box;
}
