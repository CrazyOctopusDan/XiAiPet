.checkout-page {
  min-height: 100vh;
  padding-bottom: 220rpx;
  background: #F7F4EA;
}
.checkout-card-head,
.checkout-bottom-bar {
  display: flex;
  align-items: center;
}

.checkout-shell {
  padding: 16rpx 20rpx 0;
}

.checkout-hero,
.checkout-card {
  border-radius: 28rpx;
  background: #FFFFFF;
}

.checkout-hero {
  padding: 30rpx 28rpx;
}

.checkout-title,
.checkout-subtitle,
.pickup-phone-hint,
.pet-choice-hint,
.notice-copy,
.fulfillment-mode-label,
.fulfillment-mode-hint,
.store-name,
.store-address,
.reservation-date,
.remark-summary-text,
.pet-choice-name,
.pet-choice-meta,
.notice-check-label,
.payment-method-label,
.payment-method-hint,
.fee-label,
.fee-value {
  display: block;
}

.checkout-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #2E261F;
}

.checkout-subtitle,
.pickup-phone-hint,
.pet-choice-hint,
.notice-copy {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7E766D;
}

.checkout-card {
  margin-top: 18rpx;
  padding: 26rpx 24rpx;
}

.checkout-card-head {
  justify-content: space-between;
}

.checkout-card-title,
.checkout-card-summary {
  font-size: 28rpx;
  font-weight: 700;
  color: #2E261F;
}

.checkout-card-summary {
  color: #9A6A3A;
}

.fulfillment-mode-row,
.pet-choice-row,
.checkout-bottom-actions {
  display: flex;
}

.fulfillment-mode-row {
  gap: 16rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.fulfillment-mode-pill {
  flex: 1;
  min-width: 188rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #F5EFE3;
}

.fulfillment-mode-pill.active {
  background: #F6BE3E;
}

.fulfillment-mode-label,
.store-name,
.reservation-date,
.pet-choice-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #2E261F;
}

.fulfillment-mode-pill.active .fulfillment-mode-label,
.fulfillment-mode-pill.active .fulfillment-mode-hint {
  color: #FFFFFF;
}

.fulfillment-mode-hint,
.store-address,
.pet-choice-meta,
.remark-summary-text,
.notice-check-label,
.payment-method-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7E766D;
}

.store-card,
.address-summary-card,
.address-empty-card {
  margin-top: 20rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
}

.store-card,
.address-summary-card,
.remark-summary-card,
.notice-card {
  background: #FFF7E6;
}

.address-empty-card {
  border: 2rpx dashed #E4D8C5;
  background: #FFFCF5;
}

.address-summary-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.address-summary-name,
.address-summary-phone,
.address-summary-body,
.address-empty-title,
.address-empty-body {
  display: block;
}

.address-summary-name,
.address-empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2E261F;
}

.address-summary-phone {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #876C53;
}

.address-summary-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #F0D39A;
  font-size: 20rpx;
  color: #6A4D2E;
}

.address-summary-body,
.address-empty-body {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6F6457;
}

.pickup-phone-input {
  margin-top: 20rpx;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #FFF7E6;
  font-size: 28rpx;
  color: #2E261F;
}

.pet-choice-row {
  gap: 14rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.pet-choice {
  padding: 14rpx 20rpx;
  border-radius: 22rpx;
  background: #F5EFE3;
}

.reservation-summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #FFF7E6;
}

.reservation-summary-title,
.reservation-summary-hint,
.reservation-summary-action {
  display: block;
}

.reservation-summary-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2E261F;
}

.reservation-summary-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8B8175;
}

.reservation-summary-action {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #F6BE3E;
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.reservation-slot {
  padding: 18rpx 0;
  border-radius: 20rpx;
  background: #F5EFE3;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  color: #6F6457;
}

.reservation-slot.active,
.pet-choice.active {
  background: #F6BE3E;
  color: #FFFFFF;
}

.pet-choice {
  border: 2rpx solid transparent;
  box-shadow: 0 8rpx 20rpx rgba(103, 76, 44, 0.06);
}

.pet-choice.active {
  border-color: #E5A900;
  box-shadow: 0 12rpx 26rpx rgba(246, 190, 62, 0.28);
}

.pet-choice.active .pet-choice-name,
.pet-choice.active .pet-choice-meta {
  color: #FFFFFF;
}

.remark-summary-card,
.notice-card {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 24rpx;
}

.fee-row,
.fee-value-with-arrow,
.payment-method-row {
  display: flex;
}

.fee-row {
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
}

.fee-row:first-of-type {
  margin-top: 22rpx;
}

.fee-label {
  font-size: 24rpx;
  color: #6F6457;
}

.fee-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #2E261F;
}

.delivery-fee-row {
  min-height: 56rpx;
}

.fee-value-with-arrow {
  align-items: center;
  gap: 8rpx;
}

.fee-arrow {
  font-size: 34rpx;
  line-height: 1;
  color: #9A6A3A;
}

.payment-method-row {
  gap: 14rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.payment-method-pill {
  flex: 1;
  min-width: 220rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: #F5EFE3;
}

.payment-method-pill.active {
  background: #F6BE3E;
}

.payment-method-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #2E261F;
}

.payment-method-pill.active .payment-method-label,
.payment-method-pill.active .payment-method-hint {
  color: #FFFFFF;
}

.remark-summary-text,
.notice-copy {
  margin-top: 0;
}

.notice-check-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.notice-check {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 2rpx solid #D4B37C;
  background: #FFFFFF;
  box-sizing: border-box;
}

.notice-check.active {
  background: #F6BE3E;
  border-color: #F6BE3E;
}

.notice-check-mark {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  color: #FFFFFF;
}

.checkout-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-top: 22rpx;
}

.checkout-item-image {
  width: 116rpx;
  height: 116rpx;
  border-radius: 18rpx;
  background: #F3F3F3;
}

.checkout-item-main {
  flex: 1;
  min-width: 0;
}

.checkout-item-name,
.checkout-item-spec,
.checkout-item-price {
  display: block;
}

.checkout-item-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #333333;
}

.checkout-item-spec {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8B8175;
}

.checkout-item-price {
  font-size: 26rpx;
  font-weight: 700;
  color: #FF5D4A;
}

.checkout-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.98);
}

.checkout-total {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #171717;
}

.checkout-bottom-actions {
  gap: 14rpx;
}

.checkout-total-price {
  margin-left: 8rpx;
  color: #FF3A30;
}

.checkout-return,
.checkout-submit {
  min-width: 200rpx;
  border-radius: 999rpx;
}

.checkout-return {
  background: #F5EFE3;
  color: #6B5A47;
}

.checkout-submit {
  background: #F6BE3E;
  color: #FFFFFF;
}

.checkout-submit.disabled {
  background: #E3D7C3;
  color: #9D907C;
}

.checkout-return::after,
.checkout-submit::after {
  border: 0;
}

.reservation-mask {
  position: fixed;
  inset: 0;
  z-index: 45;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(0, 0, 0, 0.28);
}

.reservation-panel {
  width: 100%;
  max-height: 78vh;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #FFFFFF;
  box-shadow: 0 -18rpx 48rpx rgba(38, 28, 16, 0.18);
}

.reservation-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.reservation-panel-title,
.reservation-panel-subtitle,
.reservation-date-name,
.reservation-date-count {
  display: block;
}

.reservation-panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2E261F;
}

.reservation-panel-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8B8175;
}

.reservation-panel-close {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F5EFE3;
  font-size: 36rpx;
  line-height: 1;
  color: #6F6457;
}

.reservation-picker {
  display: flex;
  gap: 18rpx;
  height: 600rpx;
  margin-top: 24rpx;
}

.reservation-date-list {
  width: 188rpx;
  height: 100%;
  border-radius: 24rpx;
  background: #F8F2E8;
}

.reservation-date-tab {
  margin: 10rpx;
  padding: 18rpx 14rpx;
  border-radius: 20rpx;
  color: #6F6457;
}

.reservation-date-tab.active {
  background: #F6BE3E;
  color: #FFFFFF;
  box-shadow: 0 10rpx 22rpx rgba(246, 190, 62, 0.26);
}

.reservation-date-name {
  font-size: 23rpx;
  font-weight: 700;
}

.reservation-date-count {
  margin-top: 6rpx;
  font-size: 19rpx;
  opacity: 0.76;
}

.reservation-time-list {
  flex: 1;
  height: 100%;
}

.reservation-slot-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.reservation-confirm {
  margin-top: 24rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #F6BE3E;
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.reservation-confirm::after {
  border: 0;
}

.delivery-fee-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.28);
}

.delivery-fee-panel {
  width: 560rpx;
  max-width: 100%;
  padding: 28rpx 28rpx 30rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 20rpx 52rpx rgba(38, 28, 16, 0.16);
}

.delivery-fee-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.delivery-fee-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2E261F;
}

.delivery-fee-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #F5EFE3;
  font-size: 34rpx;
  line-height: 1;
  color: #6F6457;
}

.delivery-fee-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.delivery-fee-detail {
  display: block;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #FFF7E6;
  font-size: 24rpx;
  line-height: 1.45;
  color: #5F5144;
}
