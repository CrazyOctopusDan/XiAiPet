.profile-page {
  min-height: 100vh;
  padding: var(--profile-safe-top, 144rpx) 24rpx calc(242rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 18% 4%, rgba(246, 227, 150, 0.44) 0, transparent 30%),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 50%, #F6E396 100%);
  color: #40535C;
  box-sizing: border-box;
}

.balance-card-head,
.balance-line,
.balance-foot,
.recharge-card {
  display: flex;
}

.profile-title,
.member-chip,
.summary-avatar,
.profile-name,
.profile-phone,
.balance-label,
.balance-currency,
.balance-amount,
.balance-foot-text,
.balance-action,
.recharge-card-kicker,
.recharge-card-title,
.recharge-card-copy,
.recharge-card-action,
.quick-index,
.quick-title,
.quick-copy {
  display: block;
}

.profile-title {
  font-size: 54rpx;
  line-height: 1;
  font-weight: 900;
  letter-spacing: -2rpx;
  color: #40535C;
}

.member-chip {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 22rpx;
  font-weight: 800;
  color: #40535C;
}

.member-chip.in-card {
  position: absolute;
  right: 28rpx;
  top: 28rpx;
  z-index: 2;
  border: 1rpx solid var(--member-card-border);
  background: var(--member-card-pill-bg);
  color: var(--member-card-text);
}

.balance-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  border-radius: 38rpx;
  background: var(--member-card-bg);
  box-shadow: var(--member-card-shadow);
}

.balance-card::after {
  content: '';
  position: absolute;
  right: -72rpx;
  bottom: -86rpx;
  width: 250rpx;
  height: 250rpx;
  border-radius: 50%;
  background: var(--member-card-glow);
}

.balance-card-head {
  position: relative;
  z-index: 1;
  align-items: center;
  gap: 20rpx;
}

.summary-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 104rpx;
  height: 104rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, #D5F1FF 0%, #D5F1FF 100%);
  box-shadow: inset 0 -8rpx 0 rgba(64, 83, 92, 0.12);
  font-size: 46rpx;
  font-weight: 900;
  color: var(--member-card-text);
}

.summary-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--member-card-text);
}

.profile-phone {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: var(--member-card-muted);
}

.balance-label {
  position: relative;
  z-index: 1;
  margin-top: 34rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: var(--member-card-muted);
}

.balance-line {
  position: relative;
  z-index: 1;
  align-items: flex-end;
  margin-top: 2rpx;
}

.balance-currency {
  padding-bottom: 12rpx;
  font-size: 38rpx;
  font-weight: 900;
  color: var(--member-card-text);
}

.balance-amount {
  font-size: 76rpx;
  line-height: 1;
  font-weight: 900;
  letter-spacing: -3rpx;
  color: var(--member-card-text);
}

.balance-foot {
  position: relative;
  z-index: 1;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
}

.balance-foot-text {
  font-size: 22rpx;
  color: var(--member-card-muted);
}

.balance-action {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.46);
  font-size: 22rpx;
  font-weight: 800;
  color: var(--member-card-text);
}

.recharge-card {
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 26rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #40535C 0%, #60777C 100%);
  box-shadow: 0 18rpx 36rpx rgba(64, 83, 92, 0.16);
  box-sizing: border-box;
}

.recharge-card-main {
  flex: 1;
  min-width: 0;
}

.recharge-card-kicker {
  font-size: 20rpx;
  font-weight: 800;
  color: rgba(255, 253, 245, 0.72);
}

.recharge-card-title {
  margin-top: 8rpx;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #FFFDF5;
}

.recharge-card-copy {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: rgba(255, 253, 245, 0.78);
}

.recharge-card-action {
  flex-shrink: 0;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 23rpx;
  font-weight: 900;
  color: #40535C;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.quick-card {
  min-height: 184rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
  box-sizing: border-box;
}

.quick-card.primary {
  background: #F6E396;
}

.quick-card.balance-entry {
  background: linear-gradient(135deg, #FFF8E8 0%, #FFE0A1 100%);
}

.quick-card.gifts-entry {
  background: linear-gradient(135deg, #F9FEFF 0%, #D5F1FF 100%);
}

.quick-index {
  font-size: 30rpx;
  line-height: 1;
  font-weight: 900;
  color: rgba(213, 241, 255, 0.28);
}

.quick-title {
  margin-top: 26rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #40535C;
}

.quick-copy {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #7B8B92;
}
