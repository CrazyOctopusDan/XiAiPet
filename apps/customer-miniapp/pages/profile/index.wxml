<view class="profile-page" style="--profile-safe-top: {{profileSafeTop}}rpx;">
  <view class="balance-card" style="{{membershipCardStyle}}" bindtap="handleBalanceTap">
    <text class="member-chip in-card">{{membershipCardName || summary.memberLevel}}</text>
    <view class="balance-card-head">
      <view class="summary-avatar">{{summary.avatarText}}</view>
      <view class="summary-main">
        <text class="profile-name">{{summary.nickname}}</text>
        <text class="profile-phone">{{summary.contactPhoneLabel}}</text>
      </view>
    </view>
    <text class="balance-label">账户余额</text>
    <view class="balance-line">
      <text class="balance-currency">￥</text>
      <text class="balance-amount">{{summary.balance}}</text>
    </view>
    <view class="balance-foot">
      <text class="balance-foot-text">累计充值 ￥{{summary.totalRecharge}}</text>
      <text class="balance-action">查看流水</text>
    </view>
  </view>
  <view class="profile-facts">
    <view class="fact-pill {{summary.birthdayLabel === '未设置生日' ? 'editable' : ''}}" data-target="birthday" bindtap="handleProfileFactTap">
      <text class="fact-label">生日</text>
      <text class="fact-value">{{summary.birthdayLabel}}</text>
    </view>
    <view class="fact-pill {{summary.contactPhoneLabel === '未绑定手机号' ? 'editable' : ''}}" data-target="contact" bindtap="handleProfileFactTap">
      <text class="fact-label">联系方式</text>
      <text class="fact-value">{{summary.contactPhoneLabel}}</text>
    </view>
  </view>
  <view class="quick-grid">
    <view class="quick-card primary" bindtap="handleProfileDetailTap">
      <text class="quick-index">01</text>
      <text class="quick-title">个人信息</text>
      <text class="quick-copy">昵称、性别、生日</text>
    </view>
    <view class="quick-card" bindtap="handleAddressTap">
      <text class="quick-index">02</text>
      <text class="quick-title">我的地址</text>
      <text class="quick-copy">配送 / 快递地址</text>
    </view>
    <view class="quick-card" bindtap="handlePetsTap">
      <text class="quick-index">03</text>
      <text class="quick-title">宠物档案</text>
      <text class="quick-copy">下单宠物资料</text>
    </view>
    <view class="quick-card balance-entry" bindtap="handleBalanceTap">
      <text class="quick-index">04</text>
      <text class="quick-title">余额流水</text>
      <text class="quick-copy">收入、支出、余额</text>
    </view>
  </view>
</view>
