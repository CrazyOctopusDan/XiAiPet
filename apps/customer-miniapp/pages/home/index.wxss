.home-page {
  min-height: 100vh;
  /* padding-bottom: calc(242rpx + env(safe-area-inset-bottom)); */
  background: #FFFFFF;
  color: #40535C;
}

.hero-poster {
  width: 100%;
  display: block;
}

.home-content {
  padding: 0 24rpx 0;
}

.secondary-module-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.secondary-module-card,
.primary-module-card {
  box-sizing: border-box;
  border: 4rpx solid #1D1A17;
  background: #FFF8E9;
  overflow: hidden;
}

.secondary-module-card {
  min-width: 0;
  min-height: 230rpx;
  padding: 14rpx 10rpx 18rpx;
  border-radius: 32rpx;
  text-align: center;
  border-color: #ead098;
  box-shadow: 0 8rpx 0 #ead098;
}

.secondary-module-art {
  width: 100%;
  height: 142rpx;
  display: block;
  transform: scale(3) translateY(16rpx);
  z-index: -999;
}

.secondary-module-title {
  display: block;
  margin-top: 10rpx;
  overflow: hidden;
  color: #151515;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.15;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.primary-module-card {
  min-height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 36rpx;
  padding: 26rpx 26rpx 26rpx 34rpx;
  border-radius: 38rpx;
  background: #4F8BC3;
}

.primary-module-copy {
  min-width: 0;
  flex: 1;
}

.primary-module-title,
.primary-module-subtitle {
  display: block;
  color: #FFFFFF;
}

.primary-module-title {
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.15;
  text-shadow: 0 3rpx 0 rgba(0, 0, 0, 0.18);
}

.primary-module-subtitle {
  margin-top: 16rpx;
  font-size: 25rpx;
  font-weight: 700;
  opacity: 0.9;
}

.primary-module-art {
  flex: 0 0 330rpx;
  width: 330rpx;
  height: 230rpx;
  display: block;
  transform: scale(2.5) translate(0,20rpx) translateZ(10rpx);
}

.home-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: calc(42rpx + env(safe-area-inset-top)) 32rpx calc(42rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(64, 83, 92, 0.32);
}

.home-modal {
  width: 100%;
  max-width: 650rpx;
  max-height: calc(100vh - 84rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  overflow-y: auto;
  padding: 30rpx;
  border: 3rpx solid rgba(151, 105, 48, 0.22);
  border-radius: 30rpx;
  box-sizing: border-box;
  background: #FFFDF7;
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.86),
    0 22rpx 54rpx rgba(74, 42, 19, 0.18);
}

.home-modal-head,
.contact-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-modal-title,
.home-modal-subtitle,
.home-modal-close,
.contact-label,
.contact-value,
.notice-modal-copy {
  display: block;
}

.home-modal-title {
  color: #4B2709;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
}

.home-modal-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #FBF1D2;
  color: #7A4A17;
  font-size: 38rpx;
  line-height: 1;
  text-align: center;
}

.home-modal-subtitle {
  margin-top: 12rpx;
  color: #6A5C4B;
  font-size: 25rpx;
  line-height: 1.45;
}

.contact-list {
  margin-top: 22rpx;
}

.contact-row {
  min-height: 108rpx;
  margin-top: 14rpx;
  padding: 18rpx 18rpx 18rpx 22rpx;
  border: 2rpx solid #F0E2C7;
  border-radius: 22rpx;
  box-sizing: border-box;
  background: #FFF9E8;
}

.contact-row:first-child {
  margin-top: 0;
}

.contact-copy {
  min-width: 0;
  flex: 1;
}

.contact-label {
  color: #8A7359;
  font-size: 22rpx;
  line-height: 1.2;
}

.contact-value {
  margin-top: 8rpx;
  color: #40535C;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  word-break: break-all;
}

.notice-modal-button {
  border: none;
  border-radius: 999rpx;
  box-sizing: border-box;
  padding: 0;
  font-size: 26rpx;
  font-weight: 800;
}

.notice-modal-copy {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #FFF9E8;
  color: #40535C;
  font-size: 28rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

.notice-modal-button {
  width: 100%;
  height: 72rpx;
  margin-top: 22rpx;
  background: #40535C;
  color: #FFFFFF;
  line-height: 72rpx;
}
