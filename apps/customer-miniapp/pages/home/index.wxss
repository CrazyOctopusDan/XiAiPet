.home-page {
  min-height: 100vh;
  padding-bottom: calc(242rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 82% 12%, rgba(246, 227, 150, 0.22) 0, transparent 28%),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 48%, #FFF2C8 100%);
  color: #40535C;
}

.hero-poster {
  width: 100%;
  display: block;
  filter: drop-shadow(0 12rpx 20rpx rgba(134, 98, 42, 0.08));
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin: -10rpx 20rpx 0;
}

.module-card {
  width: 100%;
  height: 506rpx;
  position: relative;
  box-sizing: border-box;
  padding: 3rpx;
  background: linear-gradient(145deg, rgba(246, 227, 150, 0.95) 0%, rgba(242, 196, 111, 0.88) 72%, rgba(224, 178, 94, 0.82) 100%);
  border-radius: 28rpx;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 12rpx 28rpx rgba(134, 98, 42, 0.08);
}

.module-card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 92% 8%, rgba(246, 227, 150, 0.16) 0, transparent 26%),
    linear-gradient(180deg, rgba(255, 254, 247, 0.98) 0%, rgba(255, 248, 229, 0.96) 100%);
  border-radius: 25rpx;
}

.module-card-title {
  position: absolute;
  top: 40rpx;
  left: 14rpx;
  right: 14rpx;
  z-index: 2;
  color: #4B2709;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
  letter-spacing: 4rpx;
  text-align: center;
  text-shadow:
    0 2rpx 0 #7A4A17,
    0 4rpx 10rpx rgba(72, 40, 10, 0.16);
}

.module-card--preorder .module-card-title,
.module-card--notice .module-card-title,
.module-card--vip .module-card-title {
  transform: scaleX(1.01);
}

.module-card-art {
  width: calc(100% - 18rpx);
  height: calc(100% - 26rpx);
  position: absolute;
  left: 9rpx;
  top: 12rpx;
  display: block;
  z-index: 1;
}

.module-card-action {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 26rpx;
  z-index: 3;
  height: 58rpx;
  border-radius: 34rpx;
  border: 3rpx solid rgba(74, 42, 19, 0.76);
  box-sizing: border-box;
  background: linear-gradient(180deg, #F7E38F 0%, #E9C765 100%);
  box-shadow:
    inset 0 3rpx 0 rgba(255, 255, 255, 0.48),
    0 5rpx 0 rgba(120, 78, 35, 0.32),
    0 10rpx 18rpx rgba(80, 104, 105, 0.08);
  color: #40535C;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.42);
}

.module-card-action-blue {
  background: linear-gradient(180deg, #D8EEF2 0%, #B7DDE6 100%);
}

.module-card-action-pink {
  background: linear-gradient(180deg, #F7E38F 0%, #E9C765 100%);
}

.home-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx 24rpx calc(42rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(64, 83, 92, 0.32);
}

.home-modal {
  width: 100%;
  padding: 30rpx;
  border: 3rpx solid rgba(151, 105, 48, 0.22);
  border-radius: 30rpx;
  box-sizing: border-box;
  background: #FFFDF7;
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.86),
    0 22rpx 54rpx rgba(74, 42, 19, 0.18);
}

.home-modal-head,
.contact-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-modal-title,
.home-modal-subtitle,
.home-modal-close,
.contact-label,
.contact-value,
.notice-modal-copy {
  display: block;
}

.home-modal-title {
  color: #4B2709;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
}

.home-modal-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #FBF1D2;
  color: #7A4A17;
  font-size: 38rpx;
  line-height: 52rpx;
  text-align: center;
}

.home-modal-subtitle {
  margin-top: 12rpx;
  color: #6A5C4B;
  font-size: 25rpx;
  line-height: 1.45;
}

.contact-list {
  margin-top: 22rpx;
}

.contact-row {
  min-height: 108rpx;
  margin-top: 14rpx;
  padding: 18rpx 18rpx 18rpx 22rpx;
  border: 2rpx solid #F0E2C7;
  border-radius: 22rpx;
  box-sizing: border-box;
  background: #FFF9E8;
}

.contact-row:first-child {
  margin-top: 0;
}

.contact-copy {
  min-width: 0;
  flex: 1;
}

.contact-label {
  color: #8A7359;
  font-size: 22rpx;
  line-height: 1.2;
}

.contact-value {
  margin-top: 8rpx;
  color: #40535C;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  word-break: break-all;
}

.copy-button,
.notice-modal-button {
  border: none;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  font-weight: 800;
}

.copy-button {
  flex: 0 0 auto;
  width: 112rpx;
  height: 58rpx;
  margin-left: 18rpx;
  background: #D8EEF2;
  color: #40535C;
  line-height: 58rpx;
}

.notice-modal-copy {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #FFF9E8;
  color: #40535C;
  font-size: 28rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

.notice-modal-button {
  width: 100%;
  height: 72rpx;
  margin-top: 22rpx;
  background: #40535C;
  color: #FFFFFF;
  line-height: 72rpx;
}
