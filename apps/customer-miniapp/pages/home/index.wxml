<view class="home-page">
  <image class="hero-poster" mode="widthFix" src="{{heroBannerSrc}}" />

  <view class="module-grid">
    <image
      class="module-card"
      wx:for="{{modules}}"
      wx:key="id"
      mode="widthFix"
      src="{{item.imageSrc}}"
      data-module-id="{{item.id}}"
      bindtap="handleModuleTap"
    />
  </view>
</view>
