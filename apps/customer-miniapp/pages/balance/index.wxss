.balance-page {
  min-height: 100vh;
  padding-bottom: calc(104rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 18% 0%, rgba(246, 227, 150, 0.38) 0, transparent 28%),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 52%, #F6E396 100%);
  color: #40535C;
  box-sizing: border-box;
}

.month-card-head,
.overview-head,
.overview-balance-line,
.overview-metrics {
  display: flex;
  align-items: center;
}

.balance-shell {
  padding: 18rpx 24rpx 0;
}

.overview-label,
.overview-head-action,
.overview-status,
.overview-currency,
.overview-value,
.overview-pill-label,
.overview-pill-value,
.month-title,
.month-summary,
.ledger-title,
.ledger-note,
.ledger-date,
.ledger-amount {
  display: block;
}

.balance-overview-card {
  position: relative;
  overflow: hidden;
  margin-top: 10rpx;
  padding: 32rpx 30rpx 30rpx;
  border-radius: 38rpx;
  background:
    radial-gradient(circle at 86% 8%, rgba(255, 230, 163, 0.34) 0, transparent 30%),
    linear-gradient(145deg, #FFF8D8 0%, #F6E396 62%, #F2C46F 100%);
  box-shadow: 0 26rpx 58rpx rgba(82, 116, 126, 0.22);
  box-sizing: border-box;
}

.balance-overview-card::after {
  content: '';
  position: absolute;
  right: -82rpx;
  bottom: -92rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.overview-head,
.overview-balance-line,
.overview-metrics {
  position: relative;
  z-index: 1;
}

.overview-head {
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.overview-label {
  padding-top: 12rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #7B8B92;
}

.overview-head-action {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  gap: 12rpx;
}

.overview-status {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
  font-size: 20rpx;
  font-weight: 800;
  color: #40535C;
}

.overview-balance-line {
  align-items: flex-end;
  margin-top: 10rpx;
}

.overview-currency {
  padding-bottom: 12rpx;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 900;
  color: #40535C;
}

.overview-value {
  font-size: 82rpx;
  line-height: 1;
  font-weight: 900;
  color: #40535C;
}

.recharge-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 150rpx;
  height: 58rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #40535C;
  color: #FFFDF5;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 58rpx;
  box-shadow: 0 12rpx 24rpx rgba(64, 83, 92, 0.22);
}

.recharge-entry::after {
  border: 0;
}

.overview-metrics {
  gap: 18rpx;
  margin-top: 34rpx;
}

.overview-pill {
  flex: 1;
  min-width: 0;
  padding: 20rpx 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.14);
  box-sizing: border-box;
}

.overview-pill-label {
  font-size: 20rpx;
  font-weight: 800;
  color: #7B8B92;
}

.overview-pill-value {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #40535C;
}

.month-card {
  margin-top: 20rpx;
  padding: 28rpx 26rpx 10rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
  box-sizing: border-box;
}

.month-card-head {
  justify-content: space-between;
}

.month-title {
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.month-summary {
  margin-top: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #7B8B92;
}

.ledger-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 26rpx 0;
}

.ledger-row + .ledger-row {
  border-top: 2rpx solid rgba(64, 83, 92, 0.08);
}

.ledger-main {
  flex: 1;
  min-width: 0;
}

.ledger-title {
  font-size: 30rpx;
  line-height: 1.28;
  font-weight: 900;
  color: #40535C;
}

.ledger-note {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.35;
  color: #7B8B92;
}

.ledger-date {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #7B8B92;
}

.ledger-amount-wrap {
  flex-shrink: 0;
  min-width: 150rpx;
  padding: 8rpx 0;
  text-align: right;
}

.ledger-amount {
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 900;
}

.ledger-amount-wrap.income .ledger-amount {
  color: #2E8B57;
}

.ledger-amount-wrap.expense .ledger-amount {
  color: #D05C45;
}

.balance-load-more {
  padding: 28rpx 0 6rpx;
  color: #7B8B92;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}
