<view class="balance-page">
  <page-nav />

  <view class="balance-shell">
    <view class="balance-overview-card">
      <view class="overview-head">
        <text class="overview-label">当前余额</text>
        <text class="overview-status">可用于订单抵扣</text>
      </view>
      <view class="overview-balance-line">
        <text class="overview-currency">￥</text>
        <text class="overview-value">{{overview.currentBalance}}</text>
      </view>
      <view class="overview-metrics">
        <view class="overview-pill">
          <text class="overview-pill-label">累计收入</text>
          <text class="overview-pill-value">￥{{overview.totalIncome}}</text>
        </view>
        <view class="overview-pill">
          <text class="overview-pill-label">累计支出</text>
          <text class="overview-pill-value">￥{{overview.totalExpense}}</text>
        </view>
      </view>
    </view>

    <view class="month-card" wx:for="{{groups}}" wx:key="month">
      <view class="month-card-head">
        <view>
          <text class="month-title">{{item.monthLabel}}</text>
          <text class="month-summary">收入 ￥{{item.totalIncome}} · 支出 ￥{{item.totalExpense}}</text>
        </view>
      </view>

      <view class="ledger-row" wx:for="{{item.items}}" wx:key="id">
        <view class="ledger-main">
          <text class="ledger-title">{{item.title}}</text>
          <text class="ledger-note" wx:if="{{item.note}}">{{item.note}}</text>
          <text class="ledger-date">{{item.date}}</text>
        </view>
        <view class="ledger-amount-wrap {{item.type === 'income' ? 'income' : 'expense'}}">
          <text class="ledger-amount">{{item.type === 'income' ? '+' : '-'}}￥{{item.amount}}</text>
        </view>
      </view>
    </view>

    <view class="balance-load-more" wx:if="{{groups.length}}">
      <text wx:if="{{loadingMore}}">正在加载更多流水</text>
      <text wx:elif="{{!hasMore}}">已显示全部流水</text>
      <text wx:else>继续下滑加载更多</text>
    </view>
  </view>
</view>
