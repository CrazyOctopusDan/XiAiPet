.orders-page {
  min-height: 100vh;
  padding: var(--orders-header-top, 96rpx) 24rpx calc(242rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 14% 0%, rgba(246, 227, 150, 0.22) 0, transparent 30%),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 54%, #F6E396 100%);
  color: #40535C;
  box-sizing: border-box;
}

.orders-hero {
  padding: 0 8rpx 26rpx;
}

.orders-heading-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: var(--orders-header-height, 64rpx);
  padding-right: var(--orders-header-right, 212rpx);
  box-sizing: border-box;
}

.orders-title {
  display: block;
  font-size: 44rpx;
  line-height: 1.12;
  font-weight: 900;
  color: #40535C;
}

.orders-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #7B8B92;
}

.orders-badge {
  display: block;
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.orders-tabs {
  width: 100%;
  margin: -6rpx 0 22rpx;
  white-space: nowrap;
}

.orders-tab-row {
  display: flex;
  gap: 12rpx;
  padding: 4rpx 8rpx 8rpx;
  box-sizing: border-box;
}

.orders-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 128rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(64, 83, 92, 0.1);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: inset 0 -4rpx 0 rgba(64, 83, 92, 0.04);
  box-sizing: border-box;
}

.orders-tab.active {
  border-color: rgba(64, 83, 92, 0.18);
  background: #40535C;
  box-shadow: 0 14rpx 28rpx rgba(64, 83, 92, 0.18);
}

.orders-tab-label {
  display: block;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #6B7C84;
}

.orders-tab.active .orders-tab-label {
  color: #FFFDF5;
}

.orders-card {
  padding: 34rpx 30rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
  box-sizing: border-box;
}

.orders-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.empty-mark {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
  width: 96rpx;
  height: 96rpx;
  padding: 0 24rpx;
  border-radius: 30rpx;
  background: #F6E396;
  box-sizing: border-box;
}

.empty-mark-line {
  height: 6rpx;
  border-radius: 999rpx;
  background: #F6E396;
  opacity: 0.88;
}

.empty-mark-line.short {
  width: 28rpx;
}

.card-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.card-body {
  display: block;
  font-size: 25rpx;
  line-height: 1.6;
  font-weight: 700;
  color: #7B8B92;
}

.catalog-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin: 10rpx 0 0;
  padding: 0;
  border: none;
  border-radius: 999rpx;
  background: #F6E396;
  color: #40535C;
  font-size: 28rpx;
  line-height: 88rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 38rpx rgba(82, 116, 126, 0.18);
}

.catalog-button::after {
  border: 0;
}

.order-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
  box-sizing: border-box;
}

.order-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 30rpx;
  bottom: 30rpx;
  width: 8rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: #F6E396;
}

.order-card.status-payment,
.order-card.status-pending {
  border-color: rgba(246, 212, 102, 0.56);
  background: rgba(255, 253, 245, 0.94);
}

.order-card.status-work {
  border-color: rgba(180, 128, 70, 0.28);
  background: #FFF9F1;
}

.order-card.status-ready {
  border-color: rgba(82, 116, 126, 0.28);
  background: #F7FBFC;
}

.order-card.status-delivery {
  border-color: rgba(73, 143, 145, 0.28);
  background: #F4FCFB;
}

.order-card.status-completed {
  border-color: rgba(117, 147, 125, 0.22);
  background: rgba(255, 255, 255, 0.78);
}

.order-card.status-cancelled {
  border-color: rgba(123, 139, 146, 0.16);
  background: rgba(255, 255, 255, 0.72);
}

.order-card.status-payment::before,
.order-card.status-pending::before {
  background: #F6D466;
}

.order-card.status-work::before {
  background: #D7A05E;
}

.order-card.status-ready::before {
  background: #52747E;
}

.order-card.status-delivery::before {
  background: #498F91;
}

.order-card.status-completed::before {
  background: #75937D;
}

.order-card.status-cancelled::before {
  background: #A8B2B7;
}

.order-card.highlighted {
  border-color: rgba(255, 230, 163, 0.66);
  box-shadow: 0 0 0 4rpx rgba(255, 230, 163, 0.52), 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
}

.order-card-head,
.order-card-foot,
.order-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-card-head {
  gap: 20rpx;
}

.order-id,
.order-created,
.order-summary,
.order-meta-label,
.order-meta-value,
.order-total,
.order-link,
.order-status {
  display: block;
}

.order-id {
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.order-created {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #7B8B92;
}

.order-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #F6E396;
  color: #6B7C84;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
}

.order-status.status-payment,
.order-status.status-pending {
  background: #F6E396;
  color: #40535C;
}

.order-status.status-work {
  background: #F4D1A8;
  color: #754B22;
}

.order-status.status-ready {
  background: #DDEDF2;
  color: #315A67;
}

.order-status.status-delivery {
  background: #D8F0EE;
  color: #2C696B;
}

.order-status.status-completed {
  background: #E3EDDF;
  color: #526B58;
}

.order-status.status-cancelled {
  background: #EEF1F2;
  color: #7B8B92;
}

.order-summary {
  margin-top: 20rpx;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 900;
  color: #40535C;
}

.order-meta-panel {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #FFFDF5;
  box-sizing: border-box;
}

.order-meta-row {
  gap: 16rpx;
}

.order-meta-row + .order-meta-row {
  margin-top: 14rpx;
}

.order-meta-label {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #7B8B92;
}

.order-meta-value {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #7B8B92;
}

.order-card-foot {
  margin-top: 24rpx;
}

.order-total {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.order-link {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.order-card.status-ready .order-link {
  background: #DDEDF2;
  color: #315A67;
}

.order-card.status-delivery .order-link {
  background: #D8F0EE;
  color: #2C696B;
}

.order-card.status-completed .order-link,
.order-card.status-cancelled .order-link {
  background: #EEF1F2;
  color: #6B7C84;
}

.orders-loading,
.orders-end {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
}

.orders-loading-text,
.orders-end-text {
  display: block;
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #8B9AA0;
}
