.orders-page {
  min-height: 100vh;
  padding: var(--orders-header-top, 96rpx) 24rpx calc(242rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 14% 0%, rgba(246, 227, 150, 0.22) 0, transparent 30%),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 54%, #F6E396 100%);
  color: #40535C;
  box-sizing: border-box;
}

.orders-hero {
  padding: 0 8rpx 26rpx;
}

.orders-heading-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: var(--orders-header-height, 64rpx);
  padding-right: var(--orders-header-right, 212rpx);
  box-sizing: border-box;
}

.orders-title {
  display: block;
  font-size: 44rpx;
  line-height: 1.12;
  font-weight: 900;
  color: #40535C;
}

.orders-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #7B8B92;
}

.orders-badge {
  display: block;
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.orders-card {
  padding: 34rpx 30rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
  box-sizing: border-box;
}

.orders-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.empty-mark {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
  width: 96rpx;
  height: 96rpx;
  padding: 0 24rpx;
  border-radius: 30rpx;
  background: #F6E396;
  box-sizing: border-box;
}

.empty-mark-line {
  height: 6rpx;
  border-radius: 999rpx;
  background: #F6E396;
  opacity: 0.88;
}

.empty-mark-line.short {
  width: 28rpx;
}

.card-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.card-body {
  display: block;
  font-size: 25rpx;
  line-height: 1.6;
  font-weight: 700;
  color: #7B8B92;
}

.catalog-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin: 10rpx 0 0;
  padding: 0;
  border: none;
  border-radius: 999rpx;
  background: #F6E396;
  color: #40535C;
  font-size: 28rpx;
  line-height: 88rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 38rpx rgba(82, 116, 126, 0.18);
}

.catalog-button::after {
  border: 0;
}

.order-card {
  padding: 30rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
  box-sizing: border-box;
}

.order-card.highlighted {
  border-color: rgba(255, 230, 163, 0.66);
  box-shadow: 0 0 0 4rpx rgba(255, 230, 163, 0.52), 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
}

.order-card-head,
.order-card-foot,
.order-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-card-head {
  gap: 20rpx;
}

.order-id,
.order-created,
.order-summary,
.order-meta-label,
.order-meta-value,
.order-total,
.order-link,
.order-status {
  display: block;
}

.order-id {
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.order-created {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #7B8B92;
}

.order-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #F6E396;
  color: #6B7C84;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
}

.order-summary {
  margin-top: 20rpx;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 900;
  color: #40535C;
}

.order-meta-panel {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #FFFDF5;
  box-sizing: border-box;
}

.order-meta-row {
  gap: 16rpx;
}

.order-meta-row + .order-meta-row {
  margin-top: 14rpx;
}

.order-meta-label {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #7B8B92;
}

.order-meta-value {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #7B8B92;
}

.order-card-foot {
  margin-top: 24rpx;
}

.order-total {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.order-link {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}
