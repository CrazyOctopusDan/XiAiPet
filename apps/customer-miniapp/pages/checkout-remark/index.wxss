.remark-page {
  min-height: 100vh;
  padding-bottom: calc(190rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 90% 8%, rgba(213, 241, 255, 0.32) 0, rgba(213, 241, 255, 0) 240rpx),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 74%, #F9EAA6 100%);
}

.remark-shell {
  padding: 18rpx 20rpx 0;
}

.remark-hero,
.remark-card {
  border-radius: 28rpx;
  border: 2rpx solid rgba(226, 194, 134, 0.46);
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 42rpx rgba(112, 82, 42, 0.08);
  box-sizing: border-box;
}

.remark-hero {
  padding: 30rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 253, 245, 0.95), rgba(255, 247, 210, 0.9));
}

.remark-title,
.remark-subtitle,
.remark-history-title,
.remark-history-copy,
.remark-history-delete {
  display: block;
}

.remark-title,
.remark-history-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #40535C;
}

.remark-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7B8B92;
}

.remark-card {
  margin-top: 18rpx;
  padding: 24rpx;
}

.remark-input {
  width: 100%;
  min-height: 240rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #FFFDF5;
  font-size: 28rpx;
  line-height: 1.8;
  color: #40535C;
  box-sizing: border-box;
}

.remark-history-list {
  margin-top: 20rpx;
}

.remark-history-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-top: 2rpx solid rgba(46, 38, 31, 0.06);
}

.remark-history-item:first-child {
  border-top: 0;
  padding-top: 0;
}

.remark-history-copy {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7B8B92;
}

.remark-history-delete {
  font-size: 22rpx;
  font-weight: 700;
  color: #B78336;
}

.remark-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 22rpx 20rpx calc(30rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid rgba(226, 194, 134, 0.36);
  background: rgba(255, 253, 245, 0.96);
  box-shadow: 0 -18rpx 44rpx rgba(112, 82, 42, 0.1);
  box-sizing: border-box;
}

.remark-confirm {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  color: #40535C;
  box-shadow: 0 12rpx 26rpx rgba(190, 143, 54, 0.18);
}

.remark-confirm::after {
  border: 0;
}
