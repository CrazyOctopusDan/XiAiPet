<view class="remark-page">
  <page-nav />

  <view class="remark-shell">
    <view class="remark-hero">
      <text class="remark-title">订单备注</text>
      <text class="remark-subtitle">输入这次下单想提醒店主的信息，常用备注会自动保留在这里。</text>
    </view>

    <view class="remark-card">
      <textarea class="remark-input" value="{{remarkValue}}" placeholder="例如：少糖、送达前电话联系、定制细节已沟通" bindinput="handleInput" maxlength="120" />
    </view>

    <view class="remark-card" wx:if="{{history.length}}">
      <view class="remark-history-head">
        <text class="remark-history-title">历史备注</text>
      </view>
      <view class="remark-history-list">
        <view class="remark-history-item" wx:for="{{history}}" wx:key="*this">
          <text class="remark-history-copy" data-value="{{item}}" bindtap="handleUseHistory">{{item}}</text>
          <text class="remark-history-delete" data-value="{{item}}" bindtap="handleDeleteHistory">删除</text>
        </view>
      </view>
    </view>
  </view>

  <view class="remark-bottom-bar">
    <button class="remark-confirm" bindtap="handleConfirm">确认备注</button>
  </view>
</view>
