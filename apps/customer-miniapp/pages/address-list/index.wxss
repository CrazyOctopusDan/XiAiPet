.address-page {
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #FBF6DB 0%, #FFFDF4 100%);
  color: #4F341E;
}
.address-card-head,
.address-actions {
  display: flex;
  align-items: center;
}

.address-shell {
  padding: 18rpx 24rpx 0;
}

.address-title,
.address-subtitle,
.type-pill-label,
.type-pill-hint,
.address-name,
.address-phone,
.address-detail,
.empty-title,
.empty-copy {
  display: block;
}

.address-hero {
  padding: 18rpx 8rpx 12rpx;
}

.address-title {
  font-size: 50rpx;
  font-weight: 700;
}

.address-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7D6C59;
}

.type-switch-card {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.type-pill {
  flex: 1;
  padding: 24rpx 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 238, 0.95);
  box-shadow: 0 16rpx 34rpx rgba(142, 105, 55, 0.07);
}

.type-pill.active {
  background: linear-gradient(180deg, #F6BE3E 0%, #D99A39 100%);
}

.type-pill-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #4F341E;
}

.type-pill.active .type-pill-label,
.type-pill.active .type-pill-hint {
  color: #FFFFFF;
}

.type-pill-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8E7A64;
}

.address-list {
  margin-top: 18rpx;
}

.address-card {
  margin-top: 16rpx;
  padding: 30rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 251, 234, 0.96);
  box-shadow: 0 18rpx 40rpx rgba(142, 105, 55, 0.08);
}

.address-card-head {
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.address-phone {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8A7865;
}

.address-card-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.address-tag,
.address-current {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.address-tag {
  background: #FFF1C7;
  color: #8D662D;
}

.address-current {
  background: #EDE7D6;
  color: #766754;
}

.address-detail {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6F6254;
}

.address-actions {
  gap: 16rpx;
  margin-top: 24rpx;
}

.address-action {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  height: 72rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.address-action.ghost {
  border: 2rpx solid #E6D9BE;
  color: #876948;
}

.address-action.primary {
  background: #F6BE3E;
  color: #FFFFFF;
}

.empty-state {
  margin-top: 18rpx;
  padding: 80rpx 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 251, 234, 0.82);
  text-align: center;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-copy {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8A7865;
}

.address-add-button {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #4F341E;
  color: #FFFFFF;
}

.address-add-button::after {
  border: 0;
}
