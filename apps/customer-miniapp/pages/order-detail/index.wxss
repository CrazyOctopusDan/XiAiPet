.order-detail-page {
  min-height: 100vh;
  padding: calc(32rpx + env(safe-area-inset-top)) 24rpx 64rpx;
  background: linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 58%, #F6E396 100%);
  color: #40535C;
}

.detail-topbar {
  display: flex;
  align-items: center;
  min-height: 72rpx;
}

.detail-back-button {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 64rpx;
  padding: 0 20rpx 0 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 10rpx 24rpx rgba(112, 82, 42, 0.08);
}

.detail-back-icon,
.detail-back-text {
  display: block;
  color: #40535C;
}

.detail-back-icon {
  font-size: 46rpx;
  line-height: 1;
  font-weight: 700;
}

.detail-back-text {
  font-size: 24rpx;
  font-weight: 700;
}

.detail-hero {
  padding: 20rpx 12rpx 32rpx;
}

.detail-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
}

.detail-subtitle {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #7B8B92;
}

.detail-card {
  margin-top: 24rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: rgba(255, 251, 234, 0.96);
  box-shadow: 0 18rpx 40rpx rgba(142, 105, 55, 0.08);
}

.empty-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.detail-head,
.detail-meta-row,
.detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-order-id,
.detail-order-time,
.detail-status,
.detail-section-title,
.detail-copy,
.detail-item-name,
.detail-item-spec,
.detail-item-total,
.detail-meta-label,
.detail-meta-value,
.detail-total {
  display: block;
}

.detail-order-id {
  font-size: 28rpx;
  font-weight: 700;
}

.detail-order-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7B8B92;
}

.detail-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(232, 210, 67, 0.2);
  color: #7A5C28;
  font-size: 22rpx;
  font-weight: 600;
}

.detail-section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.detail-copy {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7B8B92;
}

.detail-meta-row {
  margin-top: 18rpx;
}

.detail-meta-label {
  font-size: 24rpx;
  color: #7B8B92;
}

.detail-meta-value {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  color: #7B8B92;
}

.detail-item {
  margin-top: 20rpx;
}

.detail-item-name {
  font-size: 28rpx;
  font-weight: 600;
}

.detail-item-spec {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7B8B92;
}

.detail-item-total {
  font-size: 26rpx;
  font-weight: 600;
}

.total-row {
  margin-top: 24rpx;
}

.detail-total {
  font-size: 34rpx;
  font-weight: 700;
}

.detail-button {
  margin: 8rpx 0 0;
  border: none;
  border-radius: 999rpx;
  background: #F6E396;
  color: #40535C;
  font-size: 26rpx;
  font-weight: 600;
}
