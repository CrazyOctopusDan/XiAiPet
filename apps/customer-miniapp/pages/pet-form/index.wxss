.pet-form-page {
  min-height: 100vh;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 14% 0%, rgba(246, 227, 150, 0.2) 0, transparent 30%),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 54%, #F6E396 100%);
  color: #40535C;
  box-sizing: border-box;
}

.pet-form-shell {
  padding: 32rpx 24rpx 0;
}

.pet-form-context {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 88rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.pet-form-context-label,
.pet-form-context-badge,
.section-title,
.field-label {
  display: block;
}

.pet-form-context-label {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.pet-form-context-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.pet-form-card {
  margin-top: 16rpx;
  padding: 34rpx 28rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.field-block {
  margin-top: 30rpx;
}

.field-label {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #7B8B92;
}

.text-input,
.text-area,
.picker-shell {
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid rgba(80, 104, 105, 0.08);
  border-radius: 24rpx;
  background: #FFFDF5;
  color: #40535C;
}

.text-input,
.picker-shell {
  height: 92rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  line-height: 92rpx;
  font-weight: 700;
}

.gender-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.gender-pill {
  padding: 14rpx 26rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.08);
  border-radius: 999rpx;
  background: #FFFDF5;
  font-size: 24rpx;
  font-weight: 800;
  color: #7B8B92;
  box-sizing: border-box;
}

.gender-pill.active {
  border-color: #40535C;
  background: #F6E396;
  color: #40535C;
}

.text-area {
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  line-height: 1.6;
  font-weight: 700;
}

.pet-form-fixed-action {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 246, 0.94);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 -12rpx 32rpx rgba(82, 116, 126, 0.08);
  box-sizing: border-box;
}

.save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 30rpx;
  line-height: 96rpx;
  font-weight: 900;
  color: #40535C;
  box-shadow: 0 18rpx 38rpx rgba(82, 116, 126, 0.2);
}

.save-button::after {
  border: 0;
}
