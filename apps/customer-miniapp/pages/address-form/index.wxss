.address-form-page {
  min-height: 100vh;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 14% 0%, rgba(246, 190, 62, 0.2) 0, transparent 30%),
    linear-gradient(180deg, #FFF8EA 0%, #FFFDF6 54%, #F6E7C8 100%);
  color: #3A2A1E;
  box-sizing: border-box;
}

.address-form-shell {
  padding: 32rpx 24rpx 0;
}

.address-form-context {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 88rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.address-form-context-label,
.address-form-context-badge,
.section-title,
.field-label {
  display: block;
}

.address-form-context-label {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #3A2A1E;
}

.address-form-context-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #3A2A1E;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #FFE6A3;
}

.address-form-card {
  margin-top: 16rpx;
  padding: 34rpx 28rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(82, 49, 24, 0.06);
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 34rpx rgba(106, 72, 39, 0.08);
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #3A2A1E;
}

.field-block {
  margin-top: 30rpx;
}

.field-label {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #6D563F;
}

.text-input,
.text-area {
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid rgba(82, 49, 24, 0.08);
  border-radius: 24rpx;
  background: #FFF8EA;
  color: #3A2A1E;
}

.text-input {
  height: 92rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  line-height: 92rpx;
  font-weight: 700;
}

.text-area {
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  line-height: 1.6;
  font-weight: 700;
}

.address-form-fixed-action {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 246, 0.94);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 -12rpx 32rpx rgba(72, 41, 17, 0.08);
  box-sizing: border-box;
}

.save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #3A2A1E;
  font-size: 30rpx;
  line-height: 96rpx;
  font-weight: 900;
  color: #FFE6A3;
  box-shadow: 0 18rpx 38rpx rgba(72, 41, 17, 0.2);
}

.save-button::after {
  border: 0;
}
