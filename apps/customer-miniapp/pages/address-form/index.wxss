.address-form-page {
  min-height: 100vh;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 14% 0%, rgba(246, 227, 150, 0.2) 0, transparent 30%),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 54%, #F6E396 100%);
  color: #40535C;
  box-sizing: border-box;
}

.address-form-shell {
  padding: 32rpx 24rpx 0;
}

.address-form-context {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 88rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.address-form-context-label,
.address-form-context-badge,
.section-title,
.field-label {
  display: block;
}

.address-form-context-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
}

.address-form-context-label {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.address-form-context-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.recognition-button {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  min-width: 142rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #D8F0F4;
  color: #40535C;
  font-size: 23rpx;
  line-height: 56rpx;
  font-weight: 900;
}

.recognition-button::after {
  border: 0;
}

.address-form-card {
  margin-top: 16rpx;
  padding: 34rpx 28rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.field-block {
  margin-top: 30rpx;
}

.field-label {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #7B8B92;
}

.field-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 14rpx;
}

.field-label-row .field-label {
  margin-bottom: 0;
}

.location-button {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  margin-left: auto;
  min-width: 148rpx;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #D8F0F4;
  color: #40535C;
  font-size: 24rpx;
  line-height: 58rpx;
  font-weight: 900;
}

.location-button::after {
  border: 0;
}

.location-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 2rpx dashed rgba(80, 104, 105, 0.18);
  background: #FFFDF5;
  box-sizing: border-box;
}

.location-card.is-selected {
  border-style: solid;
  border-color: rgba(80, 104, 105, 0.2);
  background: #F8FCF4;
}

.location-title,
.location-desc,
.sync-express-title,
.sync-express-desc {
  display: block;
}

.location-title {
  font-size: 26rpx;
  line-height: 1.3;
  font-weight: 900;
  color: #40535C;
}

.location-desc {
  font-size: 23rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #7B8B92;
}

.location-privacy-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.12);
  background: #F8FCF4;
  box-sizing: border-box;
}

.location-privacy-copy {
  flex: 1 1 auto;
  min-width: 0;
}

.location-privacy-title,
.location-privacy-desc {
  display: block;
}

.location-privacy-title {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 900;
  color: #40535C;
}

.location-privacy-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #7B8B92;
}

.location-privacy-button {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  min-width: 150rpx;
  height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #F6E396;
  color: #40535C;
  font-size: 23rpx;
  line-height: 60rpx;
  font-weight: 900;
}

.location-privacy-button::after {
  border: 0;
}

.text-input,
.text-area {
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid rgba(80, 104, 105, 0.08);
  border-radius: 24rpx;
  background: #FFFDF5;
  color: #40535C;
}

.text-input {
  height: 92rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  line-height: 92rpx;
  font-weight: 700;
}

.text-area {
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  line-height: 1.6;
  font-weight: 700;
}

.sync-express-card {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.1);
  background: #FFFFFF;
  box-sizing: border-box;
}

.sync-express-card.is-checked {
  border-color: rgba(80, 104, 105, 0.22);
  background: #F8FCF4;
}

.sync-express-check {
  position: relative;
  flex: 0 0 auto;
  width: 34rpx;
  height: 34rpx;
  margin-top: 4rpx;
  border-radius: 10rpx;
  border: 4rpx solid #40535C;
  box-sizing: border-box;
}

.sync-express-card.is-checked .sync-express-check {
  background: #40535C;
}

.sync-express-card.is-checked .sync-express-check::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 2rpx;
  width: 10rpx;
  height: 18rpx;
  border: solid #FFFFFF;
  border-width: 0 4rpx 4rpx 0;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.sync-express-copy {
  flex: 1 1 auto;
  min-width: 0;
}

.sync-express-title {
  font-size: 26rpx;
  line-height: 1.3;
  font-weight: 900;
  color: #40535C;
}

.sync-express-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #7B8B92;
}

.address-form-fixed-action {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 246, 0.94);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 -12rpx 32rpx rgba(82, 116, 126, 0.08);
  box-sizing: border-box;
}

.save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 30rpx;
  line-height: 96rpx;
  font-weight: 900;
  color: #40535C;
  box-shadow: 0 18rpx 38rpx rgba(82, 116, 126, 0.2);
}

.save-button::after {
  border: 0;
}

.recognition-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  background: rgba(31, 45, 50, 0.42);
  box-sizing: border-box;
}

.recognition-modal {
  width: 100%;
  max-height: 78vh;
  padding: 30rpx 28rpx 28rpx;
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: 0 24rpx 56rpx rgba(31, 45, 50, 0.22);
  box-sizing: border-box;
}

.recognition-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.recognition-modal-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.recognition-close-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 58rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: #F3F6F3;
  color: #7B8B92;
  font-size: 34rpx;
  line-height: 58rpx;
  font-weight: 800;
}

.recognition-close-button::after {
  border: 0;
}

.recognition-textarea {
  width: 100%;
  min-height: 280rpx;
  margin-top: 26rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.08);
  background: #FFFDF5;
  color: #40535C;
  font-size: 25rpx;
  line-height: 1.55;
  font-weight: 700;
  box-sizing: border-box;
}

.recognition-tip {
  display: block;
  margin-top: 18rpx;
  font-size: 23rpx;
  line-height: 1.45;
  font-weight: 800;
  color: #7B8B92;
}

.recognition-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
}

.recognition-action {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1 1 0;
  min-width: 0;
  height: 82rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 82rpx;
  font-weight: 900;
  color: #40535C;
}

.recognition-action::after {
  border: 0;
}

.recognition-action.secondary {
  background: #F3F6F3;
}

.recognition-action.primary {
  background: #F6E396;
}
