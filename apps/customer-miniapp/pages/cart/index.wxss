.cart-page {
  --cart-bottom-bar-action-height: 88rpx;
  --cart-bottom-bar-padding-top: 22rpx;
  --cart-bottom-bar-padding-bottom: 28rpx;
  --cart-bottom-bar-safe-height: calc(
    var(--cart-bottom-bar-action-height) +
    var(--cart-bottom-bar-padding-top) +
    var(--cart-bottom-bar-padding-bottom) +
    env(safe-area-inset-bottom)
  );
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
  background:
    radial-gradient(circle at 12% 0%, rgba(246, 227, 150, 0.18) 0, transparent 30%),
    linear-gradient(180deg, #FFFDF5 0%, #FFF9DF 58%, #F6E396 100%);
  color: #40535C;
}

.cart-shell {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  margin: 18rpx 24rpx 0;
  padding-bottom: var(--cart-bottom-bar-safe-height);
  box-sizing: border-box;
}

.cart-toolbar,
.select-all,
.row-meta,
.row-stepper,
.bottom-summary,
.bottom-actions,
.cart-bottom-bar {
  display: flex;
  align-items: center;
}

.cart-toolbar {
  justify-content: space-between;
  padding: 26rpx 24rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
}

.select-all {
  gap: 16rpx;
}

.select-all-label,
.clear-action {
  font-size: 27rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.clear-action {
  color: #7B8B92;
}

.cart-list {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
}

.cart-list-scroll {
  height: 100%;
}

.cart-fulfillment-group {
  margin-bottom: 24rpx;
}

.cart-fulfillment-group:last-child {
  margin-bottom: 0;
}

.cart-fulfillment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 0 6rpx 14rpx;
}

.cart-fulfillment-title {
  font-size: 26rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.cart-fulfillment-count {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #7B8B92;
}

.checkbox,
.row-check,
.stepper-btn {
  flex-shrink: 0;
}

.checkbox {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  box-sizing: border-box;
  border: 3rpx solid #D8EEF2;
  border-radius: 50%;
  background: #FFFFFF;
}

.checkbox.active {
  border-color: #40535C;
  background: #F6E396;
}

.checkbox.active::after {
  content: '';
  width: 18rpx;
  height: 10rpx;
  border-left: 5rpx solid #40535C;
  border-bottom: 5rpx solid #40535C;
  transform: rotate(-45deg) translate(1rpx, -2rpx);
  box-sizing: border-box;
}

.checkbox.disabled {
  border-color: #D8EEF2;
  background: rgba(255, 255, 255, 0.62);
}

.row-check.disabled {
  opacity: 0.58;
}

.cart-swipe-row {
  position: relative;
  margin-bottom: 18rpx;
  overflow: hidden;
  border-radius: 32rpx;
}

.cart-swipe-row:last-child {
  margin-bottom: 0;
}

.cart-delete-action {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 32rpx 32rpx 0;
  background: #E86B61;
}

.cart-delete-label {
  font-size: 24rpx;
  font-weight: 900;
  color: #FFFFFF;
}

.cart-row {
  position: relative;
  display: flex;
  gap: 18rpx;
  padding: 24rpx 20rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
  transform: translateX(0);
  transition: transform 180ms ease;
  box-sizing: border-box;
}

.cart-row.swiped {
  transform: translateX(-132rpx);
}

.row-check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
}

.row-image-wrap {
  position: relative;
  width: 148rpx;
  height: 148rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFFDF5;
}

.row-image {
  width: 100%;
  height: 100%;
  background: #FFFDF5;
}

.row-soldout-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(39, 25, 15, 0.46);
}

.row-soldout-stamp {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 76rpx;
  height: 42rpx;
  padding: 0 14rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  box-sizing: border-box;
  color: #FFFFFF;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 900;
  transform: rotate(-8deg);
}

.row-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.row-name {
  display: block;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
  color: #40535C;
}

.row-meta {
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.row-spec-trigger {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 50rpx;
  padding: 10rpx 16rpx;
  border-radius: 16rpx;
  background: #FFFDF5;
  color: #7B8B92;
  box-sizing: border-box;
}

.row-spec-label,
.row-stock {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 800;
}

.row-stock {
  display: inline-flex;
  align-items: center;
  min-height: 50rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  background: rgba(214, 72, 50, 0.1);
  color: #E86B61;
}

.row-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: auto;
  padding-top: 22rpx;
}

.row-price {
  display: block;
  font-size: 29rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #E86B61;
}

.row-stepper {
  gap: 12rpx;
  padding: 7rpx;
  border-radius: 999rpx;
  background: #FFFDF5;
  box-shadow: inset 0 0 0 2rpx rgba(80, 104, 105, 0.06);
}

.stepper-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border: 2rpx solid #D8EEF2;
  border-radius: 50%;
  background: #FFFFFF;
  font-size: 0;
  line-height: 1;
  font-weight: 800;
  color: #7B8B92;
}

.stepper-btn::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 18rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #7B8B92;
  transform: translate(-50%, -50%);
}

.stepper-btn.plus {
  border-color: #40535C;
  background: #F6E396;
  color: #40535C;
}

.stepper-btn.plus::before,
.stepper-btn.plus::after {
  background: #40535C;
}

.stepper-btn.plus::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 5rpx;
  height: 18rpx;
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
}

.stepper-count {
  min-width: 22rpx;
  font-size: 25rpx;
  line-height: 1;
  font-weight: 900;
  text-align: center;
  color: #40535C;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  margin: 18rpx 24rpx 0;
  padding: 170rpx 36rpx var(--cart-bottom-bar-safe-height);
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 34rpx rgba(80, 104, 105, 0.08);
  color: #7B8B92;
}

.empty-title {
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.empty-body {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.5;
  font-weight: 700;
  text-align: center;
}

.empty-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  margin-top: 32rpx;
  min-width: 240rpx;
  padding: 0 34rpx;
  border-radius: 999rpx;
  background: #F6E396;
  font-size: 27rpx;
  line-height: 82rpx;
  font-weight: 900;
  color: #40535C;
}

.empty-action::after,
.checkout-button::after,
.quick-buy-submit::after {
  border: 0;
}

.cart-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  gap: 20rpx;
  padding:
    var(--cart-bottom-bar-padding-top)
    24rpx
    calc(var(--cart-bottom-bar-padding-bottom) + env(safe-area-inset-bottom));
  border-top: 2rpx solid rgba(80, 104, 105, 0.06);
  background: rgba(255, 253, 246, 0.96);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 -18rpx 42rpx rgba(80, 104, 105, 0.1);
  box-sizing: border-box;
}

.bottom-summary {
  flex: 1;
  min-width: 0;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
}

.bottom-total {
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.bottom-total-price {
  margin-left: 10rpx;
  color: #E86B61;
}

.bottom-warning {
  display: block;
  font-size: 21rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #E86B61;
}

.bottom-actions {
  width: 48%;
  min-width: 0;
  justify-content: flex-end;
}

.checkout-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: var(--cart-bottom-bar-action-height);
  min-width: 0;
  margin: 0;
  padding: 0 34rpx;
  border-radius: 999rpx;
  background: #F6E396;
  box-shadow: 0 18rpx 38rpx rgba(82, 116, 126, 0.18);
  font-size: 30rpx;
  line-height: var(--cart-bottom-bar-action-height);
  font-weight: 900;
  color: #40535C;
}

.checkout-button.disabled {
  background: #FFFDF5;
  box-shadow: none;
  color: rgba(64, 83, 92, 0.42);
}

.quick-buy-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: calc(96rpx + env(safe-area-inset-top)) 24rpx calc(96rpx + env(safe-area-inset-bottom));
  background: rgba(39, 25, 15, 0.38);
  box-sizing: border-box;
}

.quick-buy-panel {
  position: relative;
  width: 100%;
  max-height: calc(100vh - 192rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  overflow: hidden;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 36rpx;
  background: #FFFDF5;
  box-shadow: 0 28rpx 70rpx rgba(39, 25, 15, 0.2);
}

.quick-buy-image {
  width: 100%;
  height: 320rpx;
  background: #FFFDF5;
}

.row-image-placeholder,
.quick-buy-image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx;
  background: linear-gradient(135deg, #FFFDF5 0%, #F6E396 100%);
  box-sizing: border-box;
  text-align: center;
}

.row-image-placeholder text,
.quick-buy-image-placeholder text {
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.quick-buy-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: rgba(64, 83, 92, 0.72);
  backdrop-filter: blur(8rpx);
  font-size: 42rpx;
  line-height: 58rpx;
  text-align: center;
  color: #40535C;
}

.quick-buy-content {
  padding: 28rpx 34rpx 0;
}

.quick-buy-name {
  display: block;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #40535C;
}

.quick-buy-summary {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.55;
  font-weight: 700;
  color: #7B8B92;
}

.quick-buy-spec-title {
  display: block;
  margin-top: 28rpx;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #40535C;
}

.quick-buy-specs {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
  margin-bottom: 34rpx;
}

.quick-buy-spec {
  padding: 16rpx 26rpx;
  border: 2rpx solid rgba(80, 104, 105, 0.06);
  border-radius: 999rpx;
  background: #FFFFFF;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #7B8B92;
}

.quick-buy-spec.active {
  border-color: #40535C;
  background: #F6E396;
  color: #40535C;
}

.quick-buy-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin: 0 34rpx 34rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #F6E396;
  box-shadow: 0 18rpx 38rpx rgba(82, 116, 126, 0.18);
  font-size: 28rpx;
  line-height: 88rpx;
  font-weight: 900;
  color: #40535C;
}
