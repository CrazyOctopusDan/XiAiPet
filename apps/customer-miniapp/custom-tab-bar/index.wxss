.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 46rpx 22rpx 0;
  box-sizing: border-box;
}

.custom-tabbar__shell {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 16rpx 42rpx calc(20rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(255, 254, 248, 0.98) 0%, rgba(255, 247, 224, 0.98) 100%);
  border: 2rpx solid rgba(176, 146, 88, 0.2);
  border-bottom: none;
  border-radius: 36rpx 36rpx 0 0;
  box-shadow:
    inset 0 3rpx 0 rgba(255, 255, 255, 0.72),
    0 -10rpx 24rpx rgba(90, 118, 126, 0.08);
  backdrop-filter: blur(12rpx);
}

.custom-tabbar__shell::before {
  content: '';
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  top: 0;
  height: 3rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(246, 227, 150, 0.95) 0%, rgba(242, 196, 111, 0.95) 100%);
}

.custom-tabbar__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  width: 148rpx;
  color: #7B8B92;
}

.custom-tabbar__label {
  min-width: 84rpx;
  padding: 5rpx 12rpx 6rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.1;
  color: inherit;
  text-align: center;
}

.custom-tabbar__item.is-active {
  color: #40535C;
}

.custom-tabbar__item.is-active .custom-tabbar__label {
  background: rgba(246, 227, 150, 0.72);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.68);
}

.custom-tabbar__center-hitbox {
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  width: 132rpx;
  height: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.custom-tabbar__center-spacer {
  width: 180rpx;
  height: 1rpx;
  flex-shrink: 0;
}

.custom-tabbar__center-ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  border-radius: 66rpx;
  background: linear-gradient(145deg, #FFF8D8 0%, #F6E396 70%, #F2C46F 100%);
  box-shadow:
    inset 0 3rpx 0 rgba(255, 255, 255, 0.62),
    0 8rpx 20rpx rgba(82, 116, 126, 0.12);
}

.custom-tabbar__center-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  border-radius: 58rpx;
  background: linear-gradient(180deg, #FFE58D 0%, #F4CF68 100%);
  border: 4rpx solid rgba(74, 42, 19, 0.12);
  box-sizing: border-box;
  box-shadow:
    inset 0 5rpx 0 rgba(255, 255, 255, 0.46),
    0 8rpx 0 rgba(132, 102, 50, 0.2),
    0 14rpx 22rpx rgba(82, 116, 126, 0.12);
}

.custom-tabbar__center-hitbox.is-active-center .custom-tabbar__center-button {
  background: linear-gradient(180deg, #FFDE7A 0%, #EFC55C 100%);
}

.custom-tabbar__home-icon {
  position: relative;
  width: 48rpx;
  height: 42rpx;
}

.custom-tabbar__home-roof {
  position: absolute;
  top: 2rpx;
  left: 8rpx;
  width: 28rpx;
  height: 28rpx;
  border-top: 4rpx solid currentColor;
  border-left: 4rpx solid currentColor;
  border-radius: 6rpx 0 0 0;
  transform: rotate(45deg);
}

.custom-tabbar__home-body {
  position: absolute;
  left: 7rpx;
  right: 7rpx;
  bottom: 2rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-top: none;
  border-radius: 0 0 10rpx 10rpx;
  background: transparent;
}

.custom-tabbar__home-door {
  position: absolute;
  left: 19rpx;
  bottom: 5rpx;
  width: 10rpx;
  height: 12rpx;
  border-radius: 6rpx 6rpx 2rpx 2rpx;
  background: currentColor;
}

.custom-tabbar__profile-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  width: 48rpx;
  height: 42rpx;
}

.custom-tabbar__profile-head {
  flex-shrink: 0;
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.custom-tabbar__profile-body {
  margin-top: 4rpx;
  width: 34rpx;
  height: 16rpx;
  border: 4rpx solid currentColor;
  border-top: none;
  border-radius: 0 0 18rpx 18rpx;
}

.custom-tabbar__order-icon {
  display: flex;
  flex-direction: column;
  gap: 7rpx;
  width: 34rpx;
  padding: 7rpx 6rpx;
  border: 4rpx solid #40535C;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.custom-tabbar__order-line {
  height: 4rpx;
  border-radius: 999rpx;
  background: #40535C;
}

.custom-tabbar__order-line--short {
  width: 20rpx;
}

.custom-tabbar__order-line--tiny {
  width: 16rpx;
}
