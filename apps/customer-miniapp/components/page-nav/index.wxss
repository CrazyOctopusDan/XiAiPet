.page-nav {
  box-sizing: border-box;
  position: relative;
  z-index: 3;
}

.page-nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.page-nav-bar.is-fixed {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
}

.page-nav-bar--transparent {
  background: transparent;
}

.page-nav-bar--solid {
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(12rpx);
}

.page-nav-back {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
}

.page-nav-back--light {
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(8rpx);
}

.page-nav-back-icon {
  width: 22rpx;
  height: 22rpx;
  border-left: 5rpx solid #171717;
  border-bottom: 5rpx solid #171717;
  transform: rotate(45deg) translate(1px, -1px);
  box-sizing: border-box;
}

.page-nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  max-width: 420rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  pointer-events: none;
}

.page-nav-title--dark {
  color: #171717;
}

.page-nav-title--light {
  color: #FFFFFF;
}
