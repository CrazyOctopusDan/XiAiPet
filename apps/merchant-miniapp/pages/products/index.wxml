<view class="page">
  <view class="summary-card">
    <view class="summary-head">
      <view class="page-mark">商</view>
      <view class="summary-copy">
        <text class="page-title">商品管理</text>
        <text class="page-subtitle">按品类维护商品</text>
      </view>
    </view>

    <view class="summary-metrics">
      <view class="metric-chip accent">
        <text class="metric-value">{{summary.totalProducts}}</text>
        <text class="metric-label">当前商品</text>
      </view>
      <view class="metric-chip">
        <text class="metric-value">{{summary.publishedProducts}}</text>
        <text class="metric-label">已上架</text>
      </view>
      <view class="metric-chip">
        <text class="metric-value">{{summary.stockWarnings}}</text>
        <text class="metric-label">库存预警</text>
      </view>
    </view>
  </view>

  <view class="toolbar-card">
    <view class="toolbar-head">
      <view>
        <text class="section-title">商品筛选</text>
        <text class="section-note">商品编辑保持三步流程</text>
      </view>
      <button class="primary-button" bindtap="handleCreateTap">新建</button>
    </view>

    <view class="search-row">
      <input class="search-input" placeholder="商品名称或说明" value="{{draftKeyword}}" bindinput="handleKeywordInput" confirm-type="search" bindconfirm="handleKeywordConfirm" />
      <button class="search-button" bindtap="handleKeywordConfirm">搜索</button>
    </view>

    <view class="pill-row">
      <view class="pill {{item.isActive ? 'active' : ''}}" wx:for="{{categoryFilters}}" wx:key="id" data-id="{{item.id}}" bindtap="handleCategoryTap">{{item.label}}</view>
      <text class="clear-link" wx:if="{{keyword}}" bindtap="handleClearSearch">清空</text>
    </view>
  </view>

  <view class="empty-card" wx:if="{{isEmpty && !loading}}">
    <text class="empty-title">当前没有商品</text>
    <text class="empty-body">新建商品后会显示在这里</text>
  </view>

  <view class="card-list" wx:elif="{{!loading}}">
    <view
      class="product-swipe-row {{swipedProductId === item.id ? 'active' : ''}}"
      wx:for="{{cards}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtouchstart="handleProductTouchStart"
      bindtouchend="handleProductTouchEnd"
    >
      <button class="product-delete-action" data-id="{{item.id}}" data-name="{{item.name}}" catchtap="handleDeleteTap">删除</button>
      <view class="product-card" data-id="{{item.id}}" bindtap="handleEditTap">
        <image class="product-image" src="{{item.imagePreviewUrl}}" mode="aspectFill"></image>
        <view class="product-body">
          <view class="product-head">
            <text class="product-name">{{item.name}}</text>
            <text class="status-badge">{{item.statusLabel}}</text>
            <view class="product-move-actions">
              <button class="product-move-button" disabled="{{!item.canMoveUp || isReordering}}" data-id="{{item.id}}" data-direction="up" catchtap="handleMoveProductTap">上</button>
              <button class="product-move-button" disabled="{{!item.canMoveDown || isReordering}}" data-id="{{item.id}}" data-direction="down" catchtap="handleMoveProductTap">下</button>
            </view>
          </view>

          <view class="product-meta">
            <view class="meta-chip">
              <text class="meta-label">价格</text>
              <text class="meta-value">{{item.priceRangeLabel}}</text>
            </view>
            <view class="meta-chip">
              <text class="meta-label">库存</text>
              <text class="meta-value">{{item.stockLabel}}</text>
            </view>
            <view class="meta-chip full">
              <text class="meta-label">履约</text>
              <text class="meta-value">{{item.fulfillmentModesLabel}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{pageInfo.hasMore}}" class="product-load-more" bindtap="handleLoadMoreProducts">
      {{isLoadingMore ? '加载中' : '加载更多商品'}}
    </view>
  </view>
</view>
