<view class="page">
  <view class="hero-card">
    <text class="page-title">商品列表</text>
    <text class="page-subtitle">按一级品类浏览商品，点击卡片进入三步编辑。</text>
  </view>

  <view class="toolbar-card">
    <input class="search-input" placeholder="搜索商品名称" value="{{draftKeyword}}" bindinput="handleKeywordInput" confirm-type="search" bindconfirm="handleKeywordConfirm" />
    <view class="pill-row">
      <view class="pill {{item.isActive ? 'active' : ''}}" wx:for="{{categoryFilters}}" wx:key="id" data-id="{{item.id}}" bindtap="handleCategoryTap">{{item.label}}</view>
    </view>
  </view>

  <view class="empty-card" wx:if="{{isEmpty && !loading}}">
    <text class="page-title">当前品类还没有商品</text>
  </view>

  <view class="card-list" wx:elif="{{!loading}}">
    <view class="product-card" wx:for="{{cards}}" wx:key="id" data-id="{{item.id}}" bindtap="handleEditTap">
      <image class="product-image" src="{{item.imagePreviewUrl}}" mode="aspectFill"></image>
      <view class="product-body">
        <view class="product-head">
          <text class="product-name">{{item.name}}</text>
          <text class="status-badge">{{item.statusLabel}}</text>
        </view>
        <text class="product-copy">{{item.stockLabel}}</text>
        <text class="product-copy">{{item.priceRangeLabel}}</text>
        <text class="product-copy">{{item.fulfillmentModesLabel}}</text>
      </view>
    </view>
  </view>

  <button class="floating-button" bindtap="handleCreateTap">新建商品</button>
</view>
