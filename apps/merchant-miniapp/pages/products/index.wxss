.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 200rpx;
  background: linear-gradient(180deg, #F6EFE4 0%, #FCFAF5 100%);
  color: #1F2A33;
}

.hero-card,
.toolbar-card,
.product-card,
.empty-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(46, 91, 115, 0.08);
}

.page-title,
.page-subtitle,
.product-name,
.product-copy,
.status-badge {
  display: block;
}

.page-title,
.product-name {
  font-size: 34rpx;
  font-weight: 700;
}

.page-subtitle,
.product-copy {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7E8B95;
}

.toolbar-card,
.card-list,
.empty-card {
  margin-top: 24rpx;
}

.search-input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #F4F6F8;
  font-size: 28rpx;
  box-sizing: border-box;
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.pill {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #EEF2F5;
  color: #5D6B75;
  font-size: 24rpx;
}

.pill.active {
  background: rgba(46, 91, 115, 0.14);
  color: #2E5B73;
  font-weight: 600;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-card {
  display: flex;
  gap: 18rpx;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
  background: #EEF2F5;
}

.product-body {
  flex: 1;
}

.product-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 91, 115, 0.12);
  color: #2E5B73;
  font-size: 20rpx;
}

.floating-button {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  border: none;
  border-radius: 999rpx;
  background: #2E5B73;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}
