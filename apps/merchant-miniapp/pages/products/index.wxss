.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 24rpx 80rpx;
  background: #F8F1E8;
  color: #26333D;
}

.summary-card,
.toolbar-card,
.product-card,
.empty-card,
.product-delete-action {
  box-sizing: border-box;
  border: 2rpx solid #F0E2D0;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.summary-card,
.toolbar-card,
.empty-card {
  padding: 28rpx;
  border-radius: 24rpx;
}

.summary-head,
.summary-metrics,
.toolbar-head,
.search-row,
.pill-row,
.product-card,
.product-head,
.product-meta,
.product-delete-action {
  display: flex;
}

.summary-head,
.toolbar-head,
.search-row,
.pill-row,
.product-card,
.product-head {
  align-items: center;
}

.page-mark {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  border-radius: 26rpx;
  border: 2rpx solid #F3B56F;
  background: #FFF4E4;
  color: #2E5B73;
  font-size: 34rpx;
  font-weight: 800;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 22rpx;
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.section-title,
.section-note,
.product-name,
.status-badge,
.meta-label,
.meta-value,
.empty-title,
.empty-body,
.clear-link {
  display: block;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.15;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}

.summary-metrics {
  margin-top: 24rpx;
}

.metric-chip {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #FBF6EE;
}

.metric-chip + .metric-chip {
  margin-left: 12rpx;
}

.metric-chip.accent {
  background: #FFF3E6;
}

.metric-value {
  color: #26333D;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.15;
}

.metric-label {
  margin-top: 6rpx;
  color: #756756;
  font-size: 20rpx;
  line-height: 1.25;
}

.toolbar-card,
.card-list,
.empty-card {
  margin-top: 20rpx;
}

.toolbar-head {
  justify-content: space-between;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section-note {
  margin-top: 6rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.primary-button,
.search-button {
  box-sizing: border-box;
  width: 128rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 18rpx;
  background: #2E5B73;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 64rpx;
}

.search-row {
  margin-top: 22rpx;
}

.search-input {
  box-sizing: border-box;
  min-width: 0;
  height: 72rpx;
  flex: 1;
  padding: 0 22rpx;
  border: 1rpx solid #E3D5C4;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #26333D;
  font-size: 26rpx;
  line-height: 72rpx;
}

.search-button {
  width: 132rpx;
  height: 72rpx;
  margin-left: 14rpx;
  line-height: 72rpx;
}

.pill-row {
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.pill {
  box-sizing: border-box;
  min-width: 96rpx;
  height: 56rpx;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #FBF6EE;
  color: #697783;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 56rpx;
  text-align: center;
}

.pill.active {
  background: #FFF3E6;
  color: #8A5F35;
}

.clear-link {
  height: 56rpx;
  margin-left: auto;
  color: #2E5B73;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 56rpx;
}

.product-swipe-row {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
}

.product-swipe-row + .product-swipe-row {
  margin-top: 16rpx;
}

.product-card {
  position: relative;
  z-index: 2;
  width: 100%;
  padding: 20rpx;
  border-radius: 28rpx;
  transition: transform 180ms ease;
}

.product-swipe-row.active .product-card {
  transform: translateX(-156rpx);
}

.product-delete-action {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 1;
  align-items: center;
  justify-content: center;
  width: 148rpx;
  height: 100%;
  margin: 0;
  padding: 0;
  border-color: #F0D4CC;
  border-radius: 28rpx;
  background: #B6463A;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}

.product-image {
  width: 132rpx;
  height: 132rpx;
  flex: 0 0 132rpx;
  border-radius: 24rpx;
  background: #FBF6EE;
}

.product-body {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.product-head {
  justify-content: space-between;
}

.product-name {
  min-width: 0;
  flex: 1;
  color: #26333D;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.status-badge {
  flex: 0 0 auto;
  margin-left: 12rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: #EAF6EF;
  color: #3F7A57;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

.product-meta {
  flex-wrap: wrap;
  margin-top: 14rpx;
  margin-left: -6rpx;
  margin-right: -6rpx;
}

.meta-chip {
  box-sizing: border-box;
  width: 50%;
  min-width: 0;
  padding: 0 6rpx;
}

.meta-chip.full {
  width: 100%;
  margin-top: 10rpx;
}

.meta-label {
  color: #9A8A78;
  font-size: 20rpx;
  line-height: 1.2;
}

.meta-value {
  margin-top: 5rpx;
  color: #31414D;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.empty-card {
  text-align: center;
}

.empty-title {
  color: #26333D;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.2;
}

.empty-body {
  margin-top: 10rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}

.primary-button::after,
.search-button::after,
.product-delete-action::after {
  border: none;
}
