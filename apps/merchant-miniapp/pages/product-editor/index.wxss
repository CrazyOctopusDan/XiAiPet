.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 180rpx;
  box-sizing: border-box;
  background: #F8F1E8;
  color: #26333D;
}

.summary-card,
.section-card,
.loading-card {
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.summary-card,
.section-card,
.loading-card {
  padding: 28rpx;
}

.section-card,
.loading-card {
  margin-top: 22rpx;
}

.summary-head,
.section-head,
.step-row,
.pill-row,
.line-editor-head,
.line-row,
.toggle-row {
  display: flex;
  align-items: center;
}

.section-head,
.line-editor-head,
.toggle-row {
  justify-content: space-between;
}

.page-mark {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #F3EBDD;
  color: #26333D;
  font-size: 36rpx;
  font-weight: 800;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 20rpx;
}

.page-title,
.page-subtitle,
.loading-title,
.section-title,
.section-badge,
.field-label,
.field-helper,
.preview-label,
.preview-copy,
.replace-copy,
.upload-copy,
.toggle-copy,
.override-copy {
  display: block;
}

.page-title {
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 800;
}

.page-subtitle,
.loading-title {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.35;
}

.step-row,
.pill-row {
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.step-pill,
.pill {
  min-height: 56rpx;
  margin-top: 12rpx;
  margin-right: 12rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #FBF6EE;
  color: #756756;
  font-size: 24rpx;
  line-height: 56rpx;
}

.step-pill.active,
.pill.active {
  background: #FFF4E4;
  color: #2E5B73;
  font-weight: 800;
}

.section-title {
  color: #26333D;
  font-size: 32rpx;
  line-height: 1.15;
  font-weight: 800;
}

.section-badge {
  flex: 0 0 auto;
  height: 44rpx;
  margin-left: 18rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #FFF4E4;
  color: #9A6B28;
  font-size: 22rpx;
  line-height: 44rpx;
}

.upload-tile {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 184rpx;
  height: 184rpx;
  margin-top: 22rpx;
  border: 2rpx solid #E8DAC8;
  border-radius: 24rpx;
  background: #FBF6EE;
  overflow: hidden;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.upload-copy {
  color: #756756;
  font-size: 24rpx;
  font-weight: 800;
}

.replace-copy {
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.92);
  color: #2E5B73;
  font-size: 20rpx;
  line-height: 40rpx;
}

.field-label,
.field-helper,
.preview-copy,
.toggle-copy {
  margin-top: 16rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.35;
}

.field-input,
.field-area {
  width: 100%;
  margin-top: 16rpx;
  border: 2rpx solid #E8DAC8;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #26333D;
  font-size: 26rpx;
  box-sizing: border-box;
}

.field-input {
  height: 72rpx;
  padding: 0 22rpx;
}

.field-area {
  height: 176rpx;
  padding: 18rpx 22rpx;
  line-height: 1.45;
}

.line-editor,
.preview-card {
  margin-top: 22rpx;
}

.line-editor-head {
  min-height: 64rpx;
}

.line-row {
  margin-top: 14rpx;
}

.line-row .field-input {
  margin-top: 0;
}

.compact {
  flex: 1;
  min-width: 0;
}

.name-input {
  margin-right: 12rpx;
}

.price-input {
  flex: 0 0 auto;
  width: 150rpx;
  margin-right: 12rpx;
}

.preview-card {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #FBF6EE;
}

.preview-label {
  color: #26333D;
  font-size: 24rpx;
  font-weight: 800;
}

.override-copy {
  margin-top: 8rpx;
  color: #B85D48;
  font-size: 20rpx;
}

.mini-button,
.action-button {
  border: none;
  border-radius: 18rpx;
  font-weight: 800;
}

.mini-button {
  flex: 0 0 auto;
  min-width: 116rpx;
  height: 64rpx;
  padding: 0 16rpx;
  background: #EEF3F4;
  color: #2E5B73;
  font-size: 22rpx;
  line-height: 64rpx;
}

.mini-button.danger {
  min-width: 92rpx;
  background: #FFECE5;
  color: #B85D48;
}

.toggle-row {
  min-height: 64rpx;
  margin-top: 22rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #FBF6EE;
  box-sizing: border-box;
}

.toggle-row .field-label,
.toggle-row .toggle-copy {
  margin-top: 0;
}

.action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding: 16rpx;
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.12);
}

.action-button {
  width: 100%;
  height: 72rpx;
  background: #2E5B73;
  color: #FFFFFF;
  font-size: 26rpx;
  line-height: 72rpx;
}
