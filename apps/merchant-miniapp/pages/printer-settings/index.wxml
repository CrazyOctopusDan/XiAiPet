<view class="printer-page">
  <view class="hero-card">
    <view>
      <text class="page-title">打印机设置</text>
      <text class="page-subtitle">当前设备：{{connectedDeviceName}}</text>
    </view>
    <button class="ghost-button" bindtap="handleBackTap">返回</button>
  </view>

  <view class="content-card">
    <view class="section-head">
      <text class="section-title">蓝牙设备</text>
      <button class="primary-button small-button" loading="{{searching}}" bindtap="handleSearchTap">搜索</button>
    </view>

    <view class="empty-state" wx:if="{{devices.length === 0}}">
      <text class="empty-title">暂无设备</text>
      <text class="empty-body">打开小票机电源后搜索附近蓝牙设备。</text>
    </view>

    <view
      class="device-row"
      wx:for="{{devices}}"
      wx:key="deviceId"
      data-index="{{index}}"
      bindtap="handleDeviceTap"
    >
      <view>
        <text class="device-name">{{item.name}}</text>
        <text class="device-id">{{item.deviceId}}</text>
      </view>
      <text class="device-action">{{connecting ? '连接中' : '绑定'}}</text>
    </view>
  </view>

  <view class="content-card">
    <text class="section-title">已绑定设备</text>
    <view class="meta-row">
      <text class="meta-label">设备名称</text>
      <text class="meta-value">{{connectedDeviceName}}</text>
    </view>
    <view class="button-row">
      <button class="primary-button row-button" loading="{{testing}}" bindtap="handleTestPrintTap">测试打印</button>
      <button class="secondary-button row-button" bindtap="handleDisconnectTap">解绑打印机</button>
    </view>
  </view>
</view>
