.printer-page {
  min-height: 100vh;
  padding: 32rpx 24rpx;
  background: linear-gradient(180deg, #F6EFE4 0%, #FCFAF5 100%);
  color: #1F2A33;
}

.hero-card,
.content-card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(46, 91, 115, 0.08);
  padding: 28rpx;
}

.content-card {
  margin-top: 24rpx;
}

.hero-card,
.section-head,
.meta-row,
.button-row,
.device-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.page-title,
.page-subtitle,
.section-title,
.empty-title,
.empty-body,
.device-name,
.device-id,
.device-action,
.meta-label,
.meta-value {
  display: block;
}

.page-title {
  font-size: 46rpx;
  font-weight: 700;
}

.page-subtitle,
.empty-body,
.device-id,
.meta-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7E8B95;
}

.section-title,
.empty-title {
  font-size: 32rpx;
  font-weight: 700;
}

.empty-state,
.device-row,
.meta-row,
.button-row {
  margin-top: 22rpx;
}

.empty-state {
  padding: 28rpx;
  border-radius: 22rpx;
  background: #F8FBFC;
}

.device-row {
  padding: 22rpx 0;
  border-bottom: 2rpx solid rgba(46, 91, 115, 0.08);
}

.device-name {
  font-size: 28rpx;
  font-weight: 600;
}

.device-action,
.meta-value {
  font-size: 24rpx;
  color: #2E5B73;
  font-weight: 600;
}

.ghost-button,
.primary-button,
.secondary-button {
  border: none;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.ghost-button,
.secondary-button {
  background: #EEF2F5;
  color: #4C5A65;
}

.primary-button {
  background: #2E5B73;
  color: #FFFFFF;
}

.small-button {
  min-width: 140rpx;
  min-height: 68rpx;
  line-height: 68rpx;
}

.row-button {
  flex: 1;
  min-height: 76rpx;
  line-height: 76rpx;
}
