.printer-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 120rpx;
  box-sizing: border-box;
  background: #F8F1E8;
  color: #26333D;
}

.summary-card,
.content-card {
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.summary-card,
.content-card {
  padding: 28rpx;
}

.content-card {
  margin-top: 22rpx;
}

.summary-head,
.section-head,
.summary-metrics,
.device-row,
.button-row {
  display: flex;
  align-items: center;
}

.summary-head,
.section-head,
.device-row {
  justify-content: space-between;
}

.page-mark {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #F3EBDD;
  color: #26333D;
  font-size: 36rpx;
  font-weight: 800;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 20rpx;
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.section-title,
.section-meta,
.empty-title,
.empty-body,
.device-name,
.device-id,
.device-action,
.status-badge,
.bound-label,
.bound-value {
  display: block;
}

.page-title {
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 800;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.icon-button,
.small-button,
.primary-button,
.secondary-button {
  border: none;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.icon-button {
  flex: 0 0 auto;
  width: 112rpx;
  height: 64rpx;
  margin-left: 18rpx;
  background: #EEF3F4;
  color: #2E5B73;
  line-height: 64rpx;
}

.summary-metrics {
  margin-top: 26rpx;
}

.metric-chip {
  flex: 1;
  min-width: 0;
  height: 112rpx;
  margin-left: 14rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border: 2rpx solid #F0E2D0;
  border-radius: 20rpx;
  background: #FBF6EE;
}

.metric-chip:first-child {
  margin-left: 0;
}

.metric-chip-primary {
  border-color: #F3B56F;
  background: #FFF4E4;
}

.metric-value {
  color: #2E5B73;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 800;
}

.metric-label {
  margin-top: 12rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.section-title {
  color: #26333D;
  font-size: 32rpx;
  line-height: 1.15;
  font-weight: 800;
}

.section-meta {
  margin-top: 8rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.3;
}

.small-button {
  flex: 0 0 auto;
  width: 128rpx;
  height: 64rpx;
  margin-left: 18rpx;
  background: #2E5B73;
  color: #FFFFFF;
  line-height: 64rpx;
}

.empty-state,
.device-list,
.bound-panel,
.button-row {
  margin-top: 22rpx;
}

.empty-state,
.bound-panel {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #FBF6EE;
}

.empty-title {
  color: #26333D;
  font-size: 28rpx;
  font-weight: 800;
}

.empty-body {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.35;
}

.device-row {
  min-height: 88rpx;
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #FBF6EE;
  box-sizing: border-box;
}

.device-row:first-child {
  margin-top: 0;
}

.device-copy {
  min-width: 0;
  flex: 1;
}

.device-name {
  color: #26333D;
  font-size: 28rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.device-id {
  margin-top: 8rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.3;
  word-break: break-all;
}

.device-action {
  flex: 0 0 auto;
  margin-left: 18rpx;
  color: #2E5B73;
  font-size: 24rpx;
  font-weight: 800;
}

.status-badge {
  flex: 0 0 auto;
  min-width: 92rpx;
  height: 44rpx;
  margin-left: 18rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #FFECE5;
  color: #B85D48;
  font-size: 22rpx;
  line-height: 44rpx;
  text-align: center;
  box-sizing: border-box;
}

.status-badge-ready {
  background: #EEF3F4;
  color: #2E5B73;
}

.bound-label {
  color: #756756;
  font-size: 22rpx;
}

.bound-value {
  margin-top: 8rpx;
  color: #26333D;
  font-size: 30rpx;
  font-weight: 800;
}

.row-button {
  flex: 1;
  height: 72rpx;
  margin-left: 14rpx;
  line-height: 72rpx;
}

.row-button:first-child {
  margin-left: 0;
}

.primary-button {
  background: #2E5B73;
  color: #FFFFFF;
}

.secondary-button {
  background: #EEF3F4;
  color: #2E5B73;
}
