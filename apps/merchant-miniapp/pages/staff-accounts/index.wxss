.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 24rpx 80rpx;
  background: #F8F1E8;
  color: #26333D;
}

.summary-card,
.create-card,
.account-card,
.empty-card {
  box-sizing: border-box;
  border: 2rpx solid #F0E2D0;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.summary-card,
.create-card,
.empty-card {
  border-radius: 24rpx;
}

.summary-card,
.create-card {
  padding: 28rpx;
}

.summary-head,
.create-row,
.list-head,
.section-head,
.account-main,
.account-tags,
.account-actions {
  display: flex;
}

.summary-head,
.create-row,
.section-head,
.account-main,
.account-tags,
.account-actions {
  align-items: center;
}

.page-mark {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  border-radius: 26rpx;
  border: 2rpx solid #F3B56F;
  background: #FFF4E4;
  color: #2E5B73;
  font-size: 34rpx;
  font-weight: 800;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 22rpx;
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.section-title,
.section-note,
.status-pill,
.account-name,
.tag,
.empty-title,
.empty-note {
  display: block;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.15;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}

.summary-metrics {
  display: flex;
  margin-top: 24rpx;
}

.metric-chip {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #FBF6EE;
}

.metric-chip + .metric-chip {
  margin-left: 12rpx;
}

.metric-chip.accent {
  background: #FFF3E6;
}

.metric-value {
  color: #26333D;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.15;
}

.metric-label {
  margin-top: 6rpx;
  color: #756756;
  font-size: 20rpx;
  line-height: 1.25;
}

.create-card {
  margin-top: 20rpx;
}

.section-head {
  justify-content: space-between;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section-note {
  margin-top: 6rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.status-pill {
  max-width: 260rpx;
  margin-left: 20rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #FBF6EE;
  color: #2E5B73;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.create-row {
  margin-top: 22rpx;
}

.input {
  box-sizing: border-box;
  min-width: 0;
  height: 72rpx;
  flex: 1;
  padding: 0 22rpx;
  border: 1rpx solid #E3D5C4;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #26333D;
  font-size: 26rpx;
  line-height: 72rpx;
}

.primary-button,
.secondary-button,
.danger-button {
  box-sizing: border-box;
  min-width: 0;
  height: 72rpx;
  padding: 0 22rpx;
  border: none;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.primary-button {
  flex: 0 0 144rpx;
  margin-left: 14rpx;
  background: #2E5B73;
  color: #FFFFFF;
}

.list-head {
  align-items: flex-end;
  justify-content: space-between;
  margin: 28rpx 4rpx 16rpx;
}

.list-head .section-note {
  margin-top: 0;
  margin-left: 20rpx;
}

.account-card {
  padding: 22rpx;
  border-radius: 28rpx;
}

.account-card + .account-card {
  margin-top: 16rpx;
}

.account-card.disabled {
  opacity: 0.72;
}

.account-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  flex: 0 0 70rpx;
  border-radius: 22rpx;
  background: #FFF3E6;
  color: #8A5F35;
  font-size: 28rpx;
  font-weight: 800;
}

.account-copy {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.account-name {
  color: #26333D;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.account-tags {
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.tag {
  margin-right: 10rpx;
  margin-bottom: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #FBF6EE;
  color: #697783;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
}

.tag.active {
  background: #EAF6EF;
  color: #3F7A57;
}

.tag.disabled {
  background: #F8EDEA;
  color: #B6463A;
}

.account-actions {
  margin-top: 18rpx;
}

.secondary-button,
.danger-button {
  flex: 1;
  background: #FBF6EE;
}

.secondary-button {
  color: #2E5B73;
}

.danger-button {
  margin-left: 12rpx;
  color: #B6463A;
}

.primary-button::after,
.secondary-button::after,
.danger-button::after {
  border: none;
}

.empty-card {
  padding: 44rpx 28rpx;
  text-align: center;
}

.empty-title {
  color: #26333D;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.empty-note {
  margin-top: 10rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}
