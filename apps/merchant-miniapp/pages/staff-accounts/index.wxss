.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #F4F6F8;
  color: #1F2A33;
}

.panel,
.account-card {
  padding: 28rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
}

.panel {
  margin-bottom: 24rpx;
}

.title,
.subtitle,
.status,
.account-name,
.account-meta {
  display: block;
}

.title {
  margin-bottom: 8rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.subtitle,
.status,
.account-meta {
  font-size: 26rpx;
  line-height: 1.6;
  color: #4B5963;
}

.create-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-top: 20rpx;
}

.input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #C9D3DB;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.primary-button,
.secondary-button,
.danger-button {
  border-radius: 14rpx;
  font-size: 26rpx;
}

.primary-button {
  background: #2E5B73;
  color: #FFFFFF;
}

.account-card {
  margin-bottom: 18rpx;
}

.account-name {
  font-size: 30rpx;
  font-weight: 600;
}

.account-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.secondary-button {
  border: 1rpx solid #2E5B73;
  background: #FFFFFF;
  color: #2E5B73;
}

.danger-button {
  border: 1rpx solid #B6463A;
  background: #FFFFFF;
  color: #B6463A;
}
