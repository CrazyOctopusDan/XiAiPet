.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 120rpx;
  box-sizing: border-box;
  background: #F8F1E8;
  color: #26333D;
}

.summary-card,
.loading-card,
.section-card {
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.summary-card {
  padding: 28rpx;
}

.summary-head,
.section-head,
.section-title-row,
.section-toolbar,
.tier-head,
.field-pair,
.delivery-row,
.location-card,
.linked-entry,
.editor-head {
  display: flex;
  align-items: center;
}

.summary-head,
.section-head,
.section-toolbar,
.tier-head,
.location-card,
.linked-entry,
.editor-head {
  justify-content: space-between;
}

.page-mark,
.section-icon,
.linked-entry-icon {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F3EBDD;
  color: #26333D;
  font-weight: 800;
}

.page-mark {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  font-size: 36rpx;
}

.summary-copy,
.section-copy,
.linked-entry-copy {
  min-width: 0;
  flex: 1;
  margin-left: 20rpx;
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.loading-title,
.section-title,
.section-meta,
.dirty-badge,
.toolbar-copy,
.toolbar-link,
.delivery-distance,
.delivery-copy,
.delivery-more,
.location-title,
.location-meta,
.location-action,
.linked-entry-title,
.linked-entry-meta,
.linked-entry-action,
.tier-title,
.tier-badge,
.editor-title,
.editor-close {
  display: block;
}

.page-title {
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 800;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.35;
}

.summary-metrics {
  display: flex;
  margin-top: 26rpx;
}

.metric-chip {
  flex: 1;
  min-width: 0;
  height: 112rpx;
  margin-left: 14rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border: 2rpx solid #F0E2D0;
  border-radius: 20rpx;
  background: #FBF6EE;
}

.metric-chip:first-child {
  margin-left: 0;
}

.metric-chip-primary {
  border-color: #F3B56F;
  background: #FFF4E4;
}

.metric-value {
  color: #2E5B73;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
}

.metric-label {
  margin-top: 10rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.linked-entry {
  margin-top: 24rpx;
  padding: 18rpx;
  border: 2rpx solid #EAD9C5;
  border-radius: 20rpx;
  background: #FFFDF8;
}

.linked-entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: #FFF1D2;
  font-size: 28rpx;
}

.linked-entry-title {
  color: #26333D;
  font-size: 26rpx;
  line-height: 1.25;
  font-weight: 800;
}

.linked-entry-meta {
  margin-top: 6rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.3;
}

.linked-entry-action {
  flex: 0 0 auto;
  margin-left: 14rpx;
  color: #2E5B73;
  font-size: 24rpx;
  font-weight: 800;
}

.loading-card {
  margin-top: 22rpx;
  padding: 32rpx;
}

.loading-title {
  color: #756756;
  font-size: 26rpx;
}

.section-list {
  margin-top: 22rpx;
}

.section-card {
  margin-top: 22rpx;
  padding: 24rpx;
}

.section-card:first-child {
  margin-top: 0;
}

.section-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
}

.section-title {
  color: #26333D;
  font-size: 32rpx;
  line-height: 1.15;
  font-weight: 800;
}

.section-meta {
  margin-top: 8rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.3;
}

.dirty-badge {
  flex: 0 0 auto;
  min-width: 82rpx;
  height: 44rpx;
  margin-left: 18rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #EEF3F4;
  color: #2E5B73;
  font-size: 22rpx;
  line-height: 44rpx;
  text-align: center;
  box-sizing: border-box;
}

.dirty-badge-active {
  background: #FFECE5;
  color: #B85D48;
}

.form-stack,
.section-toolbar,
.delivery-list,
.tier-card,
.field-area,
.location-card {
  margin-top: 22rpx;
}

.section-toolbar {
  min-height: 64rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #FBF6EE;
  box-sizing: border-box;
}

.toolbar-copy {
  color: #756756;
  font-size: 24rpx;
}

.toolbar-link {
  color: #2E5B73;
  font-size: 24rpx;
  font-weight: 700;
}

.field-input,
.field-area {
  width: 100%;
  border: 2rpx solid #E8DAC8;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #26333D;
  font-size: 26rpx;
  box-sizing: border-box;
}

.field-input {
  height: 72rpx;
  margin-top: 16rpx;
  padding: 0 22rpx;
}

.form-stack > .field-input:first-child {
  margin-top: 0;
}

.field-pair {
  margin-top: 16rpx;
}

.field-pair .field-input {
  margin-top: 0;
}

.field-half {
  width: 50%;
  margin-left: 12rpx;
}

.field-half:first-child {
  margin-left: 0;
}

.field-area {
  height: 164rpx;
  padding: 18rpx 22rpx;
  line-height: 1.45;
}

.location-card {
  min-height: 96rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid #E8DAC8;
  border-radius: 18rpx;
  background: #FFFDF8;
  box-sizing: border-box;
}

.location-copy {
  min-width: 0;
  flex: 1;
}

.location-title {
  color: #26333D;
  font-size: 26rpx;
  line-height: 1.35;
}

.location-meta {
  margin-top: 6rpx;
  color: #756756;
  font-size: 22rpx;
}

.location-action {
  flex: 0 0 auto;
  margin-left: 18rpx;
  color: #2E5B73;
  font-size: 24rpx;
  font-weight: 800;
}

.delivery-row {
  min-height: 68rpx;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 18rpx;
  background: #FBF6EE;
  box-sizing: border-box;
}

.delivery-row:first-child {
  margin-top: 0;
}

.delivery-distance {
  flex: 0 0 auto;
  width: 88rpx;
  color: #2E5B73;
  font-size: 24rpx;
  font-weight: 800;
}

.delivery-copy {
  min-width: 0;
  flex: 1;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.35;
}

.delivery-more {
  flex: 0 0 auto;
  margin-left: 14rpx;
  color: #B99C77;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1;
}

.tier-card {
  padding: 18rpx;
  border-radius: 20rpx;
  background: #FBF6EE;
}

.tier-title {
  min-width: 0;
  flex: 1;
  color: #26333D;
  font-size: 28rpx;
  font-weight: 800;
}

.tier-badge {
  flex: 0 0 auto;
  margin-left: 16rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #FFF4E4;
  color: #9A6B28;
  font-size: 22rpx;
}

.ghost-button,
.save-button {
  width: 100%;
  height: 72rpx;
  margin-top: 20rpx;
  border: none;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.ghost-button {
  background: #EEF3F4;
  color: #2E5B73;
}

.save-button {
  background: #2E5B73;
  color: #FFFFFF;
}

.editor-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 60;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx;
  box-sizing: border-box;
  background: rgba(38, 51, 61, 0.34);
}

.editor-panel {
  width: 100%;
  max-width: 680rpx;
  padding: 26rpx;
  border: 2rpx solid #F0E2D0;
  border-radius: 26rpx;
  background: #FFFDF8;
  box-shadow: 0 22rpx 52rpx rgba(38, 51, 61, 0.18);
  box-sizing: border-box;
}

.editor-title {
  color: #26333D;
  font-size: 32rpx;
  font-weight: 800;
}

.editor-close {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #FBF6EE;
  color: #756756;
  font-size: 36rpx;
  line-height: 50rpx;
  text-align: center;
}
