<view class="page">
  <view class="summary-card">
    <view class="summary-head">
      <view class="page-mark">配</view>
      <view class="summary-copy">
        <text class="page-title">运营配置</text>
        <text class="page-subtitle">店务规则分区保存</text>
      </view>
    </view>

    <view class="summary-metrics">
      <view class="metric-chip metric-chip-primary">
        <text class="metric-value">{{view.summary.totalSections}}</text>
        <text class="metric-label">配置分区</text>
      </view>
      <view class="metric-chip">
        <text class="metric-value">{{view.summary.dirtySections}}</text>
        <text class="metric-label">未保存</text>
      </view>
      <view class="metric-chip">
        <text class="metric-value">{{view.summary.deliveryRuleCount}}</text>
        <text class="metric-label">配送档</text>
      </view>
    </view>

    <view class="linked-entry" bindtap="handleNavigateRechargeConfig">
      <view class="linked-entry-icon">充</view>
      <view class="linked-entry-copy">
        <text class="linked-entry-title">充值档位与赠品</text>
        <text class="linked-entry-meta">维护充值金额、赠送余额、赠品有效期</text>
      </view>
      <text class="linked-entry-action">进入</text>
    </view>
  </view>

  <view class="loading-card" wx:if="{{loading}}">
    <text class="loading-title">正在加载配置</text>
  </view>

  <view class="section-list" wx:else>
    <view class="section-card" wx:for="{{view.sections}}" wx:key="sectionId">
      <view class="section-head">
        <view class="section-title-row">
          <view class="section-icon">{{item.iconToken}}</view>
          <view class="section-copy">
            <text class="section-title">{{item.title}}</text>
            <text class="section-meta">{{item.summaryLabel}} · {{item.updatedLabel}}</text>
          </view>
        </view>
        <text class="dirty-badge {{item.dirtyLabel ? 'dirty-badge-active' : ''}}">{{item.dirtyLabel || '已保存'}}</text>
      </view>

      <view class="form-stack" wx:if="{{item.sectionId === 'store-profile'}}">
        <input class="field-input" data-field="storeName" value="{{item.storeFields.storeName}}" placeholder="店铺名称" bindinput="handleStoreInput" />
        <view class="location-card" bindtap="handleChooseStoreLocation">
          <view class="location-copy">
            <text class="location-title">{{item.storeFields.address || '选择店铺位置'}}</text>
            <text class="location-meta">用于计算用户配送距离</text>
          </view>
          <text class="location-action">选择</text>
        </view>
        <input class="field-input" data-field="wechatId" value="{{item.storeFields.wechatId}}" placeholder="微信号" bindinput="handleStoreInput" />
        <input class="field-input" data-field="ownerPhone" value="{{item.storeFields.ownerPhone}}" placeholder="店主手机号" bindinput="handleStoreInput" />
      </view>

      <view wx:if="{{item.sectionId === 'delivery-rules'}}">
        <view class="section-toolbar">
          <text class="toolbar-copy">下单页展示规则</text>
          <text class="toolbar-link" bindtap="handleOpenDeliveryNotice">说明</text>
        </view>
        <view class="delivery-list">
          <view class="delivery-row" wx:for="{{item.deliveryRows}}" wx:for-item="row" wx:for-index="rowIndex" wx:key="explainer" data-index="{{rowIndex}}" bindtap="handleDeliveryRowTap">
            <text class="delivery-distance">{{row.distanceKm}}km</text>
            <text class="delivery-copy">{{row.explainer}}</text>
            <text class="delivery-more">···</text>
          </view>
        </view>
        <button class="ghost-button" bindtap="handleAddDeliveryRule">新增配送档</button>
      </view>

      <view wx:if="{{item.sectionId === 'membership-tiers'}}">
        <view class="tier-card" wx:for="{{item.membershipRows}}" wx:for-item="row" wx:for-index="rowIndex" wx:key="tierId">
          <view class="tier-head">
            <text class="tier-title">{{row.name || '未命名等级'}}</text>
            <text class="tier-badge">{{row.thresholdLabel}}</text>
          </view>
          <input class="field-input" data-index="{{rowIndex}}" data-field="threshold" type="digit" value="{{row.threshold}}" placeholder="累计充值门槛" bindinput="handleMembershipInput" />
          <input class="field-input" data-index="{{rowIndex}}" data-field="name" value="{{row.name}}" placeholder="等级名称" bindinput="handleMembershipInput" />
          <input class="field-input" data-index="{{rowIndex}}" data-field="description" value="{{row.description}}" placeholder="等级说明" bindinput="handleMembershipInput" />
        </view>
        <button class="ghost-button" bindtap="handleAddTier">新增等级</button>
      </view>

      <view class="form-stack" wx:if="{{item.sectionId === 'banner'}}">
        <input class="field-input" data-field="fileId" value="{{item.bannerFields.fileId}}" placeholder="Banner fileId" bindinput="handleBannerInput" />
        <input class="field-input" data-field="altText" value="{{item.bannerFields.altText}}" placeholder="Banner 文案" bindinput="handleBannerInput" />
        <button class="ghost-button" bindtap="handleUploadBanner">上传 Banner</button>
      </view>

      <view wx:if="{{item.sectionId === 'custom-notice'}}">
        <view class="section-toolbar">
          <text class="toolbar-copy">用户端首页点击「购前须知」后展示</text>
          <text class="toolbar-link" bindtap="handleNoticeToggle">{{item.customNoticeFields.enabled ? '已开启' : '已关闭'}}</text>
        </view>
        <textarea class="field-area" data-field="content" value="{{item.customNoticeFields.content}}" placeholder="购前须知内容" bindinput="handleNoticeInput"></textarea>
      </view>

      <button class="save-button" data-section-id="{{item.sectionId}}" bindtap="handleSaveSection">保存{{item.title}}</button>
    </view>
  </view>

  <view class="editor-mask" wx:if="{{deliveryEditorVisible}}" bindtap="handleCloseDeliveryEditor">
    <view class="editor-panel" catchtap="handleEditorTap">
      <view class="editor-head">
        <text class="editor-title">{{deliveryEditorIndex >= 0 ? '编辑配送档' : '新增配送档'}}</text>
        <text class="editor-close" bindtap="handleCloseDeliveryEditor">×</text>
      </view>
      <input class="field-input" type="digit" data-field="distanceKm" value="{{deliveryEditorDraft.distanceKm}}" placeholder="配送距离 km" bindinput="handleDeliveryEditorInput" />
      <input class="field-input" type="digit" data-field="minimumOrderAmount" value="{{deliveryEditorDraft.minimumOrderAmount}}" placeholder="起送金额，可留空" bindinput="handleDeliveryEditorInput" />
      <input class="field-input" type="digit" data-field="deliveryFee" value="{{deliveryEditorDraft.deliveryFee}}" placeholder="配送费" bindinput="handleDeliveryEditorInput" />
      <button class="save-button" bindtap="handleConfirmDeliveryEditor">确认</button>
    </view>
  </view>
</view>
