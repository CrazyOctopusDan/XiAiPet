.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 80rpx;
  background:
    radial-gradient(circle at top left, rgba(246, 176, 103, 0.2), transparent 36%),
    linear-gradient(180deg, #F7F1E6 0%, #FBFAF6 100%);
  color: #1F2A33;
}

.hero-card,
.workspace-card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(69, 110, 154, 0.1);
}

.hero-card {
  padding: 32rpx 28rpx;
}

.page-title,
.page-subtitle,
.card-title,
.card-badge,
.card-subtitle,
.card-description {
  display: block;
}

.page-title,
.card-title {
  font-size: 36rpx;
  font-weight: 700;
}

.page-subtitle,
.card-description {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6E7B85;
}

.workspace-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 24rpx;
}

.workspace-card {
  box-sizing: border-box;
  width: calc((100% - 20rpx) / 2);
  padding: 0 24rpx 24rpx;
}

.card-accent {
  height: 14rpx;
  margin: 0 -24rpx 22rpx;
  border-radius: 28rpx 28rpx 12rpx 12rpx;
}

.card-head {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.icon-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: #F4F0E8;
  font-size: 36rpx;
  font-weight: 700;
}

.card-meta {
  flex: 1;
}

.card-badge {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8A6A32;
}

.card-subtitle {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.card-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
}

.primary-button,
.secondary-button {
  border: none;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.primary-button {
  background: #2E5B73;
  color: #FFFFFF;
}

.secondary-button {
  background: #EEF2F5;
  color: #4C5A65;
}
