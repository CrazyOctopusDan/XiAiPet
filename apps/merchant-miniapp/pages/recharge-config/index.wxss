.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 24rpx 120rpx;
  background: #F8F1E8;
  color: #26333D;
}

.summary-card,
.loading-card,
.empty-card,
.plan-card {
  box-sizing: border-box;
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.summary-card,
.loading-card,
.empty-card,
.plan-card {
  padding: 28rpx;
}

.summary-head,
.summary-metrics,
.top-actions,
.plan-head,
.plan-title-row,
.switch-row,
.field-grid,
.gift-toolbar,
.gift-head {
  display: flex;
  align-items: center;
}

.plan-head,
.switch-row,
.gift-toolbar,
.gift-head {
  justify-content: space-between;
}

.page-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  flex: 0 0 80rpx;
  border-radius: 24rpx;
  background: #FFF1D2;
  color: #26333D;
  font-size: 36rpx;
  font-weight: 800;
}

.summary-copy,
.plan-main {
  min-width: 0;
  flex: 1;
}

.summary-copy {
  margin-left: 20rpx;
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.loading-title,
.empty-title,
.empty-body,
.plan-title,
.plan-meta,
.plan-toggle,
.status-badge,
.field-title,
.field-hint,
.field-label,
.gift-title,
.delete-link,
.empty-inline {
  display: block;
}

.page-title {
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 800;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.35;
}

.summary-metrics {
  margin-top: 26rpx;
}

.metric-chip {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  height: 108rpx;
  margin-left: 14rpx;
  padding: 16rpx;
  border: 2rpx solid #F0E2D0;
  border-radius: 20rpx;
  background: #FBF6EE;
}

.metric-chip:first-child {
  margin-left: 0;
}

.metric-chip-primary {
  border-color: #F2C46F;
  background: #FFF3D8;
}

.metric-value {
  color: #2E5B73;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
}

.metric-label {
  margin-top: 10rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.top-actions {
  margin-top: 24rpx;
}

.top-actions .ghost-button,
.top-actions .save-button {
  flex: 1;
}

.top-actions .save-button {
  margin-left: 14rpx;
}

.loading-card,
.empty-card,
.plan-card {
  margin-top: 22rpx;
}

.loading-title,
.empty-body,
.plan-meta,
.field-hint,
.empty-inline {
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}

.empty-title {
  color: #26333D;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 800;
}

.empty-body,
.empty-card .ghost-button {
  margin-top: 16rpx;
}

.plan-title {
  color: #26333D;
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 800;
}

.status-badge {
  height: 40rpx;
  margin-left: 14rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #EEF3F4;
  color: #66727A;
  font-size: 22rpx;
  line-height: 40rpx;
}

.status-active {
  background: #E7F4ED;
  color: #347B59;
}

.plan-meta {
  margin-top: 8rpx;
}

.plan-toggle,
.delete-link {
  flex: 0 0 auto;
  margin-left: 18rpx;
  color: #2E5B73;
  font-size: 24rpx;
  font-weight: 700;
}

.plan-editor {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #F0E2D0;
}

.field-title,
.gift-title {
  color: #26333D;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.25;
}

.field-hint {
  margin-top: 6rpx;
}

.field-grid {
  margin-top: 20rpx;
}

.field-cell {
  flex: 1;
  min-width: 0;
}

.field-cell + .field-cell {
  margin-left: 14rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #756756;
  font-size: 22rpx;
}

.field-input,
.field-area {
  box-sizing: border-box;
  width: 100%;
  border: 2rpx solid #EAD9C5;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #26333D;
  font-size: 26rpx;
}

.field-input {
  height: 76rpx;
  padding: 0 20rpx;
}

.field-area {
  height: 120rpx;
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
}

.gift-toolbar {
  margin-top: 24rpx;
}

.gift-row {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #F4E6D6;
}

.gift-row .field-input {
  margin-top: 12rpx;
}

.empty-inline {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #FBF6EE;
}

.ghost-button,
.save-button,
.mini-button,
.danger-button {
  box-sizing: border-box;
  height: 76rpx;
  margin: 0;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 76rpx;
}

.ghost-button,
.mini-button {
  border: 2rpx solid #EAD9C5;
  background: #FFFDF8;
  color: #2E5B73;
}

.save-button {
  border: 0;
  background: #2E5B73;
  color: #FFFFFF;
}

.mini-button {
  width: 150rpx;
  height: 58rpx;
  font-size: 22rpx;
  line-height: 58rpx;
}

.danger-button {
  width: 100%;
  margin-top: 20rpx;
  border: 2rpx solid #F0C2B7;
  background: #FFF5F2;
  color: #B85D48;
}
