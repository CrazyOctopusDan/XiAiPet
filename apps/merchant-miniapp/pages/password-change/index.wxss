.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: #F4F6F8;
  color: #1F2A33;
}

.form-card {
  margin-bottom: 28rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #DDE4EA;
}

.title,
.subtitle,
.status {
  display: block;
}

.title {
  margin-bottom: 12rpx;
  font-size: 36rpx;
  font-weight: 600;
}

.subtitle,
.status {
  font-size: 28rpx;
  line-height: 1.6;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  margin-top: 20rpx;
  padding: 0 24rpx;
  border: 1rpx solid #C9D3DB;
  border-radius: 14rpx;
  background: #FFFFFF;
  font-size: 30rpx;
}

.status {
  margin-top: 20rpx;
  color: #B6463A;
}

.primary-button {
  border-radius: 16rpx;
  background: #2E5B73;
  color: #FFFFFF;
}
