.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 120rpx;
  box-sizing: border-box;
  background: #F8F1E8;
  color: #26333D;
}

.summary-card,
.form-card {
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.summary-card,
.form-card {
  padding: 28rpx;
}

.form-card {
  margin-top: 22rpx;
}

.summary-head,
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.page-mark {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #F3EBDD;
  color: #26333D;
  font-size: 36rpx;
  font-weight: 800;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 20rpx;
}

.page-title,
.page-subtitle,
.section-title,
.section-badge,
.status {
  display: block;
}

.page-title {
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 800;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.35;
}

.section-title {
  color: #26333D;
  font-size: 32rpx;
  line-height: 1.15;
  font-weight: 800;
}

.section-badge {
  flex: 0 0 auto;
  height: 44rpx;
  margin-left: 18rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #FFF4E4;
  color: #9A6B28;
  font-size: 22rpx;
  line-height: 44rpx;
}

.input {
  width: 100%;
  height: 72rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border: 2rpx solid #E8DAC8;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #26333D;
  font-size: 26rpx;
  box-sizing: border-box;
}

.status {
  min-height: 44rpx;
  margin-top: 20rpx;
  color: #B85D48;
  font-size: 24rpx;
  line-height: 1.45;
}

.primary-button {
  width: 100%;
  height: 72rpx;
  margin-top: 22rpx;
  border: none;
  border-radius: 18rpx;
  background: #2E5B73;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
}
