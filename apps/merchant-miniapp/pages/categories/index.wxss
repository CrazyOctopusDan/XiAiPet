.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 24rpx 160rpx;
  background: #F8F1E8;
  color: #26333D;
}

.summary-card,
.category-card,
.empty-card,
.loading-card,
.category-editor-panel {
  box-sizing: border-box;
  border: 2rpx solid #F0E2D0;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.summary-card,
.empty-card,
.loading-card,
.category-editor-panel {
  border-radius: 24rpx;
}

.summary-card,
.category-card,
.empty-card,
.loading-card,
.category-editor-panel {
  padding: 28rpx;
}

.summary-head,
.summary-metrics,
.section-head,
.editor-head,
.editor-actions,
.field-stack,
.list-head,
.category-head,
.category-tags,
.move-actions,
.card-actions {
  display: flex;
}

.summary-head,
.section-head,
.editor-head,
.editor-actions,
.list-head,
.category-head,
.category-tags,
.move-actions,
.card-actions {
  align-items: center;
}

.page-mark {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  border-radius: 26rpx;
  border: 2rpx solid #F3B56F;
  background: #FFF4E4;
  color: #2E5B73;
  font-size: 34rpx;
  font-weight: 800;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 22rpx;
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.section-title,
.section-note,
.category-name,
.tag,
.helper-copy,
.empty-title,
.empty-body {
  display: block;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.15;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}

.summary-metrics {
  margin-top: 24rpx;
}

.metric-chip {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #FBF6EE;
}

.metric-chip + .metric-chip {
  margin-left: 12rpx;
}

.metric-chip.accent {
  background: #FFF3E6;
}

.metric-value {
  color: #26333D;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.15;
}

.metric-label {
  margin-top: 6rpx;
  color: #756756;
  font-size: 20rpx;
  line-height: 1.25;
}

.card-list,
.empty-card,
.loading-card {
  margin-top: 20rpx;
}

.section-head,
.list-head {
  justify-content: space-between;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section-note {
  margin-top: 6rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.text-button,
.editor-close {
  box-sizing: border-box;
  width: 112rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 16rpx;
  background: #FBF6EE;
  color: #2E5B73;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 56rpx;
}

.field-stack {
  margin-top: 22rpx;
}

.field-input {
  box-sizing: border-box;
  min-width: 0;
  height: 72rpx;
  flex: 1;
  padding: 0 22rpx;
  border: 1rpx solid #E3D5C4;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #26333D;
  font-size: 26rpx;
  line-height: 72rpx;
}

.token-input {
  flex: 0 0 210rpx;
  margin-left: 12rpx;
}

.primary-button,
.secondary-button,
.ghost-button,
.danger-button,
.category-fab {
  box-sizing: border-box;
  min-width: 0;
  height: 72rpx;
  padding: 0 18rpx;
  border: none;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.primary-button {
  width: 100%;
  margin-top: 18rpx;
  background: #2E5B73;
  color: #FFFFFF;
}

.list-head {
  margin: 28rpx 4rpx 16rpx;
}

.list-head .section-note {
  margin-top: 0;
  margin-left: 20rpx;
}

.category-card {
  border-radius: 28rpx;
}

.category-card + .category-card {
  margin-top: 16rpx;
}

.icon-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 72rpx;
  border-radius: 22rpx;
  background: #FFF3E6;
  color: #8A5F35;
  font-size: 30rpx;
  font-weight: 800;
}

.category-meta {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.move-actions {
  flex: 0 0 auto;
  margin-left: 12rpx;
}

.move-button {
  box-sizing: border-box;
  width: 56rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 16rpx;
  background: #EEF5F7;
  color: #2E5B73;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 56rpx;
}

.move-button + .move-button {
  margin-left: 8rpx;
}

.move-button[disabled] {
  background: #F4EFE8;
  color: #B9AA98;
}

.category-name {
  color: #26333D;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.category-tags {
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.tag {
  margin-right: 10rpx;
  margin-bottom: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #FBF6EE;
  color: #697783;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
}

.tag.ready {
  background: #EAF6EF;
  color: #3F7A57;
}

.tag.warning {
  background: #FFF3E6;
  color: #8A5F35;
}

.helper-copy {
  margin-top: 14rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.4;
}

.card-actions {
  margin-top: 18rpx;
}

.secondary-button,
.ghost-button,
.danger-button {
  flex: 1;
  background: #FBF6EE;
}

.ghost-button,
.danger-button {
  margin-left: 12rpx;
}

.secondary-button,
.ghost-button {
  color: #2E5B73;
}

.danger-button {
  color: #B6463A;
}

.text-button::after,
.editor-close::after,
.primary-button::after,
.secondary-button::after,
.ghost-button::after,
.danger-button::after,
.move-button::after,
.category-fab::after {
  border: none;
}

.empty-card,
.loading-card {
  text-align: center;
}

.empty-title {
  color: #26333D;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.2;
}

.empty-body {
  margin-top: 10rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}

.category-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(84rpx + env(safe-area-inset-bottom));
  z-index: 20;
  width: 148rpx;
  border-radius: 999rpx;
  background: #2E5B73;
  color: #FFFFFF;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.22);
}

.category-editor-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  box-sizing: border-box;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(38, 51, 61, 0.34);
}

.category-editor-panel {
  width: 100%;
  border-radius: 28rpx;
  box-shadow: 0 28rpx 70rpx rgba(38, 51, 61, 0.2);
}

.editor-head {
  justify-content: space-between;
}

.editor-title-group {
  min-width: 0;
  flex: 1;
}

.editor-close {
  flex: 0 0 56rpx;
  width: 56rpx;
  margin-left: 16rpx;
  border-radius: 18rpx;
  color: #756756;
  font-size: 34rpx;
}

.editor-fields {
  align-items: center;
}

.editor-actions {
  margin-top: 18rpx;
}

.editor-cancel,
.editor-save {
  flex: 1;
}

.editor-save {
  margin-top: 0;
  margin-left: 12rpx;
}
