.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 24rpx 80rpx;
  background: #F8F1E8;
  color: #1F2A33;
}

.summary-card,
.editor-card,
.category-card,
.empty-card,
.loading-card {
  box-sizing: border-box;
  border: 1rpx solid #F0E2D0;
  background: #FFFFFF;
  box-shadow: 0 16rpx 38rpx rgba(80, 52, 22, 0.09);
}

.summary-card,
.editor-card,
.empty-card,
.loading-card {
  border-radius: 32rpx;
}

.summary-card,
.editor-card,
.category-card,
.empty-card,
.loading-card {
  padding: 28rpx;
}

.summary-head,
.summary-metrics,
.section-head,
.field-stack,
.list-head,
.category-head,
.category-tags,
.card-actions {
  display: flex;
}

.summary-head,
.section-head,
.list-head,
.category-head,
.category-tags,
.card-actions {
  align-items: center;
}

.page-mark {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  border-radius: 26rpx;
  border: 2rpx solid #F3B56F;
  background: #FFF4E4;
  color: #2E5B73;
  font-size: 34rpx;
  font-weight: 800;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 22rpx;
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.section-title,
.section-note,
.category-name,
.tag,
.helper-copy,
.empty-title,
.empty-body {
  display: block;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.15;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}

.summary-metrics {
  margin-top: 24rpx;
}

.metric-chip {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #F4F7F9;
}

.metric-chip + .metric-chip {
  margin-left: 12rpx;
}

.metric-chip.accent {
  background: #FFF3E6;
}

.metric-value {
  color: #1F2A33;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.15;
}

.metric-label {
  margin-top: 6rpx;
  color: #756756;
  font-size: 20rpx;
  line-height: 1.25;
}

.editor-card,
.card-list,
.empty-card,
.loading-card {
  margin-top: 20rpx;
}

.section-head,
.list-head {
  justify-content: space-between;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section-note {
  margin-top: 6rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.text-button {
  box-sizing: border-box;
  width: 112rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 16rpx;
  background: #F4F7F9;
  color: #2E5B73;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 56rpx;
}

.field-stack {
  margin-top: 22rpx;
}

.field-input {
  box-sizing: border-box;
  min-width: 0;
  height: 72rpx;
  flex: 1;
  padding: 0 22rpx;
  border: 1rpx solid #E3D5C4;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #1F2A33;
  font-size: 26rpx;
  line-height: 72rpx;
}

.token-input {
  flex: 0 0 210rpx;
  margin-left: 12rpx;
}

.primary-button,
.secondary-button,
.ghost-button,
.danger-button {
  box-sizing: border-box;
  min-width: 0;
  height: 72rpx;
  padding: 0 18rpx;
  border: none;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.primary-button {
  width: 100%;
  margin-top: 18rpx;
  background: #2E5B73;
  color: #FFFFFF;
}

.list-head {
  margin: 28rpx 4rpx 16rpx;
}

.list-head .section-note {
  margin-top: 0;
  margin-left: 20rpx;
}

.category-card {
  border-radius: 28rpx;
}

.category-card + .category-card {
  margin-top: 16rpx;
}

.icon-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 72rpx;
  border-radius: 22rpx;
  background: #FFF3E6;
  color: #8A5F35;
  font-size: 30rpx;
  font-weight: 800;
}

.category-meta {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.category-name {
  color: #1F2A33;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.category-tags {
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.tag {
  margin-right: 10rpx;
  margin-bottom: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #F4F7F9;
  color: #697783;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
}

.tag.ready {
  background: #EAF6EF;
  color: #3F7A57;
}

.tag.warning {
  background: #FFF3E6;
  color: #8A5F35;
}

.helper-copy {
  margin-top: 14rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.4;
}

.card-actions {
  margin-top: 18rpx;
}

.secondary-button,
.ghost-button,
.danger-button {
  flex: 1;
  background: #F4F7F9;
}

.ghost-button,
.danger-button {
  margin-left: 12rpx;
}

.secondary-button,
.ghost-button {
  color: #2E5B73;
}

.danger-button {
  color: #B6463A;
}

.text-button::after,
.primary-button::after,
.secondary-button::after,
.ghost-button::after,
.danger-button::after {
  border: none;
}

.empty-card,
.loading-card {
  text-align: center;
}

.empty-title {
  color: #1F2A33;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.2;
}

.empty-body {
  margin-top: 10rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}
