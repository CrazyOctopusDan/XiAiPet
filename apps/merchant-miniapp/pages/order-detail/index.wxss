.detail-page {
  min-height: 100vh;
  padding: 32rpx 24rpx calc(180rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #F6EFE4 0%, #FCFAF5 100%);
  color: #1F2A33;
}

.hero-card,
.content-card,
.empty-card,
.loading-card,
.drawer {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(46, 91, 115, 0.08);
}

.hero-card,
.content-card,
.empty-card,
.loading-card {
  padding: 28rpx;
}

.hero-head,
.status-wrap,
.meta-row,
.timeline-head,
.product-row,
.drawer-actions,
.option-list {
  display: flex;
  align-items: center;
}

.hero-head,
.meta-row,
.timeline-head,
.product-row,
.drawer-actions {
  justify-content: space-between;
}

.status-wrap,
.option-list {
  gap: 12rpx;
}

.page-title,
.page-subtitle,
.status-pill,
.payment-badge,
.section-title,
.meta-label,
.meta-value,
.timeline-label,
.timeline-time,
.timeline-meta,
.timeline-note,
.product-name,
.product-meta,
.product-total,
.remark-copy,
.drawer-title,
.drawer-subtitle,
.drawer-label,
.audit-copy,
.empty-title,
.empty-body,
.loading-title,
.loading-body,
.total-value {
  display: block;
}

.page-title {
  font-size: 46rpx;
  font-weight: 700;
}

.page-subtitle,
.meta-label,
.timeline-time,
.timeline-meta,
.product-meta,
.remark-copy,
.drawer-subtitle,
.audit-copy,
.empty-body,
.loading-body {
  font-size: 22rpx;
  color: #7E8B95;
}

.page-subtitle {
  margin-top: 12rpx;
}

.status-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(230, 197, 107, 0.28);
  color: #725625;
  font-size: 24rpx;
  font-weight: 700;
}

.payment-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(182, 70, 58, 0.1);
  color: #B6463A;
  font-size: 20rpx;
  font-weight: 600;
}

.content-card,
.empty-card,
.loading-card {
  margin-top: 24rpx;
}

.section-title,
.empty-title,
.loading-title,
.drawer-title {
  font-size: 32rpx;
  font-weight: 700;
}

.meta-row,
.product-row {
  gap: 16rpx;
  margin-top: 18rpx;
}

.meta-value {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  color: #31414D;
}

.timeline-item {
  position: relative;
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
}

.timeline-dot {
  width: 18rpx;
  height: 18rpx;
  margin-top: 10rpx;
  border-radius: 9rpx;
  background: #2E5B73;
  flex-shrink: 0;
}

.timeline-content {
  flex: 1;
  padding-bottom: 8rpx;
  border-bottom: 2rpx solid rgba(46, 91, 115, 0.08);
}

.timeline-label,
.product-name {
  font-size: 26rpx;
  font-weight: 600;
}

.timeline-note {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #495A66;
}

.product-total,
.total-value {
  font-size: 30rpx;
  font-weight: 700;
}

.total-row {
  margin-top: 22rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(252, 250, 245, 0.94);
  backdrop-filter: blur(12rpx);
}

.action-button,
.primary-button,
.secondary-button {
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-button,
.primary-button {
  background: #2E5B73;
  color: #FFFFFF;
}

.secondary-button {
  background: #EEF2F5;
  color: #4C5A65;
}

.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 28, 36, 0.28);
}

.drawer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
  padding: 28rpx;
}

.drawer-subtitle {
  margin-top: 10rpx;
  line-height: 1.6;
}

.drawer-section {
  margin-top: 24rpx;
}

.drawer-label {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #31414D;
}

.option-list {
  flex-wrap: wrap;
}

.option-pill {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #EEF2F5;
  color: #5D6B75;
  font-size: 24rpx;
}

.option-pill.active {
  background: rgba(46, 91, 115, 0.14);
  color: #2E5B73;
  font-weight: 600;
}

.reason-input {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #F4F6F8;
  font-size: 26rpx;
  box-sizing: border-box;
}

.audit-card {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #F8FBFC;
}

.audit-copy + .audit-copy {
  margin-top: 8rpx;
}

.drawer-actions {
  gap: 16rpx;
  margin-top: 28rpx;
}

.drawer-actions button {
  flex: 1;
}
