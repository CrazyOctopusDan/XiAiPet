.detail-page {
  min-height: 100vh;
  padding: 28rpx 24rpx calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #F8F1E8;
  color: #26333D;
}

.summary-card,
.content-card,
.empty-card,
.loading-card,
.drawer {
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.summary-card,
.content-card,
.empty-card,
.loading-card {
  padding: 28rpx;
}

.content-card,
.empty-card,
.loading-card {
  margin-top: 22rpx;
}

.summary-head,
.status-wrap,
.summary-metrics,
.meta-row,
.section-head,
.timeline-head,
.product-row,
.drawer-actions,
.inline-actions,
.option-list {
  display: flex;
  align-items: center;
}

.summary-head,
.meta-row,
.section-head,
.timeline-head,
.product-row,
.drawer-actions {
  justify-content: space-between;
}

.page-mark {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #F3EBDD;
  color: #26333D;
  font-size: 36rpx;
  font-weight: 800;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 20rpx;
}

.page-title,
.page-subtitle,
.status-pill,
.payment-badge,
.metric-value,
.metric-label,
.section-title,
.meta-label,
.meta-value,
.timeline-label,
.timeline-time,
.timeline-meta,
.timeline-note,
.product-name,
.product-meta,
.product-total,
.remark-copy,
.print-status,
.drawer-title,
.drawer-subtitle,
.drawer-label,
.audit-copy,
.empty-title,
.empty-body,
.loading-title,
.loading-body,
.total-value {
  display: block;
}

.page-title {
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 800;
}

.page-subtitle,
.meta-label,
.print-status,
.timeline-time,
.timeline-meta,
.product-meta,
.remark-copy,
.drawer-subtitle,
.audit-copy,
.empty-body,
.loading-body {
  color: #756756;
  font-size: 22rpx;
  line-height: 1.35;
}

.page-subtitle {
  margin-top: 8rpx;
}

.status-wrap {
  flex: 0 0 auto;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 18rpx;
}

.status-pill,
.payment-badge {
  min-width: 88rpx;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 44rpx;
  text-align: center;
  box-sizing: border-box;
}

.status-pill {
  background: #FFF4E4;
  color: #9A6B28;
  font-weight: 800;
}

.payment-badge {
  margin-top: 8rpx;
  background: #FFECE5;
  color: #B85D48;
  font-weight: 700;
}

.summary-metrics {
  margin-top: 26rpx;
}

.metric-chip {
  flex: 1;
  min-width: 0;
  height: 112rpx;
  margin-left: 14rpx;
  padding: 16rpx;
  border: 2rpx solid #F0E2D0;
  border-radius: 20rpx;
  background: #FBF6EE;
  box-sizing: border-box;
}

.metric-chip:first-child {
  margin-left: 0;
}

.metric-chip-primary {
  border-color: #F3B56F;
  background: #FFF4E4;
}

.metric-value {
  color: #2E5B73;
  font-size: 26rpx;
  line-height: 1.2;
  font-weight: 800;
}

.metric-label {
  margin-top: 10rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.section-title,
.empty-title,
.loading-title,
.drawer-title {
  color: #26333D;
  font-size: 32rpx;
  line-height: 1.15;
  font-weight: 800;
}

.meta-row,
.product-row {
  margin-top: 18rpx;
}

.meta-label {
  flex: 0 0 auto;
  width: 150rpx;
}

.meta-value {
  min-width: 0;
  flex: 1;
  color: #26333D;
  font-size: 24rpx;
  line-height: 1.35;
  text-align: right;
}

.timeline-item {
  position: relative;
  display: flex;
  margin-top: 20rpx;
}

.timeline-dot {
  flex: 0 0 auto;
  width: 18rpx;
  height: 18rpx;
  margin-top: 10rpx;
  border-radius: 9rpx;
  background: #2E5B73;
}

.timeline-content {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #F0E2D0;
}

.timeline-label,
.product-name,
.pet-detail-name {
  color: #26333D;
  font-size: 26rpx;
  font-weight: 800;
}

.pet-detail-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 2rpx solid #F0E2D0;
  border-radius: 20rpx;
  background: #FBF6EE;
}

.pet-detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.pet-detail-meta,
.pet-allergy {
  display: block;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.35;
}

.pet-detail-meta {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
  text-align: right;
}

.pet-allergy {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #FFFDF8;
}

.pet-allergy.warning {
  color: #9A4A2F;
  background: #FFF0E8;
}

.timeline-note {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.35;
}

.product-copy {
  min-width: 0;
  flex: 1;
}

.product-total,
.total-value {
  flex: 0 0 auto;
  margin-left: 18rpx;
  color: #2E5B73;
  font-size: 30rpx;
  font-weight: 800;
}

.inline-actions {
  margin-top: 24rpx;
}

.compact-button {
  flex: 1;
  height: 72rpx;
  margin-left: 14rpx;
  line-height: 72rpx;
}

.compact-button:first-child {
  margin-left: 0;
}

.total-row {
  margin-top: 22rpx;
}

.remark-copy {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding: 16rpx;
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.12);
}

.action-button,
.primary-button,
.secondary-button {
  height: 72rpx;
  border: none;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.action-button,
.primary-button {
  background: #2E5B73;
  color: #FFFFFF;
}

.secondary-button {
  background: #EEF3F4;
  color: #2E5B73;
}

.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 28, 36, 0.28);
}

.drawer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
  padding: 28rpx;
}

.drawer-subtitle {
  margin-top: 10rpx;
}

.drawer-section {
  margin-top: 24rpx;
}

.drawer-label {
  margin-bottom: 14rpx;
  color: #26333D;
  font-size: 24rpx;
  font-weight: 800;
}

.option-list {
  flex-wrap: wrap;
}

.option-pill {
  min-height: 56rpx;
  margin-top: 12rpx;
  margin-right: 12rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #FBF6EE;
  color: #756756;
  font-size: 24rpx;
  line-height: 56rpx;
}

.option-pill.active {
  background: #FFF4E4;
  color: #2E5B73;
  font-weight: 800;
}

.reason-input {
  width: 100%;
  height: 176rpx;
  padding: 18rpx 22rpx;
  border: 2rpx solid #E8DAC8;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #26333D;
  font-size: 26rpx;
  line-height: 1.45;
  box-sizing: border-box;
}

.audit-card {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #FBF6EE;
}

.audit-copy + .audit-copy {
  margin-top: 8rpx;
}

.drawer-actions {
  margin-top: 28rpx;
}

.drawer-actions button {
  flex: 1;
  margin-left: 14rpx;
}

.drawer-actions button:first-child {
  margin-left: 0;
}

.gift-section {
  border-color: #F3B56F;
  background: #FFF9F0;
}

.gift-count {
  display: block;
  color: #B85D48;
  font-size: 22rpx;
  font-weight: 800;
}

.gift-reminder {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #FFECE5;
  color: #9A4F3D;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.5;
}

.gift-detail-card {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 2rpx solid #F0D2B3;
  border-radius: 18rpx;
  background: #FFFDF8;
}

.gift-detail-head {
  display: flex;
  align-items: center;
}

.gift-mark {
  box-sizing: border-box;
  flex: 0 0 auto;
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background: #B85D48;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 42rpx;
  text-align: center;
}

.gift-name {
  display: block;
  margin-left: 14rpx;
  color: #26333D;
  font-size: 26rpx;
  font-weight: 800;
}

.gift-description {
  display: block;
  margin-top: 12rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.4;
}
