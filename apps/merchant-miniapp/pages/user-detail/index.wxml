<view class="page">
  <view class="empty-card" wx:if="{{!detail}}">
    <text class="page-title">未找到用户</text>
  </view>

  <view wx:else>
    <view class="summary-card">
      <view class="summary-head">
        <image class="avatar" src="{{detail.avatarUrl}}" mode="aspectFill"></image>
        <view class="summary-copy">
          <text class="page-title">{{detail.nickname}}</text>
          <text class="page-subtitle">{{detail.contactPhoneMasked}}</text>
        </view>
      </view>

      <view class="summary-metrics">
        <view class="metric-chip metric-chip-primary">
          <text class="metric-value">{{detail.currentBalanceLabel}}</text>
          <text class="metric-label">当前余额</text>
        </view>
        <view class="metric-chip">
          <text class="metric-value">{{detail.membershipTierLabel}}</text>
          <text class="metric-label">会员等级</text>
        </view>
      </view>
    </view>

    <view class="history-card">
      <view class="section-head">
        <text class="section-title">最近操作</text>
        <text class="section-badge">审计</text>
      </view>
      <text class="history-title">{{detail.latestOperationTitle}}</text>
      <text class="page-subtitle">{{detail.latestOperationNote}}</text>
      <text class="page-subtitle">{{detail.latestOperationMeta}}</text>
    </view>
  </view>

  <view class="action-bar" wx:if="{{detail && canAdjustBalance}}">
    <button class="action-button" bindtap="handleOpenDrawer">调整余额</button>
  </view>

  <view class="drawer-mask" wx:if="{{drawerOpen}}" bindtap="handleCloseDrawer"></view>
  <view class="drawer" wx:if="{{drawerOpen}}">
    <text class="section-title">余额调整</text>
    <view class="pill-row">
      <view class="pill {{action === 'add' ? 'active' : ''}}" data-action="add" bindtap="handleActionTap">增加</view>
      <view class="pill {{action === 'deduct' ? 'active' : ''}}" data-action="deduct" bindtap="handleActionTap">扣减</view>
      <view class="pill {{action === 'set' ? 'active' : ''}}" data-action="set" bindtap="handleActionTap">指定余额</view>
    </view>

    <input class="field-input" type="number" placeholder="{{action === 'set' ? '目标余额' : '调整金额'}}" value="{{amountText}}" bindinput="handleAmountInput" />

    <view class="pill-row">
      <view class="pill {{reasonType === '充值' ? 'active' : ''}}" data-reason="充值" bindtap="handleReasonTap">充值</view>
      <view class="pill {{reasonType === '补偿' ? 'active' : ''}}" data-reason="补偿" bindtap="handleReasonTap">补偿</view>
      <view class="pill {{reasonType === '人工纠错' ? 'active' : ''}}" data-reason="人工纠错" bindtap="handleReasonTap">人工纠错</view>
      <view class="pill {{reasonType === '线下收款' ? 'active' : ''}}" data-reason="线下收款" bindtap="handleReasonTap">线下收款</view>
      <view class="pill {{reasonType === '其他' ? 'active' : ''}}" data-reason="其他" bindtap="handleReasonTap">其他</view>
    </view>

    <textarea class="field-area" placeholder="备注" value="{{note}}" bindinput="handleNoteInput"></textarea>
    <text class="page-subtitle" wx:if="{{action === 'deduct' || action === 'set'}}">调整后余额 {{resultingBalanceLabel}}</text>
    <text class="error-copy" wx:if="{{disableSubmitReason}}">{{disableSubmitReason}}</text>
    <button class="action-button" loading="{{submitting}}" disabled="{{!!disableSubmitReason}}" bindtap="handleConfirmAdjust">确认调整</button>
  </view>
</view>
