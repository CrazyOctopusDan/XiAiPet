.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 180rpx;
  background: linear-gradient(180deg, #F6EFE4 0%, #FCFAF5 100%);
  color: #1F2A33;
}

.hero-card,
.balance-card,
.history-card,
.empty-card,
.drawer {
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(46, 91, 115, 0.08);
}

.balance-card,
.history-card {
  margin-top: 24rpx;
}

.hero-head,
.pill-row {
  display: flex;
}

.hero-head {
  gap: 18rpx;
  align-items: center;
}

.pill-row {
  gap: 14rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #EEF2F5;
}

.page-title,
.page-subtitle,
.balance-label,
.balance-value,
.section-title,
.history-title,
.error-copy {
  display: block;
}

.page-title,
.section-title,
.history-title {
  font-size: 34rpx;
  font-weight: 700;
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7E8B95;
}

.balance-label {
  font-size: 22rpx;
  color: #7E8B95;
}

.balance-value {
  margin-top: 12rpx;
  font-size: 56rpx;
  font-weight: 700;
  color: #2E5B73;
}

.action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.action-button {
  width: 100%;
  border: none;
  border-radius: 999rpx;
  background: #2E5B73;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 28, 36, 0.28);
}

.drawer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.pill {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #EEF2F5;
  color: #5D6B75;
  font-size: 24rpx;
}

.pill.active {
  background: rgba(46, 91, 115, 0.14);
  color: #2E5B73;
  font-weight: 600;
}

.field-input,
.field-area {
  width: 100%;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #F4F6F8;
  font-size: 28rpx;
  box-sizing: border-box;
}

.field-input {
  min-height: 88rpx;
}

.field-area {
  min-height: 160rpx;
  padding-top: 20rpx;
}

.error-copy {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #B6463A;
}
