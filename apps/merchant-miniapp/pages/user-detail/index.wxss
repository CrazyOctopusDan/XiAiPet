.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 180rpx;
  box-sizing: border-box;
  background: #F8F1E8;
  color: #26333D;
}

.summary-card,
.history-card,
.empty-card,
.drawer {
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.summary-card,
.history-card,
.empty-card,
.drawer {
  padding: 28rpx;
}

.history-card {
  margin-top: 22rpx;
}

.summary-head,
.summary-metrics,
.section-head,
.pill-row {
  display: flex;
  align-items: center;
}

.section-head {
  justify-content: space-between;
}

.avatar {
  flex: 0 0 auto;
  width: 112rpx;
  height: 112rpx;
  border: 4rpx solid #F3EBDD;
  border-radius: 56rpx;
  background: #FBF6EE;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 20rpx;
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.section-title,
.section-badge,
.history-title,
.error-copy {
  display: block;
}

.page-title,
.section-title,
.history-title {
  color: #26333D;
  font-size: 34rpx;
  line-height: 1.15;
  font-weight: 800;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.35;
}

.summary-metrics {
  margin-top: 26rpx;
}

.metric-chip {
  flex: 1;
  min-width: 0;
  height: 112rpx;
  margin-left: 14rpx;
  padding: 16rpx;
  border: 2rpx solid #F0E2D0;
  border-radius: 20rpx;
  background: #FBF6EE;
  box-sizing: border-box;
}

.metric-chip:first-child {
  margin-left: 0;
}

.metric-chip-primary {
  border-color: #F3B56F;
  background: #FFF4E4;
}

.metric-value {
  color: #2E5B73;
  font-size: 32rpx;
  line-height: 1.1;
  font-weight: 800;
}

.metric-label {
  margin-top: 10rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.section-badge {
  flex: 0 0 auto;
  height: 44rpx;
  margin-left: 18rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #FFF4E4;
  color: #9A6B28;
  font-size: 22rpx;
  line-height: 44rpx;
}

.history-title {
  margin-top: 20rpx;
  font-size: 30rpx;
}

.action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding: 16rpx;
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.12);
}

.action-button {
  width: 100%;
  height: 72rpx;
  border: none;
  border-radius: 18rpx;
  background: #2E5B73;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 28, 36, 0.28);
}

.drawer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

.pill-row {
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.pill {
  min-height: 56rpx;
  margin-top: 12rpx;
  margin-right: 12rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #FBF6EE;
  color: #756756;
  font-size: 24rpx;
  line-height: 56rpx;
}

.pill.active {
  background: #FFF4E4;
  color: #2E5B73;
  font-weight: 800;
}

.field-input,
.field-area {
  width: 100%;
  margin-top: 18rpx;
  border: 2rpx solid #E8DAC8;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #26333D;
  font-size: 26rpx;
  box-sizing: border-box;
}

.field-input {
  height: 72rpx;
  padding: 0 22rpx;
}

.field-area {
  height: 164rpx;
  padding: 18rpx 22rpx;
  line-height: 1.45;
}

.error-copy {
  margin-top: 14rpx;
  color: #B85D48;
  font-size: 22rpx;
  line-height: 1.35;
}

.drawer > .action-button {
  margin-top: 20rpx;
}
