.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 180rpx;
  box-sizing: border-box;
  background: #F8F1E8;
  color: #26333D;
}

.summary-card,
.detail-card,
.empty-card,
.drawer {
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.summary-card,
.detail-card,
.empty-card,
.drawer {
  padding: 28rpx;
}

.detail-card {
  margin-top: 22rpx;
}

.summary-head,
.summary-metrics,
.section-head,
.detail-tabs,
.detail-tab,
.basic-row,
.address-head,
.pet-card-head,
.pill-row {
  display: flex;
  align-items: center;
}

.section-head {
  justify-content: space-between;
}

.avatar {
  flex: 0 0 auto;
  width: 112rpx;
  height: 112rpx;
  border: 4rpx solid #F3EBDD;
  border-radius: 56rpx;
  background: #FBF6EE;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 20rpx;
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.section-title,
.section-badge,
.history-title,
.basic-label,
.basic-value,
.address-default,
.ledger-amount,
.error-copy {
  display: block;
}

.page-title,
.section-title,
.history-title {
  color: #26333D;
  font-size: 34rpx;
  line-height: 1.15;
  font-weight: 800;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.35;
}

.summary-metrics {
  margin-top: 26rpx;
}

.metric-chip {
  flex: 1;
  min-width: 0;
  height: 112rpx;
  margin-left: 14rpx;
  padding: 16rpx;
  border: 2rpx solid #F0E2D0;
  border-radius: 20rpx;
  background: #FBF6EE;
  box-sizing: border-box;
}

.metric-chip:first-child {
  margin-left: 0;
}

.metric-chip-primary {
  border-color: #F3B56F;
  background: #FFF4E4;
}

.metric-value {
  color: #2E5B73;
  font-size: 32rpx;
  line-height: 1.1;
  font-weight: 800;
}

.metric-label {
  margin-top: 10rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.section-badge {
  flex: 0 0 auto;
  height: 44rpx;
  margin-left: 18rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #FFF4E4;
  color: #9A6B28;
  font-size: 22rpx;
  line-height: 44rpx;
}

.detail-tabs {
  gap: 10rpx;
  padding: 8rpx;
  border-radius: 20rpx;
  background: #F8F1E8;
}

.detail-tab {
  flex: 1;
  min-width: 0;
  height: 70rpx;
  justify-content: center;
  border-radius: 16rpx;
  color: #756756;
}

.detail-tab.active {
  background: #FFFDF8;
  color: #2E5B73;
  box-shadow: 0 8rpx 18rpx rgba(46, 91, 115, 0.08);
}

.detail-tab-label {
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.1;
}

.detail-tab-count {
  min-width: 34rpx;
  height: 34rpx;
  margin-left: 8rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(46, 91, 115, 0.1);
  color: #2E5B73;
  font-size: 20rpx;
  line-height: 34rpx;
  text-align: center;
}

.detail-panel {
  margin-top: 24rpx;
}

.basic-row,
.address-row {
  padding: 18rpx 0;
  border-top: 2rpx solid #F1E5D6;
}

.basic-row:first-of-type,
.address-row:first-of-type {
  border-top: none;
}

.basic-row {
  justify-content: space-between;
}

.basic-label {
  flex: 0 0 auto;
  color: #756756;
  font-size: 24rpx;
}

.basic-value {
  min-width: 0;
  flex: 1;
  margin-left: 20rpx;
  color: #26333D;
  font-size: 26rpx;
  font-weight: 800;
  text-align: right;
  word-break: break-all;
}

.address-head {
  justify-content: space-between;
}

.pet-section {
  margin-top: 10rpx;
  border-top: 2rpx solid #F1E5D6;
}

.pet-card {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 2rpx solid #F0E2D0;
  border-radius: 16rpx;
  background: #FBF6EE;
}

.pet-card-head {
  justify-content: space-between;
}

.pet-name {
  min-width: 0;
  flex: 1;
  color: #26333D;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
  word-break: break-all;
}

.pet-meta {
  flex: 0 0 auto;
  margin-left: 18rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.pet-allergy {
  display: block;
  margin-top: 12rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.35;
  word-break: break-all;
}

.pet-allergy.warning {
  color: #9A4E19;
  font-weight: 800;
}

.address-head .history-title {
  margin-top: 0;
}

.address-default {
  flex: 0 0 auto;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #E9F5EE;
  color: #2F7D55;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.empty-section {
  padding: 20rpx 0;
}

.history-title {
  margin-top: 20rpx;
  font-size: 30rpx;
}

.ledger-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-top: 18rpx;
  padding: 18rpx 0;
  border-top: 2rpx solid #F1E5D6;
}

.ledger-row:first-child {
  border-top: none;
}

.ledger-main {
  min-width: 0;
  flex: 1;
  padding-right: 20rpx;
}

.ledger-main .history-title {
  margin-top: 0;
}

.ledger-side {
  flex: 0 0 auto;
  min-width: 170rpx;
  text-align: right;
}

.ledger-amount {
  color: #756756;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.15;
}

.ledger-amount.income {
  color: #2F7D55;
}

.ledger-amount.expense {
  color: #B85D48;
}

.load-more-row {
  padding: 20rpx 0 4rpx;
  text-align: center;
}

.action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding: 16rpx;
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.12);
}

.action-button {
  width: 100%;
  height: 72rpx;
  border: none;
  border-radius: 18rpx;
  background: #2E5B73;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 28, 36, 0.28);
}

.drawer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

.pill-row {
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.pill {
  min-height: 56rpx;
  margin-top: 12rpx;
  margin-right: 12rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #FBF6EE;
  color: #756756;
  font-size: 24rpx;
  line-height: 56rpx;
}

.pill.active {
  background: #FFF4E4;
  color: #2E5B73;
  font-weight: 800;
}

.field-input,
.field-area {
  width: 100%;
  margin-top: 18rpx;
  border: 2rpx solid #E8DAC8;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #26333D;
  font-size: 26rpx;
  box-sizing: border-box;
}

.field-input {
  height: 72rpx;
  padding: 0 22rpx;
}

.field-area {
  height: 164rpx;
  padding: 18rpx 22rpx;
  line-height: 1.45;
}

.error-copy {
  margin-top: 14rpx;
  color: #B85D48;
  font-size: 22rpx;
  line-height: 1.35;
}

.drawer > .action-button {
  margin-top: 20rpx;
}
