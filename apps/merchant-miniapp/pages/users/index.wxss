.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 24rpx 80rpx;
  background: #F8F1E8;
  color: #1F2A33;
}

.summary-card,
.toolbar-card,
.user-card,
.empty-card {
  box-sizing: border-box;
  border: 1rpx solid #F0E2D0;
  background: #FFFFFF;
  box-shadow: 0 16rpx 38rpx rgba(80, 52, 22, 0.09);
}

.summary-card,
.toolbar-card,
.empty-card {
  padding: 28rpx;
  border-radius: 32rpx;
}

.summary-head,
.summary-metrics,
.toolbar-head,
.field-pills,
.search-row,
.user-card,
.user-head,
.user-meta,
.balance-row {
  display: flex;
}

.summary-head,
.toolbar-head,
.field-pills,
.search-row,
.user-card,
.user-head,
.user-meta,
.balance-row {
  align-items: center;
}

.page-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #F3B56F 0%, #E98F78 58%, #2E5B73 100%);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 800;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 22rpx;
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.section-title,
.section-note,
.pill,
.clear-link,
.user-name,
.tier-badge,
.meta-chip,
.balance-label,
.user-balance,
.empty-title,
.empty-body {
  display: block;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.15;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}

.summary-metrics {
  margin-top: 24rpx;
}

.metric-chip {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #F4F7F9;
}

.metric-chip + .metric-chip {
  margin-left: 12rpx;
}

.metric-chip.accent {
  background: #FFF3E6;
}

.metric-value {
  color: #1F2A33;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.15;
}

.metric-value.balance {
  font-size: 24rpx;
}

.metric-label {
  margin-top: 6rpx;
  color: #756756;
  font-size: 20rpx;
  line-height: 1.25;
}

.toolbar-card,
.card-list,
.empty-card {
  margin-top: 20rpx;
}

.toolbar-head {
  justify-content: space-between;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section-note {
  margin-top: 6rpx;
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.field-pills {
  flex: 0 0 auto;
  margin-left: 16rpx;
}

.pill {
  box-sizing: border-box;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #F4F7F9;
  color: #697783;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 56rpx;
}

.pill + .pill {
  margin-left: 10rpx;
}

.pill.active {
  background: #FFF3E6;
  color: #8A5F35;
}

.search-row {
  margin-top: 22rpx;
}

.field-input {
  box-sizing: border-box;
  min-width: 0;
  height: 72rpx;
  flex: 1;
  padding: 0 22rpx;
  border: 1rpx solid #E3D5C4;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #1F2A33;
  font-size: 26rpx;
  line-height: 72rpx;
}

.search-button {
  box-sizing: border-box;
  width: 132rpx;
  height: 72rpx;
  margin-left: 14rpx;
  padding: 0;
  border: none;
  border-radius: 18rpx;
  background: #2E5B73;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.clear-link {
  margin-top: 16rpx;
  color: #2E5B73;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.3;
}

.user-card {
  padding: 20rpx;
  border-radius: 28rpx;
}

.user-card + .user-card {
  margin-top: 16rpx;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  flex: 0 0 104rpx;
  border-radius: 28rpx;
  background: #F4F7F9;
}

.user-body {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.user-head {
  justify-content: space-between;
}

.user-name {
  min-width: 0;
  flex: 1;
  color: #1F2A33;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.tier-badge {
  flex: 0 0 auto;
  margin-left: 12rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: #FFF3E6;
  color: #8A5F35;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

.user-meta {
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.meta-chip {
  margin-right: 10rpx;
  margin-bottom: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #F4F7F9;
  color: #697783;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
}

.meta-chip.audit {
  background: #EAF6EF;
  color: #3F7A57;
}

.balance-row {
  justify-content: space-between;
  margin-top: 8rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F0E2D0;
}

.balance-label {
  color: #756756;
  font-size: 22rpx;
  line-height: 1.2;
}

.user-balance {
  color: #2E5B73;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.empty-card {
  text-align: center;
}

.empty-title {
  color: #1F2A33;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.2;
}

.empty-body {
  margin-top: 10rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}

.search-button::after {
  border: none;
}
