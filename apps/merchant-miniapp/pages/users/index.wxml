<view class="page">
  <view class="hero-card">
    <text class="page-title">用户管理</text>
    <text class="page-subtitle">搜索会员并查看当前余额。</text>
  </view>

  <view class="toolbar-card">
    <view class="pill-row">
      <view class="pill {{searchField === 'phone' ? 'active' : ''}}" data-field="phone" bindtap="handleSearchFieldTap">手机号搜索</view>
      <view class="pill {{searchField === 'name' ? 'active' : ''}}" data-field="name" bindtap="handleSearchFieldTap">昵称搜索</view>
    </view>
    <input class="field-input" placeholder="搜索" value="{{draftQuery}}" bindinput="handleQueryInput" confirm-type="search" bindconfirm="handleSearchSubmit" />
    <button class="search-button" bindtap="handleSearchSubmit">搜索</button>
  </view>

  <view class="empty-card" wx:if="{{isEmpty && !loading}}">
    <text class="page-title">暂无搜索结果</text>
    <text class="page-subtitle">输入手机号或昵称后点搜索。</text>
  </view>

  <view class="card-list" wx:elif="{{!loading}}">
    <view class="user-card" wx:for="{{cards}}" wx:key="openid" data-openid="{{item.openid}}" bindtap="handleOpenUser">
      <image class="avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-body">
        <text class="user-name">{{item.nickname}}</text>
        <text class="user-copy">{{item.contactPhoneMasked}}</text>
        <text class="user-copy">会员等级：{{item.membershipTierLabel}}</text>
        <text class="user-balance">当前余额 {{item.currentBalanceLabel}}</text>
      </view>
    </view>
  </view>

  <view class="empty-card" wx:else>
    <text class="page-title">正在搜索用户</text>
  </view>
</view>
