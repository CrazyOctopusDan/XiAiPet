.access-page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: #F4F6F8;
  color: #1F2A33;
}

.access-card {
  margin-bottom: 28rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #DDE4EA;
}

.heading {
  display: block;
  margin-bottom: 12rpx;
  font-size: 36rpx;
  font-weight: 600;
}

.body,
.status,
.meta-line {
  font-size: 28rpx;
  line-height: 1.6;
}

.status {
  display: block;
  margin-top: 20rpx;
}

.status.allowed {
  color: #2E5B73;
}

.status.denied {
  color: #B6463A;
}

.primary-cta {
  border-radius: 16rpx;
  background: #2E5B73;
  color: #FFFFFF;
}

.meta-line {
  margin-top: 24rpx;
}
