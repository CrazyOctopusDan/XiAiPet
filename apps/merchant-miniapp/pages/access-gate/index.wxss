.access-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 24rpx 72rpx;
  background: #F8F1E8;
  color: #26333D;
}

.brand-card,
.login-card {
  box-sizing: border-box;
  width: 100%;
  border: 2rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: #FFFDF8;
  box-shadow: 0 16rpx 36rpx rgba(46, 91, 115, 0.07);
}

.brand-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.brand-mark {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  flex: 0 0 88rpx;
  border: 2rpx solid #F3B56F;
  border-radius: 24rpx;
  background: #FFF4E4;
  color: #2E5B73;
  line-height: 1;
}

.brand-mark-main {
  font-size: 36rpx;
  font-weight: 800;
}

.brand-mark-sub {
  margin-top: 6rpx;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.brand-copy {
  min-width: 0;
  flex: 1;
  margin-left: 24rpx;
}

.brand-title,
.brand-subtitle,
.login-title,
.login-subtitle,
.field-label,
.status-text,
.role-pill {
  display: block;
}

.brand-title {
  color: #26333D;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.15;
}

.brand-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #756756;
}

.login-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.login-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.login-copy {
  min-width: 0;
  flex: 1;
}

.login-title {
  color: #26333D;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.login-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.35;
  color: #756756;
}

.role-pill {
  flex: 0 0 auto;
  margin-left: 20rpx;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #FFF4E4;
  color: #9A6B28;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.field-group {
  margin-top: 22rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #6A5B4B;
  font-size: 24rpx;
  font-weight: 600;
}

.login-input {
  box-sizing: border-box;
  width: 100%;
  height: 72rpx;
  padding: 0 22rpx;
  border: 2rpx solid #E8DAC8;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #26333D;
  font-size: 26rpx;
}

.input-placeholder {
  color: #9B8A78;
}

.status-strip {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  min-height: 72rpx;
  margin-top: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 18rpx;
  background: #FBF6EE;
  color: #756756;
  overflow: hidden;
}

.status-strip.allowed {
  background: #E9F2F5;
  color: #2E5B73;
}

.status-strip.denied {
  background: #FFF1EF;
  color: #9B342D;
}

.status-text {
  font-size: 24rpx;
  line-height: 1.45;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.primary-cta {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 72rpx;
  margin-top: 24rpx;
  padding: 0;
  border: none;
  border-radius: 18rpx;
  background: #2E5B73;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.primary-cta::after {
  border: none;
}
