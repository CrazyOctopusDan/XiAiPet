.orders-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 24rpx 80rpx;
  background: #F8F1E8;
  color: #1F2A33;
}

.summary-card,
.toolbar-card,
.group-card,
.empty-card,
.loading-card {
  box-sizing: border-box;
  border: 1rpx solid #F0E2D0;
  background: #FFFFFF;
  box-shadow: 0 16rpx 38rpx rgba(80, 52, 22, 0.09);
}

.summary-card,
.toolbar-card,
.empty-card,
.loading-card {
  border-radius: 32rpx;
}

.summary-card,
.toolbar-card,
.group-card,
.empty-card,
.loading-card {
  padding: 28rpx;
}

.summary-head,
.summary-metrics,
.search-row,
.filter-row,
.group-head,
.order-head,
.order-status-wrap,
.order-meta-grid,
.order-foot {
  display: flex;
}

.summary-head,
.search-row,
.filter-row,
.group-head,
.order-head,
.order-status-wrap,
.order-foot {
  align-items: center;
}

.page-mark {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  border-radius: 26rpx;
  border: 2rpx solid #F3B56F;
  background: #FFF4E4;
  color: #2E5B73;
  font-size: 34rpx;
  font-weight: 800;
}

.summary-copy {
  min-width: 0;
  flex: 1;
  margin-left: 22rpx;
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.group-title,
.group-count,
.order-status,
.payment-badge,
.order-time,
.order-id,
.order-summary,
.meta-label,
.meta-value,
.order-total,
.order-link,
.empty-title,
.empty-body,
.loading-title,
.loading-body,
.clear-link {
  display: block;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.15;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}

.summary-metrics {
  margin-top: 24rpx;
}

.metric-chip {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #F4F7F9;
}

.metric-chip + .metric-chip {
  margin-left: 12rpx;
}

.metric-chip.accent {
  background: #FFF3E6;
}

.metric-value {
  color: #1F2A33;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.15;
}

.metric-label {
  margin-top: 6rpx;
  color: #756756;
  font-size: 20rpx;
  line-height: 1.25;
}

.toolbar-card,
.group-list,
.empty-card,
.loading-card {
  margin-top: 20rpx;
}

.search-input {
  box-sizing: border-box;
  min-width: 0;
  height: 72rpx;
  flex: 1;
  padding: 0 22rpx;
  border: 1rpx solid #E3D5C4;
  border-radius: 18rpx;
  background: #FFFDF8;
  color: #1F2A33;
  font-size: 26rpx;
  line-height: 72rpx;
}

.search-button {
  box-sizing: border-box;
  width: 144rpx;
  height: 72rpx;
  margin-left: 14rpx;
  padding: 0;
  border: none;
  border-radius: 18rpx;
  background: #2E5B73;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.search-button::after {
  border: none;
}

.filter-row {
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.filter-pill {
  box-sizing: border-box;
  min-width: 92rpx;
  height: 56rpx;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #F4F7F9;
  color: #697783;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 56rpx;
  text-align: center;
}

.filter-pill.active {
  background: #FFF3E6;
  color: #8A5F35;
}

.clear-link {
  height: 56rpx;
  margin-left: auto;
  color: #2E5B73;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.group-card {
  border-radius: 28rpx;
}

.group-card + .group-card {
  margin-top: 18rpx;
}

.group-head,
.order-foot {
  justify-content: space-between;
}

.group-title {
  color: #1F2A33;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.group-count {
  color: #756756;
  font-size: 22rpx;
  font-weight: 700;
}

.order-card {
  box-sizing: border-box;
  margin-top: 18rpx;
  padding: 22rpx;
  border: 1rpx solid #F0E2D0;
  border-radius: 24rpx;
  background: #FFFDF8;
}

.order-head {
  justify-content: space-between;
}

.order-status-wrap {
  min-width: 0;
  flex: 1;
}

.order-status,
.payment-badge {
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
}

.order-status {
  background: #FFF3E6;
  color: #8A5F35;
}

.payment-badge {
  margin-left: 8rpx;
  background: #F8EDEA;
  color: #B6463A;
}

.order-time {
  max-width: 210rpx;
  margin-left: 16rpx;
  color: #756756;
  font-size: 20rpx;
  line-height: 1.2;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.order-summary {
  margin-top: 18rpx;
  color: #1F2A33;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.order-id {
  margin-top: 8rpx;
  color: #697783;
  font-size: 22rpx;
  line-height: 1.3;
}

.order-meta-grid {
  flex-wrap: wrap;
  margin-top: 16rpx;
  margin-left: -6rpx;
  margin-right: -6rpx;
}

.meta-chip {
  box-sizing: border-box;
  width: 33.333%;
  min-width: 0;
  padding: 0 6rpx;
}

.meta-label {
  color: #9A8A78;
  font-size: 20rpx;
  line-height: 1.2;
}

.meta-value {
  margin-top: 6rpx;
  color: #31414D;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.order-foot {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0E2D0;
}

.order-total {
  color: #1F2A33;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.2;
}

.order-link {
  color: #2E5B73;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.empty-card,
.loading-card {
  text-align: center;
}

.empty-title,
.loading-title {
  color: #1F2A33;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.2;
}

.empty-body,
.loading-body {
  margin-top: 10rpx;
  color: #756756;
  font-size: 24rpx;
  line-height: 1.4;
}
