<view class="orders-page">
  <view class="summary-card">
    <view class="summary-head">
      <view class="page-mark">单</view>
      <view class="summary-copy">
        <text class="page-title">{{pageTitle}}</text>
        <text class="page-subtitle">{{pageSubtitle}}</text>
      </view>
    </view>

    <view class="summary-metrics">
      <view class="metric-chip accent">
        <text class="metric-value">{{summary.totalOrders}}</text>
        <text class="metric-label">{{summaryOrderLabel}}</text>
      </view>
      <view class="metric-chip">
        <text class="metric-value">{{summary.activeGroups}}</text>
        <text class="metric-label">履约分组</text>
      </view>
      <view class="metric-chip">
        <text class="metric-value">{{summary.pendingPayment}}</text>
        <text class="metric-label">待支付</text>
      </view>
    </view>
  </view>

  <view class="toolbar-card">
    <view class="search-row">
      <input
        class="search-input"
        placeholder="订单号、用户、商品"
        value="{{draftKeyword}}"
        bindinput="handleKeywordInput"
        confirm-type="search"
        bindconfirm="handleKeywordConfirm"
      />
      <button class="search-button" bindtap="handleKeywordConfirm">搜索</button>
    </view>

    <view class="filter-row">
      <view
        class="filter-pill {{activeMode === item.value ? 'active' : ''}}"
        wx:for="{{filters}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="handleFilterTap"
      >
        {{item.label}}
      </view>
      <text class="clear-link" wx:if="{{keyword}}" bindtap="handleClearSearch">清空</text>
    </view>
  </view>

  <view class="empty-card" wx:if="{{isEmpty && !loading}}">
    <text class="empty-title">{{emptyTitle}}</text>
    <text class="empty-body">{{emptyBody}}</text>
  </view>

  <view class="group-list" wx:elif="{{!loading}}">
    <view class="group-card" wx:for="{{groups}}" wx:key="groupLabel">
      <view class="group-head">
        <text class="group-title">{{item.groupLabel}}</text>
        <text class="group-count">{{item.countLabel}}</text>
      </view>

      <view
        class="order-card"
        wx:for="{{item.orders}}"
        wx:for-item="order"
        wx:key="id"
        data-order-id="{{order.id}}"
        bindtap="handleOrderTap"
      >
        <view class="order-head">
          <view class="order-status-wrap">
            <text class="order-status">{{order.statusLabel}}</text>
            <text class="payment-badge" wx:if="{{order.secondaryBadgeLabel}}">{{order.secondaryBadgeLabel}}</text>
          </view>
          <text class="order-time">{{order.createdAtLabel}}</text>
        </view>

        <text class="order-summary">{{order.itemSummary}}</text>
        <text class="order-id">{{order.orderIdLabel}}</text>

        <view class="order-meta-grid">
          <view class="meta-chip">
            <text class="meta-label">客户</text>
            <text class="meta-value">{{order.customerLabel}}</text>
          </view>
          <view class="meta-chip">
            <text class="meta-label">预约</text>
            <text class="meta-value">{{order.scheduleLabel}}</text>
          </view>
          <view class="meta-chip">
            <text class="meta-label">方式</text>
            <text class="meta-value">{{order.fulfillmentLabel}}</text>
          </view>
        </view>

        <view class="order-foot">
          <text class="order-total">{{order.payableTotalLabel}}</text>
          <text class="order-link">查看详情</text>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-card" wx:else>
    <text class="loading-title">正在加载订单</text>
    <text class="loading-body">稍后按履约进度显示</text>
  </view>
</view>
